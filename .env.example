# ─── Sendero × Arc — environment ─────────────────────────────────────────────

# ─── App URLs ───────────────────────────────────────────────────────────────
# Local QA:
#   NEXT_PUBLIC_APP_URL=http://localhost:3010
#   NEXT_PUBLIC_SENDERO_GUEST_LINK_ORIGIN=http://localhost:3010
# Production:
#   set both to the deployed app origin that serves /app, /g, and /invoice.
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_SENDERO_GUEST_LINK_ORIGIN=http://localhost:3010

# ─── Neon Postgres (@sendero/database) ──────────────────────────────────────
# Console: https://console.neon.tech
# Use the POOLED URL for DATABASE_URL (serverless / edge / app runtime)
# and the DIRECT URL for DIRECT_URL (migrations only).
DATABASE_URL=postgresql://user:pass@host-pooler.neon.tech/sendero?sslmode=require
DIRECT_URL=postgresql://user:pass@host.neon.tech/sendero?sslmode=require
# "neon" = WebSocket serverless driver (edge). "node" = default Prisma pool (dev).
SENDERO_DB_DRIVER=node

# ─── LLM providers (AI agent) ─────────────────────────────────────────────────
# Preferred: Vercel AI Gateway (Gemini-first routing; see README).
# Direct cascade when the gateway is absent or fails: Gemini → OpenAI → Anthropic.
AI_GATEWAY_API_KEY=
# Google AI Studio / Gemini API (same key works for gateway BYOK + direct @ai-sdk/google)
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_API_KEY=   # optional alias for GOOGLE_GENERATIVE_AI_API_KEY
# Get direct keys: https://console.anthropic.com/settings/keys / https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=

# ─── Duffel (flights + hotels) ──────────────────────────────────────────────
# Sandbox: https://duffel.com/docs/guides/quick-start
# Live tokens start with "duffel_live_"; sandbox with "duffel_test_"
DUFFEL_API_TOKEN=duffel_test_...
DUFFEL_ENV=test
DUFFEL_WEBHOOK_SECRET=

# ─── Svix (outbound/customer webhooks) ──────────────────────────────────────
# Dashboard: https://dashboard.svix.com
# Optional for local QA. Required only when creating customer webhook portal
# links or publishing Sendero tenant events to customer endpoints.
SVIX_TOKEN=
SVIX_SERVER_URL=https://api.us.svix.com

# ─── Email (guest invites + platform invoices) ──────────────────────────────
# Console: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
SENDERO_EMAIL_FROM=Sendero <hello@sendero.travel>
SENDERO_EMAIL_REPLY_TO=
SENDERO_SUPPORT_EMAIL=hello@sendero.travel

# ─── Circle Developer-Controlled Wallets (treasury) ─────────────────────────
# Console: https://console.circle.com/wallets/dev/api-keys
# Entity secret: https://developers.circle.com/w3s/docs/generate-entity-secret-ciphertext
CIRCLE_API_KEY=TEST_API_KEY:...
CIRCLE_ENTITY_SECRET_CIPHERTEXT=...
# Wallet set + treasury wallet (created once, then cached here)
CIRCLE_WALLET_SET_ID=
CIRCLE_TREASURY_WALLET_ID=
CIRCLE_TREASURY_ADDRESS=0x...

# ─── Arc L2 (Circle's USDC-native chain) ────────────────────────────────────
# Arc Testnet RPC: https://docs.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
# Arc Testnet native USDC (also the gas token)
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
ARC_EXPLORER_URL=https://testnet.arcscan.app
# Deployed SenderoGuestEscrow. Set every alias to the same address to avoid
# server/client drift while the codebase still supports legacy names.
ARC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_ARC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_SENDERO_GUEST_ESCROW=0x...

# Operator EOA for App Kit, Gateway, nanopay splits, and escrow smokes.
TREASURY_PRIVATE_KEY=0x...
TREASURY_VIEM_ADDRESS=0x...
SENDERO_TREASURY_ADDRESS=0x...

# Cron / operational fallbacks.
CRON_SECRET=
INVOICE_SIGNING_SECRET=
BLOB_READ_WRITE_TOKEN=

# ─── Clerk (SaaS auth: orgs, roles, billing tier) ───────────────────────
# Dashboard: https://dashboard.clerk.com
# Create an Application → copy the keys from API Keys.
# Local / Preview: use Test keys (pk_test_…, sk_test_…).
# Vercel Production: use Production keys (pk_live_…, sk_live_…); `bun run env:validate`
# fails the build on production if test keys are still set.
# Required for all authed routes. Webhook secret signs org/user.created events.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
# Optional. Comma-separated extra origins for OAuth return URLs (staging domains, etc.).
# Defaults already include NEXT_PUBLIC_APP_URL, NEXT_PUBLIC_SITE_URL, VERCEL_URL, and
# localhost:3010 + localhost:3011 in development.
# NEXT_PUBLIC_CLERK_ALLOWED_REDIRECT_ORIGINS=https://staging-app.example.com,https://staging.example.com
# Auth routing (defaults below are what apps/app middleware expects).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# After auth (legacy name; Clerk still reads this in many setups).
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app/onboarding/passkey
# Prefer these for hosted/invite flows — if unset, Clerk may land on *.accounts.dev/default-redirect.
# See https://clerk.com/docs/guides/development/customize-redirect-urls
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
# Clerk Dashboard → Security (or Session / unrecognized device): Unauthorized sign-in URL — full URL on your app origin, e.g. https://app.sendero.travel/sign-in/unauthorized
# Hackathon default: beta is open unless this is explicitly false/closed/off.
IS_BETA_OPEN=true
# Closed beta list lives in environment, not source. Separate emails/wallets with commas or newlines.
# For post-demo hardening, mirror approved entries into Clerk's Allowlist or Restricted mode.
PRIVATE_BETA_WHITELIST=
# Optional. Defaults to CLERK_SECRET_KEY for signing the private beta access cookie.
PRIVATE_BETA_COOKIE_SECRET=

# ─── Circle Modular Wallets (passkey user auth) ─────────────────────────
# Console: https://console.circle.com/wallets/modular
#   1. Add Passkey Domain: "localhost" (dev) + your prod domain
#   2. Generate Client Key under Modular Wallets → Client Keys
#      Format: TEST_CLIENT_KEY:<id>:<secret>
#      (NOT the App Kit / Swap Kit KIT_KEY: value — that's a different product)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl

# ─── ERC-8004 + ERC-8183 Agent (populated by `bun run bootstrap-agent`) ─────
# Run scripts/bootstrap-agent.ts ONCE after treasury is faucet-funded.
# It creates wallets, mints the Sendero agent NFT, seeds reputation events.
SENDERO_PROVIDER_WALLET_ID=
SENDERO_PROVIDER_ADDRESS=
SENDERO_AGENT_ID=
DEMO_CLIENT_WALLET_ID=
DEMO_CLIENT_ADDRESS=
AUX_VALIDATOR_1_WALLET_ID=
AUX_VALIDATOR_1_ADDRESS=
AUX_VALIDATOR_2_WALLET_ID=
AUX_VALIDATOR_2_ADDRESS=
# Optional: custom metadata URI for the agent NFT (defaults to Sendero's hosted JSON)
SENDERO_METADATA_URI=
