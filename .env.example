# ─── Sendero × Arc — environment ─────────────────────────────────────────────
# Run `bun run scripts/config-doctor.ts` after editing to verify this file
# matches what the codebase actually reads. CI gates on a clean diff.

# === App URLs ===
# Local QA:
#   NEXT_PUBLIC_APP_URL=http://localhost:3010
#   NEXT_PUBLIC_SENDERO_GUEST_LINK_ORIGIN=http://localhost:3010
# Production: set every *_URL to the deployed origin. NEXT_PUBLIC_APP_URL is
# the canonical app origin (serves /app, /g, /invoice). Marketing/help/docs
# live on sibling subdomains.
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_SENDERO_GUEST_LINK_ORIGIN=http://localhost:3010
# Server-side aliases for the app origin. Read by the indexer dispatcher
# (apps/ponder) when it posts back into /api/internal/* routes. Either
# alias works; both are checked so deploys can keep their existing naming.
APP_ORIGIN=http://localhost:3010
SENDERO_APP_ORIGIN=http://localhost:3010
# Marketing/site origin. Used by clerk allowed-origins, llms.txt, layout SEO.
NEXT_PUBLIC_SITE_URL=https://sendero.travel
# Help center origin. Read by edge worker + llms.txt fanout.
NEXT_PUBLIC_HELP_URL=https://help.sendero.travel
# Docs origin. Read by edge worker + llms.txt fanout.
NEXT_PUBLIC_DOCS_URL=https://docs.sendero.travel
# Edge worker origin (Cloudflare Workers). Used in storybook + edge bootstrap.
NEXT_PUBLIC_SENDERO_EDGE_URL=http://localhost:3021
# Server-side alias for the edge URL (read by apps/edge/src/index.ts itself).
SENDERO_EDGE_URL=http://localhost:3021

# === Neon Postgres (@sendero/database) ===
# Console: https://console.neon.tech
# Use the POOLED URL for DATABASE_URL (serverless / edge / app runtime)
# and the DIRECT URL for DIRECT_URL (migrations only).
DATABASE_URL=postgresql://user:pass@host-pooler.neon.tech/sendero?sslmode=require
# Read by Prisma directly via packages/database/prisma/schema.prisma. Not
# referenced as process.env in TS, so config-doctor is told to skip it.
DIRECT_URL=postgresql://user:pass@host.neon.tech/sendero?sslmode=require
# Unpooled connection used by `pg.Client` LISTEN/NOTIFY in
# apps/app/lib/pg-listen.ts. Required for the wallet balance SSE stream;
# falls back to slow-poll when missing.
DATABASE_URL_UNPOOLED=postgresql://user:pass@host.neon.tech/sendero?sslmode=require
# Ponder indexer prefers the private (intra-region) connection, falls back to
# DATABASE_URL. Set on Railway/Fly when both URLs are exposed.
DATABASE_PRIVATE_URL=
# "neon" = WebSocket serverless driver (edge). "node" = default Prisma pool (dev).
SENDERO_DB_DRIVER=node
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
PASSPORT_VAULT_KEK=

# === Circle Gateway — Solana destination support (Phase 4) ===
# Sendero's Solana relayer keypair. Pays SOL gas for `gatewayMint` calls
# when transferring USDC from EVM → Solana via Circle Gateway. Single
# platform-level keypair, not per-tenant — tenant attribution lives in
# the burn intent's sourceDepositor field.
#
# Format: base58-encoded secret (Phantom export) OR JSON array of bytes
# (Solana CLI keypair). Generate with `solana-keygen new --outfile k.json`
# then `cat k.json` for the JSON array, or use Phantom to export base58.
#
# Operator runbook: docs/PHASE_4_SOLANA_RUNBOOK.md
#
# Without this set, Solana destination transfers fail loudly. EVM-only
# operations are unaffected.
SENDERO_GATEWAY_SOLANA_RELAYER_SECRET_KEY=

# === Encryption KEK provider ===
# env = read SENDERO_KEK / SENDERO_KEK_V<N>; gcp-kms = decrypt
# SENDERO_KEK_CIPHERTEXT / SENDERO_KEK_CIPHERTEXT_V<N> with Google Cloud KMS.
SENDERO_KEK_PROVIDER=env

# === Prisma Data Platform — Accelerate + Pulse ===
# Console: https://console.prisma.io
# Both are opt-in sibling clients alongside the default `prisma` singleton.
# The default workhorse keeps using DATABASE_URL via Neon adapter; these
# unlock cached reads + real-time subscriptions for new code paths.
#
# Accelerate: connection pool + query cache. Use `prismaAccelerated` from
# @sendero/database/accelerate on hot reads with `cacheStrategy.ttl`.
# Falls back to DATABASE_URL when unset (Accelerate becomes a no-op
# pass-through), so local dev works without Prisma Data Platform setup.
PRISMA_ACCELERATE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=...
# Pulse: real-time row-change subscriptions. Use `createPulseClient()` from
# @sendero/database/pulse for new live surfaces (deposit/transfer feeds,
# operator dashboards). REQUIRED if Pulse is used — factory throws when
# unset rather than silently never firing.
PULSE_API_KEY=

# === LLM providers (AI agent) ===
# Preferred: Vercel AI Gateway (Gemini-first routing; see README).
# Direct cascade when the gateway is absent or fails: Gemini → OpenAI → Anthropic.
AI_GATEWAY_API_KEY=
# Force a specific provider regardless of available keys. Optional.
# One of: gateway | google | openai | anthropic
AI_PROVIDER=
# Google AI Studio / Gemini API (same key works for gateway BYOK + direct @ai-sdk/google)
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional alias for GOOGLE_GENERATIVE_AI_API_KEY. Picked up by packages/tools/src/agent.ts.
GEMINI_API_KEY=
# Get direct keys: https://console.anthropic.com/settings/keys / https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=

# === Vertex AI / Gemini (OCR + multimodal) ===
# Read by packages/ocr/src/providers/gemini-multimodal.ts. Optional —
# only set when running OCR via Vertex instead of the AI SDK gateway path.
# Service-account JSON, base64-encoded or raw. Loaded via GoogleAuth.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Project ID. Any one of these three is accepted (in priority order).
GCLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT=
GOOGLE_VERTEX_PROJECT=
# Vertex region. Defaults to us-central1 if neither is set.
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VERTEX_LOCATION=us-central1
# Google Maps Platform key (used by the in-trip concierge for Places).
# https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=
# Optional fallback shared key for Maps + Places when GOOGLE_MAPS_API_KEY isn't set.
GOOGLE_API_KEY=
# Dedicated Places key. Read by packages/env/src/index.ts when the
# concierge needs Places-only scoping (typeahead + nearby search). Falls
# back to GOOGLE_API_KEY when unset.
GOOGLE_PLACES_API_KEY=

# === Duffel (flights + hotels) ===
# Sandbox: https://duffel.com/docs/guides/quick-start
# Live tokens start with "duffel_live_"; sandbox with "duffel_test_"
DUFFEL_API_TOKEN=duffel_test_...
DUFFEL_ENV=test
DUFFEL_WEBHOOK_SECRET=

# === Sherpa (visa requirements) ===
# Sherpa partner API. Read by packages/sherpa/src/client.ts.
# Console: https://sherpa.travel — request partner credentials via sales.
SHERPA_API_KEY=
# Optional override; defaults to prod URL in production, dev URL otherwise.
SHERPA_API_BASE_URL=
# Per-request timeout in ms. Optional (default 4500).
SHERPA_API_TIMEOUT_MS=4500
# HMAC secret used to verify Sherpa webhook callbacks at /api/webhooks/sherpa.
SHERPA_WEBHOOK_SECRET=

# === Svix (outbound/customer webhooks) ===
# Dashboard: https://dashboard.svix.com
# Optional for local QA. Required only when creating customer webhook portal
# links or publishing Sendero tenant events to customer endpoints.
SVIX_TOKEN=
SVIX_SERVER_URL=https://api.us.svix.com

# === Email (guest invites + platform invoices) ===
# Console: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
SENDERO_EMAIL_FROM=Sendero <hello@sendero.travel>
SENDERO_EMAIL_REPLY_TO=
SENDERO_SUPPORT_EMAIL=hello@sendero.travel

# === Circle Developer-Controlled Wallets (treasury) ===
# Console: https://console.circle.com/wallets/dev/api-keys
# Entity secret: https://developers.circle.com/w3s/docs/generate-entity-secret-ciphertext
CIRCLE_API_KEY=TEST_API_KEY:...
# Pre-encryption entity secret (raw, used by SDKs that handle the encryption
# step themselves — `@sendero/circle/wallets`). Never log or commit. The
# *_CIPHERTEXT below is the same value pre-encrypted for the bare Circle API.
CIRCLE_ENTITY_SECRET=...
CIRCLE_ENTITY_SECRET_CIPHERTEXT=...
# Optional: Circle App Kit publishable key for embedded widgets.
CIRCLE_KIT_KEY=ck_pub_...
# Wallet set + treasury wallet (created once, then cached here)
CIRCLE_WALLET_SET_ID=
CIRCLE_TREASURY_WALLET_ID=
CIRCLE_TREASURY_ADDRESS=0x...

# Platform-level walletset that owns every traveler DCW. Set once per env;
# `ensureTravelerWallet` derives a child wallet under this set keyed on
# User.id. Sendero pays Circle; tenant context lives at the policy layer,
# not the wallet layer.
SENDERO_WALLETSET_ID=
# Server-held delegate EOA for App Kit's UnifiedBalanceKit (used by the
# /api/transfer/spend route to sign on the traveler's behalf — DCW model,
# travelers never see a key). Generate with: openssl rand -hex 32, then
# fund with a small amount of Arc gas.
SENDERO_UB_DELEGATE_PRIVATE_KEY=

# === Arc L2 (Circle's USDC-native chain) ===
# Arc Testnet RPC: https://docs.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
# Arc Testnet native USDC (also the gas token)
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
ARC_EXPLORER_URL=https://testnet.arcscan.app
# Browser-side mirror so prefund-success + tx-receipt UIs can deep-link to Arcscan.
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
# Deployed SenderoGuestEscrow. Set every alias to the same address to avoid
# server/client drift while the codebase still supports legacy names.
ARC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_ARC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_SENDERO_GUEST_ESCROW=0x...
SENDERO_GUEST_ESCROW=0x...
# First block of the escrow deploy. Used by ponder + balance scans to bound history.
ARC_ESCROW_DEPLOY_BLOCK=
# Public-side Arc chain config (browser bundle).
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
# Optional WebSocket endpoint for live block streams. Falls back to the RPC URL.
NEXT_PUBLIC_ARC_WS_URL=
# Force network mode override. One of: testnet-beta | production. Auto-derived
# from ARC_CHAIN_ID otherwise. Flip to `production` when Arc mainnet ships.
SENDERO_NETWORK_MODE=
# Chain selector for settlement-v2 dispatching. One of: arc-testnet | arc.
# Defaults via SENDERO_NETWORK_MODE; set explicitly to override per env.
SENDERO_CHAIN=arc-testnet

# Operator EOA for App Kit, Gateway, nanopay splits, and escrow smokes.
TREASURY_PRIVATE_KEY=0x...
TREASURY_VIEM_ADDRESS=0x...
SENDERO_TREASURY_ADDRESS=0x...

# Operator EOA private key for SenderoGuestEscrow operator-only writes
# (`setClaimCodeHash`, `cancelTrip`, `sweepUnspent`). Address derived from
# this key MUST equal `ARC_OPERATOR` set at escrow init time. Either env
# alias works; both are checked. Generate with: openssl rand -hex 32.
OPERATOR_PRIVATE_KEY=
ARC_OPERATOR_PRIVATE_KEY=

# Deployed SenderoStamps proxy + circle contract id (used by the stamps
# event monitor + OG previews). See contracts deploy runbook in CLAUDE.md.
SENDERO_STAMPS_ADDRESS=0x...

# x402 paid-tools seller address (apps/edge). Falls back to TREASURY_VIEM_ADDRESS.
SENDERO_SELLER_ADDRESS=0x...

# Cron / operational fallbacks.
CRON_SECRET=
INVOICE_SIGNING_SECRET=
# HMAC key for /api/og/share?token=… payloads. Distinct from
# INVOICE_SIGNING_SECRET so unfurl-card signing rotates independently
# of long-lived invoice URLs. Generate with `openssl rand -hex 32`.
OG_SHARE_SIGNING_SECRET=
BLOB_READ_WRITE_TOKEN=

# === MCPB stdio→HTTP proxy (apps/mcpb/server/index.ts) ===
# These env vars are injected by Claude Desktop from the MCPB user_config
# fields when an end-user installs sendero.mcpb. They are NOT set in the
# Sendero monorepo's own runtime — only inside the bundled proxy process
# on the user's machine. Documented here so config-doctor knows about them.
SENDERO_API_KEY=
SENDERO_MCP_URL=https://app.sendero.travel/api/mcp

# === @sendero/cli (packages/cli/src/index.ts) ===
# Override the API base for the CLI. Same shape as SENDERO_MCP_URL but
# scoped to whoami/openapi.json/MCP dispatch. End-user env, not monorepo
# runtime — documented for config-doctor parity.
SENDERO_API_URL=https://app.sendero.travel
# Standard NO_COLOR opt-out (https://no-color.org). End-user env;
# any truthy value disables ANSI color in the CLI output formatter
# (packages/cli/src/output/formatter.ts).
NO_COLOR=

# === Passport debug (apps/app/lib/passport-debug.ts) ===
# Set to 1 to enable verbose passport-flow logging. Server-only and client-
# exposed variants are separate so a public site preview never trips into
# debug mode by inheriting a server flag.
DEBUG_PASSPORT=
NEXT_PUBLIC_DEBUG_PASSPORT=

# Agent dispatch shared secret used by internal channel webhooks. Compared
# constant-time. Rotate quarterly. Never revert to `===`.
AGENT_DISPATCH_SECRET=
# Indexer → app dispatch shared secret. apps/ponder uses this to authenticate
# POSTs back into /api/internal/billing/* and /api/internal/security-alerts/*
# (settlement-v2 observer + claim-lockout alert fanout). Rotate alongside
# AGENT_DISPATCH_SECRET.
INDEXER_DISPATCH_SECRET=

# === Clerk (SaaS auth: orgs, roles, billing tier) ===
# Dashboard: https://dashboard.clerk.com
# Create an Application → copy the keys from API Keys.
# Local / Preview: use Test keys (pk_test_…, ak_…).
# Vercel Production: use Production keys (pk_live_…, sk_live_…); `bun run env:validate`
# fails the build on production if test keys are still set.
# Required for all authed routes. Webhook secret signs org/user.created events.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=ak_...
CLERK_WEBHOOK_SECRET=whsec_...
# Optional. When `true` the user-details panel renders a demo identity
# (no Clerk lookup) — used in screenshots / Storybook flows.
NEXT_PUBLIC_CLERK_DEMO_MODE=false
# Optional. Comma-separated extra origins for OAuth return URLs (staging domains, etc.).
# Defaults already include NEXT_PUBLIC_APP_URL, NEXT_PUBLIC_SITE_URL, VERCEL_URL, and
# localhost:3010 + localhost:3011 in development.
NEXT_PUBLIC_CLERK_ALLOWED_REDIRECT_ORIGINS=
# Auth routing. Auto-discovered by Clerk middleware (not grepped by config-doctor).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# After auth (legacy name; Clerk still reads this in many setups).
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app/onboarding/passkey
# Prefer these for hosted/invite flows — if unset, Clerk may land on *.accounts.dev/default-redirect.
# See https://clerk.com/docs/guides/development/customize-redirect-urls
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
# Pin the ClerkProvider's clerk-js + UI bundle versions. Optional — defaults
# baked into apps/app/app/layout.tsx are kept current with each Clerk upgrade.
NEXT_PUBLIC_CLERK_JS_VERSION=
NEXT_PUBLIC_CLERK_UI_VERSION=

# === Beta gating ===
# Hackathon default: beta is open unless this is explicitly false/closed/off.
IS_BETA_OPEN=true
# Closed beta list lives in environment, not source. Separate emails/wallets with commas or newlines.
# For post-demo hardening, mirror approved entries into Clerk's Allowlist or Restricted mode.
PRIVATE_BETA_WHITELIST=
# Aliases accepted by packages/env. Only one of these needs to be set;
# all three resolve to the same allowlist.
PRIVATE_BETA_ALLOWLIST=
SENDERO_PRIVATE_BETA_WHITELIST=
# Optional. Defaults to CLERK_SECRET_KEY for signing the private beta access cookie.
PRIVATE_BETA_COOKIE_SECRET=

# === Circle Modular Wallets (passkey user auth) ===
# Console: https://console.circle.com/wallets/modular
#   1. Add Passkey Domain: "localhost" (dev) + your prod domain
#   2. Generate Client Key under Modular Wallets → Client Keys
#      Format: TEST_CLIENT_KEY:<id>:<secret>
#      (NOT the App Kit / Swap Kit KIT_KEY: value — that's a different product)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl
# Modular-prefixed aliases — accepted as fallbacks by packages/circle.
NEXT_PUBLIC_CIRCLE_MODULAR_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_MODULAR_CLIENT_URL=

# === ERC-8004 + ERC-8183 Agent (populated by `bun run bootstrap-agent`) ===
# Run scripts/bootstrap-agent.ts ONCE after treasury is faucet-funded.
# It creates wallets, mints the Sendero agent NFT, seeds reputation events.
SENDERO_PROVIDER_WALLET_ID=
SENDERO_PROVIDER_ADDRESS=
SENDERO_AGENT_ID=
# Optional alias used by guest-escrow tool. Same value as SENDERO_AGENT_ID.
SENDERO_AGENT_TOKEN_ID=
DEMO_CLIENT_ADDRESS=
AUX_VALIDATOR_1_ADDRESS=

# === WhatsApp / Meta Graph API ===
# First-party WhatsApp Cloud API path. Read by packages/env +
# webhooks. Get values from https://developers.facebook.com/apps.
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Override Graph base URL when proxying. Optional.
WHATSAPP_API_BASE_URL=
# Default country code (E.164 region) when normalizing phone numbers. Optional.
WHATSAPP_DEFAULT_COUNTRY=US
# Dev-only fallback tenant id for unmapped phoneNumberId webhooks. Leave unset in prod.
WHATSAPP_DEFAULT_TENANT_ID=
# Meta App credentials for WA Embedded Signup + Graph health probe.
META_APP_ID=
META_APP_SECRET=
# Public-side bundle for the Embedded Signup button.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_ES_CONFIG_ID=
# Pin the Graph API version. Optional (default v21.0).
META_GRAPH_API_VERSION=v21.0

# === Kapso (WhatsApp BSP) ===
# BYO WhatsApp via Kapso. Console: https://app.kapso.ai
# Sendero-owned Kapso phone slots are platform inventory for support,
# sandbox, and ops. Tenant traffic should use BYO dedicated numbers
# through WhatsAppInstall, not the included Sendero support slots.
# Required when KAPSO is the active WhatsApp adapter. See packages/kapso.
KAPSO_API_KEY=
KAPSO_API_BASE_URL=https://api.kapso.ai
# Public origin Kapso posts BYO events to. Defaults to NEXT_PUBLIC_APP_URL when unset.
# Override in dev with an ngrok tunnel.
KAPSO_WEBHOOK_BASE_URL=
# Shared secret Kapso signs the project/global provisioning webhook with.
# This is verified by `apps/app/app/api/webhooks/kapso/route.ts` for
# `whatsapp.phone_number.created`.
KAPSO_GLOBAL_WEBHOOK_SECRET=
# Customer-service/tool-call fallback secret accepted by
# `/api/internal/support/tools`. Kapso support + tenant agent functions use
# SUPPORT_TOOLS_SECRET when set, otherwise this value.
KAPSO_WEBHOOK_SECRET=
# Kapso workflow id for the tenant travel operations agent. Used to attach
# inbound triggers after a paid tenant connects a dedicated WhatsApp number.
KAPSO_TENANT_WORKFLOW_ID=
SUPPORT_TOOLS_SECRET=

# === Slack ===
# Slack OAuth + bot for the corporate channel + ops alerts.
# Get these from https://api.slack.com/apps/<app-id>.
# Bot token (xoxb-...). Required for ops alert delivery in packages/slack.
SLACK_BOT_TOKEN=xoxb-...
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=
# HMAC-SHA256 secret used to sign OAuth state. Falls back to CLERK_SECRET_KEY
# when unset; set explicitly in production. See apps/app/lib/slack-oauth-state.ts.
SLACK_STATE_SECRET=
# Channel ID (C0XXXXXXX) where ops alerts post. Required for alert routing.
SENDERO_OPS_SLACK_CHANNEL_ID=

# === Upstash Redis (KV cache) ===
# Provisioned via Vercel Marketplace (`upstash-kv-orange-leaf`). The KV_*
# names are stamped automatically by `vercel env pull` on every scope.
# UPSTASH_* aliases are accepted as a fallback for local dev.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === PostHog (product analytics) ===
# Server keys (write events from API routes / cron).
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# Browser bundle. Falls back to the server values when unset.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Liveblocks (realtime collaboration) ===
# Console: https://liveblocks.io/dashboard. Used by packages/collaboration.
LIVEBLOCKS_SECRET_KEY=
LIVEBLOCKS_WEBHOOK_SECRET_KEY=
SENDERO_AGENT_WEBHOOK_SECRET=

# === BaseHub (marketing + help CMS) ===
# Console: https://basehub.com. Provides marketing copy and help articles.
# CONTENT_URL points at the BaseHub query endpoint; CONTENT_JSON is a static
# fallback (raw JSON) used when the CMS is unreachable.
BASEHUB_TOKEN=
BASEHUB_MARKETING_CONTENT_URL=
BASEHUB_MARKETING_CONTENT_JSON=
BASEHUB_HELP_CONTENT_URL=
BASEHUB_HELP_CONTENT_JSON=

# === Ponder indexer (apps/ponder) ===
# Per-chain RPC endpoint for the indexer. Optional override; falls back to the
# public Arc testnet RPC.
PONDER_RPC_URL_ARC_TESTNET=
# Escrow address + start block to index. Optional; defaults inline in
# apps/ponder/ponder.config.ts. Set when running against a fresh deploy.
PONDER_ESCROW_ADDRESS=
PONDER_ESCROW_START_BLOCK=
# Local PGlite directory used during dev when DATABASE_URL is absent.
PONDER_PGLITE_DIR=.ponder/pglite

# === Pinata (IPFS for stamp + agent metadata) ===
# Dashboard: https://app.pinata.cloud
# JWT auth is preferred (signed, expirable). Legacy API key/secret work too.
PINATA_JWT=
PINATA_API_KEY=
# Public gateway base used to resolve `ipfs://...` for OG previews + stamp
# metadata renderers. e.g. https://gateway.pinata.cloud or a dedicated host.
PINATA_GATEWAY=https://gateway.pinata.cloud

# === Invoicing (Phase 11b) ===
# Public origin that hosts brand-pinned WOFF2 fonts for the invoice PDF
# renderer. Optional override; defaults to the Vercel Blob CDN URL baked
# into packages/invoicing/src/fonts-server.ts.
INVOICE_FONT_BASE_URL=

# === Social links (footer + help cards) ===
# Public origins for Sendero's external social presence. Optional —
# components fall back to canonical URLs when unset.
NEXT_PUBLIC_SENDERO_X_URL=https://x.com/senderotravel
NEXT_PUBLIC_SENDERO_IG_URL=https://instagram.com/senderotravel
NEXT_PUBLIC_SENDERO_WA_URL=
SENDERO_SUPPORT_WA_NUMBER=12014716388
SENDERO_SUPPORT_WA_URL=https://wa.me/12014716388
NEXT_PUBLIC_SENDERO_SUPPORT_WA_NUMBER=12014716388
NEXT_PUBLIC_SENDERO_SUPPORT_WA_URL=https://wa.me/12014716388

# === Dev tooling ===
# Skip the validate.ts schema check on builds (use sparingly). Set to "1".
SKIP_ENV_VALIDATION=
# Toggle the React-Grab inspector overlay in development. Set to "1" to enable.
NEXT_PUBLIC_ENABLE_REACT_GRAB=
# Playwright e2e bootstrap. Optional; CI wires these up explicitly.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3010
PLAYWRIGHT_STORAGE_STATE=

# === /demo trip — autonomous booking demo ===
# /demo trip slash command in the operator console queues 5 customer prompts
# that drive the real /api/agent/chat pipeline. The agent autonomously fires
# search_flights (Duffel sandbox), book_flight (Duffel hold + pay), faucet_drip
# (treasury → user wallet), settle_booking (Arc-Testnet escrow on-chain),
# mint_stamp (Circle SCP NFT), recommend_restaurants (Google Places).
#
# The demo is tenant-agnostic: every step routes through the signed-in user's
# Clerk session, so any operator in any org can run it. Each tenant uses its
# own treasury wallet (provisioned on org.created) — no per-org pinning here.
NEXT_PUBLIC_DEMO_TRIP_ENABLED=true
# Cheap domestic route — keeps demo USDC burn minimal. Override per market.
NEXT_PUBLIC_DEMO_TRIP_ORIGIN=EZE
NEXT_PUBLIC_DEMO_TRIP_DESTINATION=MDZ

# === Langfuse (@sendero/langfuse — tracing, scoring, prompt management, LLM-judge) ===
# Project-scoped keys from https://us.cloud.langfuse.com → Settings → API Keys
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# Force-enable when keys are present in another env loader. Empty = follow
# auto-detect (enabled when LANGFUSE_PUBLIC_KEY + LANGFUSE_SECRET_KEY are set).
LANGFUSE_ENABLED=
# Pull system prompts (sendero-soul, sendero-*-rules) from Langfuse with hardcoded fallbacks.
# Default false → fallback strings ship straight from the codebase, zero network calls.
LANGFUSE_PROMPT_MANAGEMENT=false
# Run the four travel-domain LLM-judges on every turn (response-quality, hallucination,
# helpfulness, booking-accuracy). Each fires one gpt-4.1-nano call per turn; measure cost
# on a slice before flipping in production.
LANGFUSE_EVALUATORS=false
# base64(LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY) — used by .mcp.json for the Langfuse MCP
# server. Compute with:  echo -n "$LANGFUSE_PUBLIC_KEY:$LANGFUSE_SECRET_KEY" | base64
LANGFUSE_MCP_AUTH=

# === MoonPay buy widget (/me/wallet top-up) ===
# Publishable key (`pk_test_…` for sandbox, `pk_live_…` for production).
# pk_test_ auto-routes to buy-sandbox.moonpay.com which lands USDC on
# base-sepolia → Circle Gateway picks it up into the unified balance.
# Flip to pk_live_ once a real test transaction is verified end-to-end.
NEXT_PUBLIC_MOONPAY_API_KEY=
# Secret signing key paired with the publishable key (`sk_test_…` /
# `sk_live_…`). Used by /api/moonpay/sign to HMAC-sign the widget URL
# search params. NEVER expose to the browser.
MOONPAY_SIGNING_SECRET=
# Webhook secret (`wk_test_…` / `wk_live_…`). Used by future
# /api/webhooks/moonpay route to verify transaction status callbacks
# (transaction.created/updated/failed). Phase D wiring.
MOONPAY_WEBHOOK_SECRET=
# Register https://app.sendero.travel + the ngrok dev host as allowed
# domains in the MoonPay dashboard. When deploying, set both at the
# all-preview scope (no `--git-branch`) AND production — see CLAUDE.md
# → "Vercel env vars: scope to all preview".

# === eSIM Go (book_esim) ===
# Wholesale eSIM aggregator powering book_esim. Sendero owns the
# eSIM Go org (FANTASMITA LLC, org 62178); tenants resell our
# inventory via TenantPricingPolicy.markupConfig.esim. So one key,
# one balance, one webhook path.
# Public docs: https://docs.esim-go.com/api/v2_5/.
ESIM_GO_API_KEY=
# Override the API base URL (defaults to https://api.esim-go.com/v2.5).
ESIM_GO_BASE_URL=
# Order mode: 'validate' | 'transaction'. Default = 'validate' in dev/
# preview, 'transaction' in production. Validate-only runs the full
# eSIM Go pipeline (bundle existence, profile compatibility, error
# responses) WITHOUT debiting balance — perfect for ngrok-backed
# preview deployments.
ESIM_GO_MODE=
# Force the mock provider regardless of ESIM_GO_API_KEY. Use 'mock' in
# tests / CI / local-without-creds; leave unset in preview + prod.
ESIM_PROVIDER=
# Note: there is NO separate webhook signing secret. eSIM Go signs
# inbound usage callbacks (V3) using ESIM_GO_API_KEY itself as the
# HMAC-SHA256 key (base64 output). Enable V3 callbacks + HMAC in the
# eSIM Go portal; receiver URL = `${NEXT_PUBLIC_APP_URL}/api/webhooks/esim-go`.

# === Sendero CLI (@sendero/cli) ===
# Active profile name for `sendero` CLI commands. Selects which credential
# block in ~/.sendero/config.json the CLI authenticates against — empty
# falls back to the "default" profile.
SENDERO_PROFILE=

# === Internal service URLs ===
# Base URL the WhatsApp inbound webhook uses to fan out to internal
# Sendero routes (booking-fanout, dispatch). Defaults to NEXT_PUBLIC_APP_URL
# when unset; explicit override lets dev hit a different ngrok host than
# the public traveler URL.
AGENT_INTERNAL_BASE_URL=

# === Kapso WhatsApp sandbox (Sendero-owned shared number) ===
# Test-mode bindings for the Kapso-provided sandbox number every free
# tenant sees during onboarding. Production tenants get their own
# WABA — see CLAUDE.md "Tenant channel operating goal".
KAPSO_SANDBOX_BUSINESS_ACCOUNT_ID=
KAPSO_SANDBOX_CONFIGURATION_ID=
KAPSO_SANDBOX_DISPLAY_PHONE_NUMBER=
KAPSO_SANDBOX_PHONE_NUMBER_ID=
# Feature flag — set to "true" to expose the WhatsApp sandbox connect
# button on /onboarding/corporate. Default off so accidental flips on
# production don't surface the shared sandbox UI.
SENDERO_ENABLE_WHATSAPP_SANDBOX=

# === Solana platform hot wallet (JIT SOL gas drip) ===
# Base58-encoded keypair for the platform Solana wallet that JIT-drips
# lamports into traveler DCWs before they sign Gateway deposits/spends/
# bridges on Solana. See CLAUDE.md "Solana gas abstraction (platform hot
# wallet)" — bootstrap with `bun apps/app/scripts/_local/provision-solana-platform.ts`.
SENDERO_SOLANA_PLATFORM_PRIVATE_KEY=
# Solana RPC endpoint. Defaults to api.devnet.solana.com when unset.
SENDERO_SOLANA_RPC_URL=

# === Slack ops channel (low-balance alerts) ===
# Channel ID the Sendero customer-support Slack bot posts platform-wallet
# low-balance alerts to. Used by lib/platform-wallet-alerts.ts.
SLACK_CHANNEL_ID=

# === OG image internal base URL ===
# Internal base URL the stamp pipeline uses to fetch boarding-pass OG
# images server-side. Defaults to NEXT_PUBLIC_APP_URL when unset.
OG_INTERNAL_BASE_URL=

# === Demand-driven observability override ===
# Set to "1" to bypass the env gate on report_knowledge_gap +
# list_available_tools (dev-only tools). Reserved for the operator
# dashboard's manual "file gap" surface — NEVER wire into the agent
# runtime. The prod-key reject gate survives the override regardless.
# See ~/.claude/skills/raj-demand-driven-context/SKILL.md.
SENDERO_GAPS_ALLOW_NONDEV=

# ─── Backfill: missing env vars surfaced by config-doctor ───────────────────
# Each entry is referenced from code; documenting here so the
# scripts/config-doctor.ts gate passes. Set values per environment.

# === Public app URL alias ===
# Tools that build deep-links (start_traveler_whatsapp_conversation, share
# pipeline) read APP_URL when NEXT_PUBLIC_APP_URL isn't set in the call site.
APP_URL=
# Same purpose, EVM-side admin: derives Circle MSCA recover/sign deep-links.
NEXT_PUBLIC_APP_HOST=

# === x402 + chain RPC ===
# Base URL the x402 outbound fetch helper resolves chain RPC against.
CHAIN_RPC_BASE=
# Comma-separated allowlist of hostnames x402_fetch may dial. Hard fail-closed
# default — every external host must be enumerated.
X402_OUTBOUND_ALLOWLIST=

# === Circle USDC token IDs (Solana legs) ===
# Per-chain Circle token IDs the nanopay settle path needs for SOL.
CIRCLE_USDC_SOL_DEVNET_TOKEN_ID=
CIRCLE_USDC_SOL_TOKEN_ID=

# === Sendero Solana ops + treasury ===
# Operator pubkey for the deployed sendero_guest_escrow program. Must match
# config.operator on the deployed program; see CLAUDE.md "Solana Anchor
# program runbook (devnet)".
SENDERO_SOLANA_OPERATOR_ADDRESS=
# Sendero platform treasury Solana pubkey — destination for traveler
# settlement reimbursement on sol-primary tenants.
SENDERO_SOLANA_TREASURY_ADDRESS=
# Override the default Circle Solana devnet USDC mint (4zMMC9srt5Ri…cDU).
SENDERO_SOLANA_USDC_MINT=
# Override the auto-detected Metaplex Agent API network. Auto-detect
# reads SENDERO_SOLANA_RPC_URL: 'devnet' substring → 'solana-devnet',
# 'mainnet'/'helius' → 'solana-mainnet', else falls back to devnet.
# Set explicitly to one of: solana-mainnet, solana-devnet, localnet,
# eclipse-mainnet, sonic-mainnet, sonic-devnet, fogo-mainnet, fogo-testnet.
# See packages/metaplex/src/mint-and-register-agent.ts.
SENDERO_METAPLEX_AGENT_NETWORK=

# === Arc bootstrap ===
# EOA private key the admin treasury setup uses to fund the platform-owner
# slot on a freshly-deployed Circle MSCA before handing authority to the
# tenant Squads multisig. apps/admin/lib/treasury/deploy-arc-msca-userop.ts.
SENDERO_ARC_BOOTSTRAP_PRIVATE_KEY=

# === Sandbox / dev tenant routing ===
# Tenant id that receives WhatsApp inbound from the Sendero-owned sandbox
# number. Used by lib/whatsapp-sandbox-routing.ts.
SENDERO_DEV_SANDBOX_TENANT_ID=

# === Anticipation-tools event sources ===
# Eventbrite private token (anticipation/eventbrite-event-discovery).
EVENTBRITE_PRIVATE_TOKEN=
# PredictHQ access token (anticipation/crowd-level-predictor).
PREDICTHQ_ACCESS_TOKEN=
# Ticketmaster API key (anticipation/mainstream-event-discovery).
TICKETMASTER_API_KEY=

# === Web search + Google Places ===
# Google Custom Search v1 API key + engine id (packages/web-search).
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
# Master toggle for the web-search package — set to 'true' to enable.
WEB_SEARCH_ENABLED=
# Set to 'true' to enable Google Places lookups (packages/google-places).
GOOGLE_PLACES_ENABLED=

# === Phoenix / Arize observability ===
# OTel collector endpoint Phoenix consumes.
PHOENIX_COLLECTOR_ENDPOINT=
# Phoenix UI base URL (apps/app spend dashboard fetches traces from here).
PHOENIX_BASE_URL=
# Phoenix API key for the spend dashboard's read calls.
PHOENIX_API_KEY=
# Phoenix project name (defaults to "sendero" when unset).
PHOENIX_PROJECT_NAME=
# Master toggle for the @sendero/arize-phoenix client — 'true' to enable.
PHOENIX_ENABLED=

# === WhatsApp group-flow templates ===
# Per-template names registered with Meta for the group-trip lifecycle
# broadcasts. Read by app/api/groups/[id]/broadcast/route.ts.
WHATSAPP_TPL_GROUP_CHANGE_ALERT=
WHATSAPP_TPL_GROUP_COMPLETION=
WHATSAPP_TPL_GROUP_DAY_OF_REMINDER=
WHATSAPP_TPL_GROUP_MEETING_POINT=
WHATSAPP_TPL_GROUP_SEAT_OPEN=


