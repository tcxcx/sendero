# ─── Sendero × Arc — environment ─────────────────────────────────────────────

# ─── Anthropic (AI agent) ───────────────────────────────────────────────────
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Duffel (flights + hotels) ──────────────────────────────────────────────
# Sandbox: https://duffel.com/docs/guides/quick-start
# Live tokens start with "duffel_live_"; sandbox with "duffel_test_"
DUFFEL_API_TOKEN=duffel_test_...
DUFFEL_ENV=test

# ─── Circle Developer-Controlled Wallets (treasury) ─────────────────────────
# Console: https://console.circle.com/wallets/dev/api-keys
# Entity secret: https://developers.circle.com/w3s/docs/generate-entity-secret-ciphertext
CIRCLE_API_KEY=TEST_API_KEY:...
CIRCLE_ENTITY_SECRET_CIPHERTEXT=...
# Wallet set + treasury wallet (created once, then cached here)
CIRCLE_WALLET_SET_ID=
CIRCLE_TREASURY_WALLET_ID=
CIRCLE_TREASURY_ADDRESS=0x...

# ─── Arc L2 (Circle's USDC-native chain) ────────────────────────────────────
# Arc Testnet RPC: https://docs.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
# Arc Testnet native USDC (also the gas token)
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
ARC_EXPLORER_URL=https://testnet.arcscan.app

# ─── Circle Modular Wallets (passkey user auth) ─────────────────────────
# Console: https://console.circle.com/wallets/modular
#   1. Add Passkey Domain: "localhost" (dev) + your prod domain
#   2. Generate Client Key under Modular Wallets → Client Keys
#      Format: TEST_CLIENT_KEY:<id>:<secret>
#      (NOT the App Kit / Swap Kit KIT_KEY: value — that's a different product)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl

# ─── ERC-8004 + ERC-8183 Agent (populated by `bun run bootstrap-agent`) ─────
# Run scripts/bootstrap-agent.ts ONCE after treasury is faucet-funded.
# It creates wallets, mints the Sendero agent NFT, seeds reputation events.
SENDERO_PROVIDER_WALLET_ID=
SENDERO_PROVIDER_ADDRESS=
SENDERO_AGENT_ID=
DEMO_CLIENT_WALLET_ID=
DEMO_CLIENT_ADDRESS=
AUX_VALIDATOR_1_WALLET_ID=
AUX_VALIDATOR_1_ADDRESS=
AUX_VALIDATOR_2_WALLET_ID=
AUX_VALIDATOR_2_ADDRESS=
# Optional: custom metadata URI for the agent NFT (defaults to Sendero's hosted JSON)
SENDERO_METADATA_URI=
