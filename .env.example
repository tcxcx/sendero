# ─── Sendero × Arc — environment ─────────────────────────────────────────────
# Run `bun run scripts/config-doctor.ts` after editing to verify this file
# matches what the codebase actually reads. CI gates on a clean diff.

# === App URLs ===
# Local QA:
#   NEXT_PUBLIC_APP_URL=http://localhost:3010
#   NEXT_PUBLIC_SENDERO_GUEST_LINK_ORIGIN=http://localhost:3010
# Production: set every *_URL to the deployed origin. NEXT_PUBLIC_APP_URL is
# the canonical app origin (serves /app, /g, /invoice). Marketing/help/docs
# live on sibling subdomains.
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_SENDERO_GUEST_LINK_ORIGIN=http://localhost:3010
# Marketing/site origin. Used by clerk allowed-origins, llms.txt, layout SEO.
NEXT_PUBLIC_SITE_URL=https://sendero.travel
# Help center origin. Read by edge worker + llms.txt fanout.
NEXT_PUBLIC_HELP_URL=https://help.sendero.travel
# Docs origin. Read by edge worker + llms.txt fanout.
NEXT_PUBLIC_DOCS_URL=https://docs.sendero.travel
# Edge worker origin (Cloudflare Workers). Used in storybook + edge bootstrap.
NEXT_PUBLIC_SENDERO_EDGE_URL=http://localhost:3021
# Server-side alias for the edge URL (read by apps/edge/src/index.ts itself).
SENDERO_EDGE_URL=http://localhost:3021

# === Neon Postgres (@sendero/database) ===
# Console: https://console.neon.tech
# Use the POOLED URL for DATABASE_URL (serverless / edge / app runtime)
# and the DIRECT URL for DIRECT_URL (migrations only).
DATABASE_URL=postgresql://user:pass@host-pooler.neon.tech/sendero?sslmode=require
# Read by Prisma directly via packages/database/prisma/schema.prisma. Not
# referenced as process.env in TS, so config-doctor is told to skip it.
DIRECT_URL=postgresql://user:pass@host.neon.tech/sendero?sslmode=require
# Unpooled connection used by `pg.Client` LISTEN/NOTIFY in
# apps/app/lib/pg-listen.ts. Required for the wallet balance SSE stream;
# falls back to slow-poll when missing.
DATABASE_URL_UNPOOLED=postgresql://user:pass@host.neon.tech/sendero?sslmode=require
# Ponder indexer prefers the private (intra-region) connection, falls back to
# DATABASE_URL. Set on Railway/Fly when both URLs are exposed.
DATABASE_PRIVATE_URL=
# "neon" = WebSocket serverless driver (edge). "node" = default Prisma pool (dev).
SENDERO_DB_DRIVER=node
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
PASSPORT_VAULT_KEK=

# === LLM providers (AI agent) ===
# Preferred: Vercel AI Gateway (Gemini-first routing; see README).
# Direct cascade when the gateway is absent or fails: Gemini → OpenAI → Anthropic.
AI_GATEWAY_API_KEY=
# Force a specific provider regardless of available keys. Optional.
# One of: gateway | google | openai | anthropic
AI_PROVIDER=
# Google AI Studio / Gemini API (same key works for gateway BYOK + direct @ai-sdk/google)
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional alias for GOOGLE_GENERATIVE_AI_API_KEY. Picked up by packages/tools/src/agent.ts.
GEMINI_API_KEY=
# Get direct keys: https://console.anthropic.com/settings/keys / https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=

# === Vertex AI / Gemini (OCR + multimodal) ===
# Read by packages/sendero-ocr/src/providers/gemini-multimodal.ts. Optional —
# only set when running OCR via Vertex instead of the AI SDK gateway path.
# Service-account JSON, base64-encoded or raw. Loaded via GoogleAuth.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Project ID. Any one of these three is accepted (in priority order).
GCLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT=
GOOGLE_VERTEX_PROJECT=
# Vertex region. Defaults to us-central1 if neither is set.
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VERTEX_LOCATION=us-central1
# Google Maps Platform key (used by the in-trip concierge for Places).
# https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=
# Optional fallback shared key for Maps + Places when GOOGLE_MAPS_API_KEY isn't set.
GOOGLE_API_KEY=

# === Duffel (flights + hotels) ===
# Sandbox: https://duffel.com/docs/guides/quick-start
# Live tokens start with "duffel_live_"; sandbox with "duffel_test_"
DUFFEL_API_TOKEN=duffel_test_...
DUFFEL_ENV=test
DUFFEL_WEBHOOK_SECRET=

# === Sherpa (visa requirements) ===
# Sherpa partner API. Read by packages/sendero-sherpa/src/client.ts.
# Console: https://sherpa.travel — request partner credentials via sales.
SHERPA_API_KEY=
# Optional override; defaults to prod URL in production, dev URL otherwise.
SHERPA_API_BASE_URL=
# Per-request timeout in ms. Optional (default 4500).
SHERPA_API_TIMEOUT_MS=4500
# HMAC secret used to verify Sherpa webhook callbacks at /api/webhooks/sherpa.
SHERPA_WEBHOOK_SECRET=

# === Svix (outbound/customer webhooks) ===
# Dashboard: https://dashboard.svix.com
# Optional for local QA. Required only when creating customer webhook portal
# links or publishing Sendero tenant events to customer endpoints.
SVIX_TOKEN=
SVIX_SERVER_URL=https://api.us.svix.com

# === Email (guest invites + platform invoices) ===
# Console: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
SENDERO_EMAIL_FROM=Sendero <hello@sendero.travel>
SENDERO_EMAIL_REPLY_TO=
SENDERO_SUPPORT_EMAIL=hello@sendero.travel

# === Circle Developer-Controlled Wallets (treasury) ===
# Console: https://console.circle.com/wallets/dev/api-keys
# Entity secret: https://developers.circle.com/w3s/docs/generate-entity-secret-ciphertext
CIRCLE_API_KEY=TEST_API_KEY:...
# Pre-encryption entity secret (raw, used by SDKs that handle the encryption
# step themselves — `@sendero/circle/wallets`). Never log or commit. The
# *_CIPHERTEXT below is the same value pre-encrypted for the bare Circle API.
CIRCLE_ENTITY_SECRET=...
CIRCLE_ENTITY_SECRET_CIPHERTEXT=...
# Optional: Circle App Kit publishable key for embedded widgets.
CIRCLE_KIT_KEY=ck_pub_...
# Wallet set + treasury wallet (created once, then cached here)
CIRCLE_WALLET_SET_ID=
CIRCLE_TREASURY_WALLET_ID=
CIRCLE_TREASURY_ADDRESS=0x...

# === Arc L2 (Circle's USDC-native chain) ===
# Arc Testnet RPC: https://docs.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
# Arc Testnet native USDC (also the gas token)
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
ARC_EXPLORER_URL=https://testnet.arcscan.app
# Deployed SenderoGuestEscrow. Set every alias to the same address to avoid
# server/client drift while the codebase still supports legacy names.
ARC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_ARC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_SENDERO_GUEST_ESCROW=0x...
SENDERO_GUEST_ESCROW=0x...
# First block of the escrow deploy. Used by ponder + balance scans to bound history.
ARC_ESCROW_DEPLOY_BLOCK=
# Public-side Arc chain config (browser bundle).
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
# Optional WebSocket endpoint for live block streams. Falls back to the RPC URL.
NEXT_PUBLIC_ARC_WS_URL=
# Force network mode override. One of: testnet-beta | production. Auto-derived
# from ARC_CHAIN_ID otherwise. Flip to `production` when Arc mainnet ships.
SENDERO_NETWORK_MODE=

# Operator EOA for App Kit, Gateway, nanopay splits, and escrow smokes.
TREASURY_PRIVATE_KEY=0x...
TREASURY_VIEM_ADDRESS=0x...
SENDERO_TREASURY_ADDRESS=0x...

# x402 paid-tools seller address (apps/edge). Falls back to TREASURY_VIEM_ADDRESS.
SENDERO_SELLER_ADDRESS=0x...

# Cron / operational fallbacks.
CRON_SECRET=
INVOICE_SIGNING_SECRET=
BLOB_READ_WRITE_TOKEN=

# Agent dispatch shared secret used by internal channel webhooks. Compared
# constant-time. Rotate quarterly. Never revert to `===`.
AGENT_DISPATCH_SECRET=

# === Clerk (SaaS auth: orgs, roles, billing tier) ===
# Dashboard: https://dashboard.clerk.com
# Create an Application → copy the keys from API Keys.
# Local / Preview: use Test keys (pk_test_…, sk_test_…).
# Vercel Production: use Production keys (pk_live_…, sk_live_…); `bun run env:validate`
# fails the build on production if test keys are still set.
# Required for all authed routes. Webhook secret signs org/user.created events.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
# Optional. When `true` the user-details panel renders a demo identity
# (no Clerk lookup) — used in screenshots / Storybook flows.
NEXT_PUBLIC_CLERK_DEMO_MODE=false
# Optional. Comma-separated extra origins for OAuth return URLs (staging domains, etc.).
# Defaults already include NEXT_PUBLIC_APP_URL, NEXT_PUBLIC_SITE_URL, VERCEL_URL, and
# localhost:3010 + localhost:3011 in development.
NEXT_PUBLIC_CLERK_ALLOWED_REDIRECT_ORIGINS=
# Auth routing. Auto-discovered by Clerk middleware (not grepped by config-doctor).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# After auth (legacy name; Clerk still reads this in many setups).
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app/onboarding/passkey
# Prefer these for hosted/invite flows — if unset, Clerk may land on *.accounts.dev/default-redirect.
# See https://clerk.com/docs/guides/development/customize-redirect-urls
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
# Pin the ClerkProvider's clerk-js + UI bundle versions. Optional — defaults
# baked into apps/app/app/layout.tsx are kept current with each Clerk upgrade.
NEXT_PUBLIC_CLERK_JS_VERSION=
NEXT_PUBLIC_CLERK_UI_VERSION=

# === Beta gating ===
# Hackathon default: beta is open unless this is explicitly false/closed/off.
IS_BETA_OPEN=true
# Closed beta list lives in environment, not source. Separate emails/wallets with commas or newlines.
# For post-demo hardening, mirror approved entries into Clerk's Allowlist or Restricted mode.
PRIVATE_BETA_WHITELIST=
# Aliases accepted by packages/sendero-env. Only one of these needs to be set;
# all three resolve to the same allowlist.
PRIVATE_BETA_ALLOWLIST=
SENDERO_PRIVATE_BETA_WHITELIST=
# Optional. Defaults to CLERK_SECRET_KEY for signing the private beta access cookie.
PRIVATE_BETA_COOKIE_SECRET=

# === Circle Modular Wallets (passkey user auth) ===
# Console: https://console.circle.com/wallets/modular
#   1. Add Passkey Domain: "localhost" (dev) + your prod domain
#   2. Generate Client Key under Modular Wallets → Client Keys
#      Format: TEST_CLIENT_KEY:<id>:<secret>
#      (NOT the App Kit / Swap Kit KIT_KEY: value — that's a different product)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl
# Modular-prefixed aliases — accepted as fallbacks by packages/sendero-circle.
NEXT_PUBLIC_CIRCLE_MODULAR_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_MODULAR_CLIENT_URL=

# === ERC-8004 + ERC-8183 Agent (populated by `bun run bootstrap-agent`) ===
# Run scripts/bootstrap-agent.ts ONCE after treasury is faucet-funded.
# It creates wallets, mints the Sendero agent NFT, seeds reputation events.
SENDERO_PROVIDER_WALLET_ID=
SENDERO_PROVIDER_ADDRESS=
SENDERO_AGENT_ID=
# Optional alias used by guest-escrow tool. Same value as SENDERO_AGENT_ID.
SENDERO_AGENT_TOKEN_ID=
DEMO_CLIENT_ADDRESS=
AUX_VALIDATOR_1_ADDRESS=

# === WhatsApp / Meta Graph API ===
# First-party WhatsApp Cloud API path. Read by packages/sendero-env +
# webhooks. Get values from https://developers.facebook.com/apps.
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Override Graph base URL when proxying. Optional.
WHATSAPP_API_BASE_URL=
# Default country code (E.164 region) when normalizing phone numbers. Optional.
WHATSAPP_DEFAULT_COUNTRY=US
# Dev-only fallback tenant id for unmapped phoneNumberId webhooks. Leave unset in prod.
WHATSAPP_DEFAULT_TENANT_ID=
# Meta App credentials for WA Embedded Signup + Graph health probe.
META_APP_ID=
META_APP_SECRET=
# Public-side bundle for the Embedded Signup button.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_ES_CONFIG_ID=
# Pin the Graph API version. Optional (default v21.0).
META_GRAPH_API_VERSION=v21.0

# === Kapso (WhatsApp BSP) ===
# BYO WhatsApp via Kapso. Console: https://app.kapso.ai
# Required when KAPSO is the active WhatsApp adapter. See packages/sendero-kapso.
KAPSO_API_KEY=
KAPSO_API_BASE_URL=https://api.kapso.ai
# Public origin Kapso posts BYO events to. Defaults to NEXT_PUBLIC_APP_URL when unset.
# Override in dev with an ngrok tunnel.
KAPSO_WEBHOOK_BASE_URL=
# Shared secret Kapso signs webhook payloads with — verified in
# `apps/app/app/api/webhooks/kapso/route.ts` via constant-time compare.
KAPSO_WEBHOOK_SECRET=

# === Slack ===
# Slack OAuth + bot for the corporate channel + ops alerts.
# Get these from https://api.slack.com/apps/<app-id>.
# Bot token (xoxb-...). Required for ops alert delivery in packages/slack.
SLACK_BOT_TOKEN=xoxb-...
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=
# HMAC-SHA256 secret used to sign OAuth state. Falls back to CLERK_SECRET_KEY
# when unset; set explicitly in production. See apps/app/lib/slack-oauth-state.ts.
SLACK_STATE_SECRET=
# Channel ID (C0XXXXXXX) where ops alerts post. Required for alert routing.
SENDERO_OPS_SLACK_CHANNEL_ID=

# === Upstash Redis (KV cache) ===
# Provisioned via Vercel Marketplace (`upstash-kv-orange-leaf`). The KV_*
# names are stamped automatically by `vercel env pull` on every scope.
# UPSTASH_* aliases are accepted as a fallback for local dev.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === PostHog (product analytics) ===
# Server keys (write events from API routes / cron).
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# Browser bundle. Falls back to the server values when unset.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Liveblocks (realtime collaboration) ===
# Console: https://liveblocks.io/dashboard. Used by packages/collaboration.
LIVEBLOCKS_SECRET_KEY=

# === BaseHub (marketing + help CMS) ===
# Console: https://basehub.com. Provides marketing copy and help articles.
# CONTENT_URL points at the BaseHub query endpoint; CONTENT_JSON is a static
# fallback (raw JSON) used when the CMS is unreachable.
BASEHUB_TOKEN=
BASEHUB_MARKETING_CONTENT_URL=
BASEHUB_MARKETING_CONTENT_JSON=
BASEHUB_HELP_CONTENT_URL=
BASEHUB_HELP_CONTENT_JSON=

# === Ponder indexer (apps/ponder) ===
# Per-chain RPC endpoint for the indexer. Optional override; falls back to the
# public Arc testnet RPC.
PONDER_RPC_URL_ARC_TESTNET=
# Escrow address + start block to index. Optional; defaults inline in
# apps/ponder/ponder.config.ts. Set when running against a fresh deploy.
PONDER_ESCROW_ADDRESS=
PONDER_ESCROW_START_BLOCK=
# Local PGlite directory used during dev when DATABASE_URL is absent.
PONDER_PGLITE_DIR=.ponder/pglite

# === Invoicing (Phase 11b) ===
# Public origin that hosts brand-pinned WOFF2 fonts for the invoice PDF
# renderer. Optional override; defaults to the Vercel Blob CDN URL baked
# into packages/invoicing/src/fonts-server.ts.
INVOICE_FONT_BASE_URL=

# === Social links (footer + help cards) ===
# Public origins for Sendero's external social presence. Optional —
# components fall back to canonical URLs when unset.
NEXT_PUBLIC_SENDERO_X_URL=https://x.com/senderotravel
NEXT_PUBLIC_SENDERO_IG_URL=https://instagram.com/senderotravel
NEXT_PUBLIC_SENDERO_WA_URL=https://wa.me/

# === Dev tooling ===
# Skip the validate.ts schema check on builds (use sparingly). Set to "1".
SKIP_ENV_VALIDATION=
# Toggle the React-Grab inspector overlay in development. Set to "1" to enable.
NEXT_PUBLIC_ENABLE_REACT_GRAB=
# Playwright e2e bootstrap. Optional; CI wires these up explicitly.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3010
PLAYWRIGHT_STORAGE_STATE=
