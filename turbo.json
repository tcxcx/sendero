{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "daemon": true,
  "globalDependencies": ["**/.env", "**/.env.local", ".mise.toml"],
  "globalEnv": ["NODE_ENV", "VERCEL", "VERCEL_ENV", "VERCEL_URL", "CI", "SKIP_ENV_VALIDATION"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "SENDERO_DB_DRIVER",
    "ANTHROPIC_API_KEY",
    "OPENAI_API_KEY",
    "AI_GATEWAY_API_KEY",
    "VERCEL_OIDC_TOKEN",
    "AI_GATEWAY_BASE_URL",
    "CRON_SECRET",
    "CLERK_SECRET_KEY",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
    "NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL",
    "CIRCLE_API_KEY",
    "CIRCLE_ENTITY_SECRET",
    "CIRCLE_ENTITY_SECRET_CIPHERTEXT",
    "CIRCLE_WALLET_SET_ID",
    "CIRCLE_TREASURY_WALLET_ID",
    "CIRCLE_TREASURY_ADDRESS",
    "NEXT_PUBLIC_CIRCLE_CLIENT_KEY",
    "NEXT_PUBLIC_CIRCLE_CLIENT_URL",
    "NEXT_PUBLIC_CIRCLE_MODULAR_CLIENT_KEY",
    "NEXT_PUBLIC_CIRCLE_MODULAR_CLIENT_URL",
    "TREASURY_PRIVATE_KEY",
    "TREASURY_VIEM_ADDRESS",
    "TREASURY_WALLET_ID",
    "TREASURY_WALLET_ADDRESS",
    "DUFFEL_ACCESS_TOKEN",
    "DUFFEL_API_TOKEN",
    "DUFFEL_ENV",
    "ARC_RPC_URL",
    "ARC_CHAIN_ID",
    "ARC_USDC_ADDRESS",
    "ARC_EURC_ADDRESS",
    "ARC_EXPLORER_URL",
    "ARC_ESCROW_ADDRESS",
    "ARC_ESCROW_DEPLOY_BLOCK",
    "PONDER_RPC_URL_ARC_TESTNET",
    "PONDER_ESCROW_ADDRESS",
    "PONDER_ESCROW_START_BLOCK",
    "PONDER_LOG_LEVEL",
    "NEXT_PUBLIC_INDEXER_URL",
    "GOOGLE_PLACES_API_KEY",
    "NEXT_PUBLIC_ARC_CHAIN_ID",
    "NEXT_PUBLIC_ARC_ESCROW_ADDRESS",
    "SENDERO_GUEST_ESCROW",
    "NEXT_PUBLIC_SENDERO_GUEST_ESCROW",
    "SENDERO_AGENT_TOKEN_ID",
    "SENDERO_AGENT_ID",
    "NEXT_PUBLIC_SENDERO_GUEST_LINK_ORIGIN",
    "NEXT_PUBLIC_SENDERO_EDGE_URL",
    "WHATSAPP_APP_SECRET",
    "WHATSAPP_VERIFY_TOKEN",
    "WHATSAPP_ACCESS_TOKEN",
    "WHATSAPP_PHONE_NUMBER_ID",
    "WHATSAPP_API_BASE_URL",
    "WHATSAPP_DEFAULT_COUNTRY",
    "WHATSAPP_DEFAULT_TENANT_ID",
    "SLACK_SIGNING_SECRET",
    "SLACK_CLIENT_ID",
    "SLACK_CLIENT_SECRET",
    "SLACK_REDIRECT_URI",
    "SLACK_STATE_SECRET",
    "META_APP_ID",
    "META_APP_SECRET",
    "META_GRAPH_API_VERSION",
    "NEXT_PUBLIC_META_APP_ID",
    "NEXT_PUBLIC_META_ES_CONFIG_ID",
    "POSTHOG_KEY",
    "POSTHOG_HOST",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "LIVEBLOCKS_SECRET_KEY",
    "BASEHUB_TOKEN",
    "RESEND_API_KEY",
    "SENDERO_EMAIL_FROM",
    "SENDERO_EMAIL_REPLY_TO",
    "SENDERO_SUPPORT_EMAIL",
    "CF_API_TOKEN",
    "CF_ACCOUNT_ID",
    "TURBO_TOKEN",
    "TURBO_TEAM"
  ],
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "CLERK_SECRET_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "ANTHROPIC_API_KEY",
        "CIRCLE_API_KEY",
        "CIRCLE_ENTITY_SECRET",
        "DUFFEL_API_TOKEN",
        "TREASURY_PRIVATE_KEY",
        "ARC_ESCROW_ADDRESS",
        "SENDERO_AGENT_TOKEN_ID",
        "NEXT_PUBLIC_ARC_CHAIN_ID",
        "NEXT_PUBLIC_ARC_ESCROW_ADDRESS",
        "NEXT_PUBLIC_SENDERO_GUEST_ESCROW",
        "NEXT_PUBLIC_CIRCLE_CLIENT_KEY",
        "NEXT_PUBLIC_CIRCLE_CLIENT_URL"
      ],
      "dependsOn": ["^build", "db:generate", "@sendero/env#validate"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.production",
        "!.next/**",
        "!dist/**"
      ],
      "outputs": [".next/**", "!.next/cache/**", "next-env.d.ts", "dist/**", ".vercel/output/**"]
    },
    "@sendero/app#build": {
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "CLERK_SECRET_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "ANTHROPIC_API_KEY",
        "CIRCLE_API_KEY",
        "CIRCLE_ENTITY_SECRET",
        "DUFFEL_API_TOKEN",
        "TREASURY_PRIVATE_KEY",
        "ARC_ESCROW_ADDRESS",
        "SENDERO_AGENT_TOKEN_ID",
        "WHATSAPP_APP_SECRET",
        "WHATSAPP_VERIFY_TOKEN",
        "WHATSAPP_ACCESS_TOKEN",
        "SLACK_SIGNING_SECRET",
        "SLACK_CLIENT_ID",
        "SLACK_CLIENT_SECRET",
        "CRON_SECRET",
        "POSTHOG_KEY",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "LIVEBLOCKS_SECRET_KEY",
        "NEXT_PUBLIC_ARC_CHAIN_ID",
        "NEXT_PUBLIC_ARC_ESCROW_ADDRESS",
        "NEXT_PUBLIC_SENDERO_GUEST_ESCROW",
        "NEXT_PUBLIC_CIRCLE_CLIENT_KEY",
        "NEXT_PUBLIC_CIRCLE_CLIENT_URL",
        "NEXT_PUBLIC_META_APP_ID",
        "NEXT_PUBLIC_META_ES_CONFIG_ID"
      ],
      "dependsOn": ["^build", "db:generate", "@sendero/env#validate"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.local", "!.next/**"],
      "outputs": [".next/**", "!.next/cache/**", ".vercel/output/**"]
    },
    "@sendero/marketing#build": {
      "env": ["BASEHUB_TOKEN", "NEXT_PUBLIC_SITE_URL"],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.local"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@sendero/help#build": {
      "env": ["BASEHUB_TOKEN", "NEXT_PUBLIC_SITE_URL"],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.local"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@sendero/env#validate": {
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "ANTHROPIC_API_KEY",
        "CLERK_SECRET_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "CIRCLE_API_KEY",
        "CIRCLE_ENTITY_SECRET",
        "DUFFEL_API_TOKEN",
        "TREASURY_PRIVATE_KEY",
        "ARC_ESCROW_ADDRESS",
        "SENDERO_AGENT_TOKEN_ID",
        "NEXT_PUBLIC_ARC_CHAIN_ID",
        "NEXT_PUBLIC_ARC_ESCROW_ADDRESS",
        "NEXT_PUBLIC_CIRCLE_CLIENT_KEY",
        "SKIP_ENV_VALIDATION"
      ],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": []
    },
    "@sendero/edge#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".wrangler/**"]
    },
    "@sendero/database#db:generate": {
      "inputs": ["prisma/schema.prisma", "package.json"],
      "outputs": ["node_modules/.prisma/**", "node_modules/@prisma/client/**", "src/generated/**"],
      "cache": true
    },
    "db:generate": {
      "dependsOn": ["@sendero/database#db:generate"],
      "cache": true
    },
    "db:migrate": {
      "cache": false,
      "persistent": false
    },
    "db:seed": {
      "cache": false,
      "dependsOn": ["@sendero/database#db:generate"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build", "db:generate"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "tsconfig.*.json", "!.next/**", "!dist/**"],
      "outputs": ["*.tsbuildinfo", ".tsbuildinfo"]
    },
    "lint": {
      "dependsOn": ["^topo"],
      "inputs": ["$TURBO_DEFAULT$", "biome.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "ANTHROPIC_API_KEY",
        "TREASURY_PRIVATE_KEY",
        "ARC_ESCROW_ADDRESS",
        "SKIP_ENV_VALIDATION"
      ],
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "db:generate", "@sendero/env#validate"]
    },
    "@sendero/edge#dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "@sendero/indexer#dev": {
      "env": [
        "DATABASE_URL",
        "PONDER_RPC_URL_ARC_TESTNET",
        "PONDER_ESCROW_ADDRESS",
        "PONDER_ESCROW_START_BLOCK",
        "PONDER_LOG_LEVEL"
      ],
      "cache": false,
      "persistent": true,
      "dependsOn": ["@sendero/indexer#codegen"]
    },
    "@sendero/indexer#start": {
      "env": [
        "DATABASE_URL",
        "PONDER_RPC_URL_ARC_TESTNET",
        "PONDER_ESCROW_ADDRESS",
        "PONDER_ESCROW_START_BLOCK",
        "PONDER_LOG_LEVEL"
      ],
      "cache": false,
      "persistent": true,
      "dependsOn": ["@sendero/indexer#codegen"]
    },
    "@sendero/indexer#codegen": {
      "inputs": ["ponder.config.ts", "ponder.schema.ts", "abis/**", "src/**"],
      "outputs": ["generated/**", ".ponder/**"]
    },
    "@sendero/indexer#build": {
      "dependsOn": ["@sendero/indexer#codegen"],
      "outputs": ["generated/**", ".ponder/**"]
    },
    "@sendero/indexer#typecheck": {
      "dependsOn": ["@sendero/indexer#codegen"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "generated/**", "!node_modules/**"],
      "outputs": ["*.tsbuildinfo", ".tsbuildinfo"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "clean": {
      "cache": false
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["build", "typecheck"]
    },
    "format": {
      "dependsOn": ["^topo"],
      "outputs": []
    }
  }
}
