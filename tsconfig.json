{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@sendero/tools": [
        "./packages/tools/src/index.ts"
      ],
      "@sendero/tools/adapters/ai-sdk": [
        "./packages/tools/src/adapters/ai-sdk.ts"
      ],
      "@sendero/tools/adapters/mcp": [
        "./packages/tools/src/adapters/mcp.ts"
      ],
      "@sendero/tools/agent": [
        "./packages/tools/src/agent.ts"
      ],
      "@sendero/tools/types": [
        "./packages/tools/src/types.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "target": "ES2020"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts"
  ]
}
