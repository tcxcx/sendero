{
  "name": "sendero-arc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sendero × Arc — AI travel agent monorepo. apps/{app, edge, docs, storybook} + packages/{auth, database, tools, circle, duffel, arc, erc8183, nanopayments, env}. Circle Arc Hackathon Spring 2026.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.10",
  "overrides": {
    "ai": "^6.0.0",
    "zod": "^3.25.76"
  },
  "resolutions": {
    "ai": "^6.0.0",
    "zod": "^3.25.76"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@sendero/app",
    "dev:edge": "turbo run dev --filter=@sendero/edge",
    "dev:indexer": "turbo run dev --filter=@sendero/indexer",
    "dev:all": "turbo run dev",
    "indexer:codegen": "turbo run codegen --filter=@sendero/indexer",
    "indexer:sync-abi": "bun run --cwd apps/ponder sync-abi",
    "build": "turbo run build",
    "start": "turbo run start --filter=@sendero/app",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "clean": "git clean -xdf .next .turbo node_modules apps/*/node_modules apps/*/.next packages/*/node_modules",
    "bootstrap-agent": "bun run scripts/bootstrap-agent.ts",
    "db:generate": "bun run --cwd packages/database db:generate",
    "db:migrate": "bun run --cwd packages/database db:migrate",
    "db:seed": "bun run --cwd packages/database db:seed",
    "db:studio": "bun run --cwd packages/database db:studio",
    "db:reset": "bun run --cwd packages/database db:reset",
    "gen": "bunx turbo gen",
    "env:validate": "bun run --cwd packages/sendero-env validate",
    "smoke:escrow": "bun run scripts/smoke-guest-escrow.ts",
    "smoke:nanopay": "bun run scripts/smoke-nanopay-batch.ts",
    "deploy:fonts": "bun run scripts/deploy-invoice-fonts.ts",
    "smoke:retry": "bun run scripts/smoke-nanopay-retry.ts",
    "smoke:resume-settle": "bun run scripts/smoke-webhook-resume-settle.ts",
    "smoke:resume-cancel": "bun run scripts/smoke-webhook-resume-cancel.ts",
    "faucet:drip": "bun run scripts/faucet-drip.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@vercel/blob": "^0.23.0",
    "@turbo/gen": "^2.9.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^5.22.0",
    "turbo": "^2.9.6",
    "typescript": "^5.8.3",
    "viem": "^2.21.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BuFi007/sendero-arc.git"
  },
  "keywords": [
    "arc",
    "circle",
    "usdc",
    "erc-8183",
    "erc-8004",
    "duffel",
    "travel",
    "ai-agent",
    "hackathon"
  ],
  "license": "MIT"
}
