{
  "name": "sendero-arc",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Sendero × Arc — AI travel agent monorepo. apps/{app, edge, docs, storybook} + packages/{auth, database, tools, circle, duffel, arc, erc8183, nanopayments, env}. Circle Arc Hackathon Spring 2026.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.10",
  "overrides": {
    "ai": "^6.0.0",
    "zod": "^3.25.76"
  },
  "resolutions": {
    "ai": "^6.0.0",
    "zod": "^3.25.76"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@sendero/app",
    "dev:edge": "turbo run dev --filter=@sendero/edge",
    "dev:indexer": "turbo run dev --filter=@sendero/indexer",
    "dev:pitch": "bun run pitch/serve.ts",
    "dev:complete": "turbo run dev --ui=stream --filter=@sendero/app --filter=@sendero/marketing --filter=@sendero/help --filter=@sendero/docs --filter=@sendero/edge --filter=@sendero/indexer --filter=@sendero/storybook",
    "dev:all": "turbo run dev --ui=stream",
    "indexer:codegen": "turbo run codegen --filter=@sendero/indexer",
    "indexer:sync-abi": "bun run --cwd apps/ponder sync-abi",
    "build": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-turbo} turbo run build",
    "start": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-turbo} turbo run start --filter=@sendero/app",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "clean": "git clean -xdf .next .turbo node_modules apps/*/node_modules apps/*/.next packages/*/node_modules",
    "bootstrap-agent": "bun run scripts/bootstrap-agent.ts",
    "db:generate": "bun run --cwd packages/database db:generate",
    "db:migrate": "bun run --cwd packages/database db:migrate",
    "db:seed": "bun run --cwd packages/database db:seed",
    "db:studio": "bun run --cwd packages/database db:studio",
    "db:reset": "bun run --cwd packages/database db:reset",
    "llms:test": "bun run --cwd packages/llms test",
    "gen": "bunx turbo gen",
    "env:validate": "bun run --cwd packages/sendero-env validate",
    "webhooks:ngrok": "bash scripts/start-sendero-ngrok.sh",
    "webhooks:urls": "bash scripts/show-sendero-webhook-urls.sh",
    "ui:sync-exports": "bun run scripts/sync-ui-exports.ts",
    "smoke:escrow": "bun run scripts/smoke-guest-escrow.ts",
    "smoke:nanopay": "bun run scripts/smoke-nanopay-batch.ts",
    "deploy:fonts": "bun run scripts/deploy-invoice-fonts.ts",
    "deploy:edge": "bun run --cwd apps/edge deploy",
    "deploy:edge:preview": "bun run --cwd apps/edge deploy:preview",
    "deploy:edge:dry-run": "bun run --cwd apps/edge deploy:dry-run",
    "deploy:edge:canary": "bun run --cwd apps/edge deploy:canary --",
    "deploy:edge:promote": "bun run --cwd apps/edge deploy:promote",
    "deploy:edge:rollback": "bun run --cwd apps/edge deploy:rollback",
    "deploy:app": "vercel --cwd apps/app deploy --prod",
    "deploy:marketing": "vercel --cwd apps/marketing deploy --prod",
    "deploy:docs": "vercel --cwd apps/docs deploy --prod",
    "deploy:help": "vercel --cwd apps/help deploy --prod",
    "deploy:rolling:configure": "bun run scripts/configure-rolling-releases.ts",
    "deploy:rolling:configure:dry": "bun run scripts/configure-rolling-releases.ts --dry-run",
    "deploy:rolling:disable": "bun run scripts/configure-rolling-releases.ts --disable",
    "deploy:rolling:status:app": "vercel --cwd apps/app rolling-release fetch",
    "deploy:rolling:status:marketing": "vercel --cwd apps/marketing rolling-release fetch",
    "deploy:rolling:status:docs": "vercel --cwd apps/docs rolling-release fetch",
    "deploy:rolling:status:help": "vercel --cwd apps/help rolling-release fetch",
    "deploy:rolling:abort:app": "vercel --cwd apps/app rolling-release abort",
    "deploy:rolling:abort:marketing": "vercel --cwd apps/marketing rolling-release abort",
    "deploy:rolling:abort:docs": "vercel --cwd apps/docs rolling-release abort",
    "deploy:rolling:abort:help": "vercel --cwd apps/help rolling-release abort",
    "deploy:rolling:approve:app": "vercel --cwd apps/app rolling-release approve",
    "deploy:rolling:complete:app": "vercel --cwd apps/app rolling-release complete",
    "config:doctor": "bun run scripts/config-doctor.ts",
    "cache:setup": "bash scripts/setup-turbo-cache.sh",
    "defect-escape:report": "bun run scripts/defect-escape-report.ts",
    "edge:health": "bash scripts/edge-health-check.sh",
    "smoke:retry": "bun run scripts/smoke-nanopay-retry.ts",
    "smoke:resume-settle": "bun run scripts/smoke-webhook-resume-settle.ts",
    "smoke:resume-cancel": "bun run scripts/smoke-webhook-resume-cancel.ts",
    "smoke:invoice-pdf": "bun run scripts/smoke-invoice-pdf-render.ts",
    "smoke:invoice-booking": "bun run scripts/smoke-invoice-booking.ts",
    "smoke:invoice-platform-bill": "bun run scripts/smoke-invoice-platform-bill.ts",
    "smoke:clerk-webhook": "bun run scripts/smoke-clerk-webhook.ts",
    "smoke:auth-onboarding": "bun run scripts/smoke-auth-onboarding.ts",
    "faucet:drip": "bun run scripts/faucet-drip.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@circle-fin/developer-controlled-wallets": "^8.0.0",
    "@circle-fin/smart-contract-platform": "^10.3.0",
    "@vercel/blob": "^2.3.3",
    "@turbo/gen": "^2.9.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^5.22.0",
    "turbo": "^2.9.6",
    "typescript": "^5.8.3",
    "viem": "^2.21.0",
    "wrangler": "^4.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BuFi007/sendero-arc.git"
  },
  "keywords": [
    "arc",
    "circle",
    "usdc",
    "erc-8183",
    "erc-8004",
    "duffel",
    "travel",
    "ai-agent",
    "hackathon"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "Tomas Cordero <tomas.cordero.esp@gmail.com> (https://github.com/tcxcx)"
}
