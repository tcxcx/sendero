{
  "name": "@sendero/billing",
  "version": "0.1.0",
  "private": true,
  "description": "Sendero — per-tenant nanopayment billing. Segment-aware pricing catalog (consumer / agency / corp / ai-agent), per-tenant spend caps, batched USDC settlement on Arc, spend analytics helpers. Reads/writes via @sendero/database.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pricing": "./src/pricing.ts",
    "./plans": "./src/plans.ts",
    "./caps": "./src/caps.ts",
    "./meter": "./src/meter.ts",
    "./batch": "./src/batch.ts",
    "./analytics": "./src/analytics.ts",
    "./markup": "./src/markup.ts",
    "./settlement": "./src/settlement.ts",
    "./markup-recommendations": "./src/markup-recommendations.ts"
  },
  "peerDependencies": {
    "@sendero/database": "*",
    "@sendero/nanopayments": "*"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
