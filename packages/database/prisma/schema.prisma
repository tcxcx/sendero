// Sendero × Arc — Prisma schema
// Multi-tenant corporate travel SaaS backing:
//   - Clerk orgs (Tenant) + passkey MSCA users
//   - Trips / Bookings (Duffel) + Policies (JSON ruleset)
//   - Suppliers (public + tenant-private)
//   - Circle Gateway Wallets + x402 nanopayment MeterEvents
//   - On-chain Settlements (fan-out legs) + ERC-8004 Attestations
//   - Clerk billing Subscriptions
//
// Hard rules:
//   * Row-level isolation via tenantId foreign keys.
//   * Financial tables (MeterEvent, Settlement, SettlementLeg, Attestation)
//     are append-only — no destructive updates, no cascade deletes from Tenant.
//   * timestamptz everywhere.
//   * cuid() for user-facing ids; uuid() for internal rows.
//   * JSON columns for free-form / provider-raw payloads.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto]
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum BillingTier {
  free
  pro
  business
  enterprise
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  paused
  incomplete
}

enum Role {
  agency_admin
  finance
  traveler
  guest
}

enum MembershipStatus {
  active
  invited
  suspended
  removed
}

enum TripStatus {
  draft
  searching
  awaiting_approval
  booked
  in_progress
  completed
  canceled
  failed
}

enum BookingStatus {
  pending
  confirmed
  ticketed
  canceled
  refunded
  failed
}

enum BookingKind {
  flight
  hotel
  rail
  car
  other
}

enum SupplierKind {
  airline
  hotel
  dmc
  rail
  car_rental
  other
}

enum SupplierVisibility {
  public
  tenant_private
}

enum SupplierStatus {
  active
  inactive
  blacklisted
  pending_review
}

enum MeterStatus {
  paid
  free
  rejected
  /// API-key-authenticated call from a sandbox key (or a production
  /// key downgraded during testnet-beta network mode). Row is kept for
  /// analytics; NanopayBatch excludes `status='sandbox'` from settlement.
  sandbox
}

enum SettlementStatus {
  pending
  submitted
  confirmed
  failed
  reverted
}

enum SettlementLegKind {
  supplier
  agency
  rail
  validator
  refund
  fee
  other
}

enum MemoryKind {
  preference
  observation
  fact
  relation
  trip_event
  policy_note
}

enum PreferenceCategory {
  seat
  cabin_class
  carrier
  meal
  hotel_chain
  hotel_room_type
  bag_allowance
  layover_tolerance
  departure_time
  price_ceiling
}

enum PreferenceSignal {
  approve
  reject
  select
  skip
}

enum ChannelKind {
  whatsapp
  slack
  email
  web
}

enum NanopayBatchStatus {
  pending
  settling
  settled
  failed
}

enum CapPeriod {
  daily
  monthly
}

enum InvoiceKind {
  booking
  platform_bill
  credit_note
}

enum InvoiceStatus {
  draft
  issued
  sent
  viewed
  paid
  overdue
  void
}

/// How a User row originated.
///   - native:   claimed via Clerk sign-up (clerkUserId is set).
///   - slack:    auto-provisioned from a Slack message (clerkUserId may
///               be null until the user signs up with the same email).
///   - whatsapp: future — auto-provisioned from a WhatsApp message.
///   - guest:    future — guest-link claim flow (escrow trips).
enum UserSource {
  native
  slack
  whatsapp
  guest
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANCY
// ─────────────────────────────────────────────────────────────────────────────

/// Paying customer. Clerk org maps 1:1 to a Tenant.
/// A Tenant can be a TMC (e.g. "SP Corporate Travel") or a corp client
/// ("Vale"). Sub-agencies modeled via self-referencing parentTenantId.
model Tenant {
  id                        String      @id @default(cuid())
  clerkOrgId                String      @unique
  slug                      String      @unique // URL-safe, e.g. "sp-corporate-travel"
  displayName               String
  billingTier               BillingTier @default(free)
  fiscalCountry             String? // ISO-3166-1 alpha-2, e.g. "BR"
  arcAddress                String? // treasury MSCA on Arc (0x…)
  parentTenantId            String?
  /// Duffel CustomerUserGroup id (`usg_…`) — each tenant maps to one group
  /// so travelers get the Travel Support Assistant scoped to their org.
  duffelCustomerUserGroupId String?     @unique
  metadata                  Json? // free-form; logo, phone, custom branding

  legalName           String?
  billingContactEmail String?
  billingAddress      Json?
  taxId               String?
  brandLogoUrl        String?
  brandColors         Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  parent   Tenant?  @relation("TenantHierarchy", fields: [parentTenantId], references: [id], onDelete: SetNull)
  children Tenant[] @relation("TenantHierarchy")

  memberships         Membership[]
  policies            Policy[]
  trips               Trip[]
  bookings            Booking[]
  suppliers           Supplier[]
  meterEvents         MeterEvent[]
  settlements         Settlement[]
  subscription        Subscription?
  sessions            Session[]
  attestations        Attestation[]
  agentMemories       AgentMemory[]
  preferenceLogs      PreferenceLog[]
  channelIdentities   ChannelIdentity[]
  slackInstalls       SlackInstall[]
  slackUserBindings   SlackUserBinding[]
  whatsappInstall     WhatsAppInstall?
  whatsappLinkTokens  WhatsAppLinkToken[]
  spendCaps           TenantSpendCap[]
  transferPolicies    TransferPolicy[]
  transferAttempts    TransferAttempt[]
  nanopayBatches      NanopayBatch[]
  invoices            Invoice[]
  circleWallets       CircleWallet[]
  ancillarySelections AncillarySelection[]
  disruptionRuns      DisruptionRun[]
  checkInNudges       CheckInNudge[]
  safetyBriefs        SafetyBrief[]
  arrivalPlaybookRuns ArrivalPlaybookRun[]
  supportTurns        SupportTurn[]
  pendingMultisigOps  PendingMultisigOp[]
  passportVaults      PassportVault[]
  tripEligibilityRuns TripEligibilityRun[]

  @@index([parentTenantId])
  @@index([createdAt])
  @@map("tenants")
}

/// Human user. Identified by Clerk; cached MSCA address is deterministic
/// from the passkey (Circle Modular Wallets).
///
/// `clerkUserId` is nullable so we can auto-provision a User from a
/// Slack / WhatsApp message before the human ever signs up via Clerk.
/// When they do sign up with the same email, the Clerk webhook upserts
/// the existing row and stamps `clerkUserId`. `source` records origin.
model User {
  id                   String     @id @default(cuid())
  clerkUserId          String?    @unique
  email                String     @unique
  displayName          String?
  imageUrl             String?
  mscaAddress          String?    @unique // 0x…, nullable until first passkey link
  phone                String?
  /// Duffel CustomerUser id (`icu_…`) — unlocks Travel Support Assistant.
  duffelCustomerUserId String?    @unique
  /// Provenance of this row. See UserSource enum for values.
  source               UserSource @default(native)
  /// Free-form user metadata (preferred language, locale, etc.).
  metadata             Json?
  createdAt            DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime   @updatedAt @db.Timestamptz(6)
  lastSeenAt           DateTime?  @db.Timestamptz(6)

  memberships         Membership[]
  wallets             Wallet[]
  travelerTrips       Trip[]               @relation("TripTraveler")
  createdTrips        Trip[]               @relation("TripCreatedBy")
  bookings            Booking[]            @relation("BookingCreatedBy")
  suppliers           Supplier[]           @relation("SupplierCreatedBy")
  meterEvents         MeterEvent[]
  sessions            Session[]
  channelIdentities   ChannelIdentity[]
  whatsappLinkTokens  WhatsAppLinkToken[]
  airlineCredits      AirlineCredit[]
  passportVaults      PassportVault[]
  tripEligibilityRuns TripEligibilityRun[]
  slackUserBindings   SlackUserBinding[]
  transferPolicies    TransferPolicy[]      @relation("TravelerPolicies")
  transferAttempts    TransferAttempt[]     @relation("TravelerTransferAttempts")

  @@index([createdAt])
  @@map("users")
}

/// Cached Duffel airline credit (unused ticket, MCO, voucher, etc.).
/// Mirrors the wire type in @sendero/duffel. Webhooks (or the ensure
/// path) keep `state` in sync with Duffel. `state` is derived from
/// spent_at / invalidated_at / expires_at so indexes on it work
/// directly for "available credits" lookups.
model AirlineCredit {
  id              String    @id // Duffel id, e.g. acd_…
  tenantId        String?
  userId          String? // Sendero User.id
  duffelUserId    String? // icu_… denormalized for list scans
  airlineIataCode String    @db.Char(2)
  /// eticket | mco | other
  type            String
  code            String
  amount          Decimal   @db.Decimal(18, 6)
  currency        String    @db.Char(3)
  issuedOn        DateTime? @db.Date
  expiresAt       DateTime? @db.Timestamptz(6)
  spentAt         DateTime? @db.Timestamptz(6)
  invalidatedAt   DateTime? @db.Timestamptz(6)
  givenName       String?
  familyName      String?
  passengerId     String? // pas_…
  orderId         String? // ord_…
  /// available | spent | invalidated | expired — precomputed for fast filters.
  state           String    @default("available")
  liveMode        Boolean   @default(false)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, state, expiresAt])
  @@index([tenantId, state])
  @@index([duffelUserId, state])
  @@map("airline_credits")
}

/// Many-to-many User↔Tenant with a per-tenant role.
model Membership {
  id                String           @id @default(cuid())
  tenantId          String
  userId            String
  clerkMembershipId String?          @unique
  role              Role             @default(traveler)
  status            MembershipStatus @default(active)
  invitedBy         String?
  invitedAt         DateTime?        @db.Timestamptz(6)
  joinedAt          DateTime?        @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@index([userId])
  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING (Clerk mirror)
// ─────────────────────────────────────────────────────────────────────────────

/// One Subscription per Tenant (Clerk Billing mirror).
model Subscription {
  id                String             @id @default(cuid())
  tenantId          String             @unique
  clerkSubId        String?            @unique
  tier              BillingTier        @default(free)
  status            SubscriptionStatus @default(active)
  currentPeriodEnd  DateTime?          @db.Timestamptz(6)
  /// Signed micro-USDC balance for the current billing period (negative = owed).
  meterBalanceMicro BigInt             @default(0)
  metadata          Json?
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// POLICY
// ─────────────────────────────────────────────────────────────────────────────

/// Corporate travel ruleset JSON. Many per tenant (e.g. per corp client).
model Policy {
  id            String    @id @default(cuid())
  tenantId      String
  slug          String // "vale-corp-2026"
  displayName   String
  /// JSON rules: maxNightUsd, intlCabinRequired, preferredCarriers, fiscalCountry, etc.
  rules         Json
  isDefault     Boolean   @default(false)
  version       Int       @default(1)
  effectiveFrom DateTime? @db.Timestamptz(6)
  effectiveTo   DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trips  Trip[]

  @@unique([tenantId, slug])
  @@index([tenantId, isDefault])
  @@index([tenantId, createdAt])
  @@map("policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRIP / BOOKING — the core product objects
// ─────────────────────────────────────────────────────────────────────────────

/// A persistent conversational thread for one trip. Core object.
model Trip {
  id              String     @id @default(cuid())
  tenantId        String
  policyId        String?
  travelerId      String? // User.id — may be guest
  createdById     String? // booking agent
  intent          Json // parsed intent: {origin,dest,dates,pax,purpose}
  status          TripStatus @default(draft)
  /// Append-only event log (agent turns, tool calls, approvals).
  events          Json       @default("[]")
  settlementRef   String? // convenience pointer to latest Settlement
  cfdiRef         String? // MX fiscal invoice reference
  reputationScore Int? // 0-100, mirrored from Attestation
  totalUsdc       Decimal?   @db.Decimal(18, 6) // denormalized from bookings
  metadata        Json?
  /// Per-trip channel routing override. Shape (see TripChannelBindings
  /// in `apps/app/lib/channel-routing.ts`):
  ///   { primary: 'whatsapp'|'slack'|'email'|'web',
  ///     whatsapp?: { identityId },
  ///     slack?: { channelId, threadTs? },
  ///     notifyChannels?: Array<...> }
  /// Nudge emitters read this before each share; null = use tenant default.
  channelBindings Json?
  createdAt       DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @db.Timestamptz(6)

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policy    Policy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  traveler  User?   @relation("TripTraveler", fields: [travelerId], references: [id], onDelete: SetNull)
  createdBy User?   @relation("TripCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  bookings     Booking[]
  settlements  Settlement[]
  attestations Attestation[]
  sessions     Session[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([policyId])
  @@index([travelerId])
  @@index([createdById])
  @@map("trips")
}

/// One reserved product inside a Trip (flight, hotel, rail, car).
model Booking {
  id                   String        @id @default(cuid())
  tenantId             String
  tripId               String
  supplierId           String?
  createdById          String?
  kind                 BookingKind
  status               BookingStatus @default(pending)
  /// Duffel order id, Amadeus PNR locator, etc.
  externalId           String?
  /// Duffel order id once the hold is placed. Separate column (not
  /// externalId) so we can put a global @unique on it for webhook
  /// lookups independent of tenant.
  duffelOrderId        String?       @unique
  pnr                  String?
  totalUsd             Decimal       @db.Decimal(12, 2)
  currency             String        @default("USD") @db.Char(3)
  /// Raw provider payload (Duffel offer / order), kept for reconciliation.
  rawDuffel            Json?
  segments             Json? // normalized itinerary
  /// Free-form booking lifecycle metadata (approvals, policy notes, etc.).
  metadata             Json?
  /// Which policy (+ which version of its rules) was applied at booking time.
  appliedPolicyId      String?
  appliedPolicyVersion Int?
  /// Result of the policy evaluation: "allowed", "allowed_with_warnings", "escalated", "rejected".
  policyCheckResult    String?
  /// Structured policy violations captured at book time.
  policyViolations     Json?
  bookedAt             DateTime?     @db.Timestamptz(6)
  createdAt            DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @db.Timestamptz(6)

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("BookingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  settlements Settlement[]
  invoice     Invoice?

  @@unique([tenantId, externalId])
  @@index([tenantId, createdAt])
  @@index([tripId])
  @@index([supplierId])
  @@index([status])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPLIER
// ─────────────────────────────────────────────────────────────────────────────

/// Airline / hotel / DMC. Either tenant-private (preferred partner) or
/// public (shared registry — tenantId is NULL, visibility = "public").
model Supplier {
  id            String             @id @default(cuid())
  tenantId      String? // null = public registry
  createdById   String?
  kind          SupplierKind
  visibility    SupplierVisibility @default(public)
  status        SupplierStatus     @default(active)
  name          String
  iataCode      String? // for airlines
  country       String? // ISO-3166-1 alpha-2
  arcAddress    String? // on-chain payout address on Arc
  commissionBps Int                @default(0) // basis points, 100 = 1%
  metadata      Json?
  createdAt     DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(6)

  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  bookings  Booking[]

  @@unique([tenantId, iataCode])
  @@index([visibility, status])
  @@index([kind])
  @@index([iataCode])
  @@map("suppliers")
}

// ─────────────────────────────────────────────────────────────────────────────
// WALLETS + METER
// ─────────────────────────────────────────────────────────────────────────────

/// User → on-chain wallet. Polymorphic by provisioner:
///
///   provisioner='msca'  — passkey-controlled Circle Modular Wallet
///                          (tenant treasury today; user-controlled in
///                          future). circleWalletId is null.
///   provisioner='dcw'   — Circle Developer-Controlled Wallet, EOA
///                          account type. Server-side custodial — Circle
///                          holds the keys, signs via entity secret.
///                          One per User, persistent across tenants and
///                          channels (same wallet whether they came in
///                          via Clerk corporate, WhatsApp lead, or B2C).
///                          circleWalletId is set.
///
/// A user may have multiple rows (one per chain) and rows from different
/// provisioners. `(userId, chainId, address)` stays unique.
model Wallet {
  id                  String    @id @default(cuid())
  userId              String
  address             String
  chainId             Int
  /// Cached Circle Gateway unified-USDC balance, in micro-USDC (1e-6).
  gatewayBalanceMicro BigInt    @default(0)
  /// Human label ("daily-ops", "treasury").
  label               String?
  /// Provisioner discriminator. See model docstring for shapes.
  provisioner         String    @default("msca")
  /// Circle DCW wallet id (e.g. `0190fe2c…`). Null for MSCA rows.
  circleWalletId      String?   @unique
  /// Walletset the DCW belongs to. Platform-level for travelers.
  circleWalletSetId   String?
  /// 'EOA' | 'SCA' for DCW; null for MSCA.
  accountType         String?
  /// Free-form. Used by transfer-policy + Gateway flows to cache things
  /// like delegate authorization status per chain.
  metadata            Json?
  lastSeenAt          DateTime? @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chainId, address])
  @@index([address])
  @@index([userId, provisioner])
  @@map("wallets")
}

/// Per-tenant Circle-backed on-chain wallet metadata. Provisioned by the
/// Clerk webhook handler / org provisioning flow (phase-11c). Distinct
/// from the user-scoped Wallet model above.
model CircleWallet {
  id                String    @id @default(cuid())
  tenantId          String
  clerkOrgId        String?
  address           String    @unique
  kind              String
  chain             String
  circleWalletSetId String?
  circleWalletId    String?
  /// Cached USDC balance in micro-USDC (1 USDC = 1_000_000). Authoritative
  /// source is the Circle webhook → `syncWalletBalance()` in
  /// @sendero/circle/balance-sync. Read this in the UI; do not poll RPC.
  usdcBalanceMicro  BigInt?
  /// Cached EURC balance, same convention as usdcBalanceMicro.
  eurcBalanceMicro  BigInt?
  balanceUpdatedAt  DateTime? @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, kind])
  @@map("circle_wallets")
}

/// Append-only nanopayment ledger. Mirrors packages/tools/src/meter.ts
/// MeterEvent but durable. NEVER update or delete rows — audit trail.
model MeterEvent {
  id             String      @id @default(uuid()) @db.Uuid
  at             DateTime    @default(now()) @db.Timestamptz(6)
  tenantId       String?
  userId         String?
  payerAddress   String? // on-chain payer (x402)
  toolName       String
  /// USDC price charged, in micro-USDC (atomic). e.g. 5000 = $0.005.
  priceMicroUsdc BigInt
  status         MeterStatus
  settlementRef  String? // Gateway transfer id or tx hash
  note           String?
  metadata       Json?
  /// Idempotency key — unique per (tenantId, key). Duplicate writes
  /// from retried webhook deliveries no-op at the DB layer.
  idempotencyKey String?
  invoiceRef     String?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, at])
  @@index([userId, at])
  @@index([toolName, at])
  @@index([status, at])
  @@index([tenantId, status, invoiceRef])
  @@map("meter_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// SETTLEMENT (on-chain fan-out)
// ─────────────────────────────────────────────────────────────────────────────

/// One on-chain settlement per Booking (ERC-8183 fan-out). Append-only.
model Settlement {
  id             String           @id @default(cuid())
  tenantId       String
  tripId         String?
  bookingId      String?
  /// Gross USDC amount distributed, in micro-USDC.
  grossMicroUsdc BigInt
  chain          String // "arc-testnet", "arc-mainnet", "base", etc.
  chainId        Int?
  status         SettlementStatus @default(pending)
  txHashes       String[]         @default([])
  initiatedAt    DateTime         @default(now()) @db.Timestamptz(6)
  confirmedAt    DateTime?        @db.Timestamptz(6)
  metadata       Json?
  createdAt      DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(6)

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  trip    Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  legs SettlementLeg[]

  @@index([tenantId, createdAt])
  @@index([bookingId])
  @@index([tripId])
  @@index([status])
  @@map("settlements")
}

/// One payout leg of a Settlement (supplier, agency, rail, validator, ...).
model SettlementLeg {
  id              String            @id @default(uuid()) @db.Uuid
  settlementId    String
  kind            SettlementLegKind
  toAddress       String
  amountMicroUsdc BigInt
  txHash          String?
  index           Int               @default(0)
  note            String?
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId, index])
  @@index([toAddress])
  @@map("settlement_legs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTESTATION (ERC-8004)
// ─────────────────────────────────────────────────────────────────────────────

/// ERC-8004 reputation write. Append-only.
model Attestation {
  id               String   @id @default(cuid())
  tenantId         String
  tripId           String?
  agentId          String // ERC-8004 agent identifier
  validatorAddress String
  stars            Int // 1-5
  txHash           String?
  chain            String?
  at               DateTime @default(now()) @db.Timestamptz(6)
  metadata         Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  trip   Trip?  @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([tripId])
  @@index([agentId])
  @@map("attestations")
}

// ─────────────────────────────────────────────────────────────────────────────
// SESSION (agent thread resume — optional)
// ─────────────────────────────────────────────────────────────────────────────

/// Clerk session → workflow thread context. Lets the agent resume an
/// interrupted turn (e.g. OTP, 3DS, approval gate).
model Session {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String?
  tripId         String?
  clerkSessionId String?
  /// Channel-agnostic subject key (WA BSUID, Slack (ent:team:user), web userId,
  /// MCP actor id). Lets runAgentTurn look up an ambient conversation session
  /// across channels without rebuilding context each turn.
  subjectKey     String?
  threadContext  Json? // in-flight tool call, pending approvals, turns log
  expiresAt      DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  trip   Trip?  @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@unique([tenantId, subjectKey])
  @@index([tenantId, createdAt])
  @@index([tripId])
  @@index([clerkSessionId])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTELLIGENCE — agent memory + preference learning (Phase 2)
// ─────────────────────────────────────────────────────────────────────────────

/// Agent memory store — per-tenant, per-subject. Phase 1 retrieval is
/// trigram-based keyword match; Phase 2 will add pgvector embeddings.
/// Append-only in practice, but lastAccessedAt/accessCount are mutable.
model AgentMemory {
  id             String     @id @default(uuid()) @db.Uuid
  tenantId       String
  /// Traveler / trip / user id this memory attaches to.
  subjectId      String
  /// Agent that created it ("sendero", "sendero:booking", "sendero:support").
  agentId        String     @default("sendero")
  kind           MemoryKind
  /// One-liner the agent reads. ≤ 240 chars.
  summary        String     @db.VarChar(240)
  /// Optional longer free-text. Indexed by trigram in Phase 2 migration.
  body           String?
  metadata       Json?
  createdAt      DateTime   @default(now()) @db.Timestamptz(6)
  lastAccessedAt DateTime?  @db.Timestamptz(6)
  accessCount    Int        @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, subjectId, kind])
  @@index([tenantId, agentId, createdAt])
  @@map("agent_memories")
}

/// Raw preference decision log. Aggregated into PreferencePattern by
/// @sendero/intelligence at recall time; not materialized server-side to
/// keep the hot path simple in Phase 2.
model PreferenceLog {
  id        String             @id @default(uuid()) @db.Uuid
  tenantId  String
  subjectId String
  category  PreferenceCategory
  /// "window", "premium_economy", "BA", "16:00-21:00"
  key       String
  signal    PreferenceSignal
  amountUsd Decimal?           @db.Decimal(12, 2)
  context   Json?
  createdAt DateTime           @default(now()) @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, subjectId, category])
  @@index([tenantId, createdAt])
  @@map("preference_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CHANNELS — WhatsApp / Slack installations + per-tenant identity mapping
// ─────────────────────────────────────────────────────────────────────────────

/// Binds a channel user (WhatsApp phone/BSUID, Slack user) to a Sendero
/// User within a Tenant. BSUID is the preferred primary key on WhatsApp
/// post-April-2026; phone is nullable to match the Meta rollout.
model ChannelIdentity {
  id                         String      @id @default(uuid()) @db.Uuid
  tenantId                   String
  userId                     String?
  kind                       ChannelKind
  /// For WhatsApp: E.164 phone (nullable — BSUID-only is possible).
  /// For Slack: member id on the workspace.
  externalUserId             String?
  /// WhatsApp only — primary identity key post-BSUID rollout.
  businessScopedUserId       String?
  parentBusinessScopedUserId String?
  username                   String?
  /// Arbitrary per-channel metadata (display name, timezone, locale hints).
  metadata                   Json?
  createdAt                  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime    @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tenantId, kind, businessScopedUserId])
  @@unique([tenantId, kind, externalUserId])
  @@index([tenantId, kind])
  @@index([userId])
  @@map("channel_identities")
}

/// Persisted Slack OAuth install. Keyed on (enterpriseId, teamId) so
/// Enterprise Grid installs spanning multiple workspaces resolve to one
/// install. `enterpriseId` is nullable for classic (non-Grid) installs.
model SlackInstall {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String
  /// Nullable for classic installs; required for Grid.
  enterpriseId        String?
  enterpriseName      String?
  teamId              String
  teamName            String
  appId               String
  botUserId           String
  /// Encrypt-at-rest in production. Plaintext acceptable on testnet demo.
  botToken            String
  scope               String
  isEnterpriseInstall Boolean  @default(false)
  authedUserId        String
  installedAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @db.Timestamptz(6)
  raw                 Json?
  /// Channel routing config from the Slack setup wizard:
  /// { defaultChannel, routes: [{ eventClass, channel, mode }] }.
  /// Read by the channel-event dispatcher + agent persona to decide where
  /// to post each Sendero event class (trip events, settlements, cap
  /// warnings, escalations, silent).
  /// Backed by `migrations/20260424_slack_routing/migration.sql`.
  routing             Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, teamId])
  @@index([tenantId])
  @@map("slack_installs")
}

/// Maps a Slack member to their Sendero User. Cached so we don't call
/// `slack.users.info` on every webhook. One row per (tenantId, slackTeamId,
/// slackUserId). Refreshed when the Slack user's email changes (rare).
///
/// Used by the Slack webhook routes (`apps/app/lib/slack-user-mapping.ts`)
/// to resolve `meter_events.userId` to the Slack user who actually
/// triggered the agent turn — instead of the workspace admin who
/// installed the bot. Critical for per-user spend caps + analytics.
model SlackUserBinding {
  id            String   @id @default(cuid())
  tenantId      String
  slackTeamId   String // Slack workspace, e.g. T08X5JKLM
  slackUserId   String // Slack member, e.g. U09H4WXZ7
  senderoUserId String // links to User.id within this tenant
  email         String? // last seen Slack email; informational
  resolvedAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [senderoUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slackTeamId, slackUserId])
  @@index([tenantId])
  @@index([senderoUserId])
  @@map("slack_user_bindings")
}

/// Short-lived token bridging a web-signed-in user to a WhatsApp number.
/// User messages the token to the Sendero WA bot; the webhook consumes
/// the token and writes a ChannelIdentity row.
model WhatsAppLinkToken {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String
  userId     String
  token      String    @unique
  expiresAt  DateTime  @db.Timestamptz(6)
  consumedAt DateTime? @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([expiresAt])
  @@map("whatsapp_link_tokens")
}

/// Per-tenant WhatsApp Business install, mediated by Kapso.
///
/// Created once the tenant admin completes the embedded signup flow
/// (see `@sendero/kapso` setup-link). Kapso fires
/// `whatsapp.phone_number.created` to our project-scope webhook, the
/// handler resolves the customer back to the Sendero tenant (via
/// `kapsoCustomerId` external-id mapping) and inserts this row.
///
/// One install per tenant for v1. Multi-install is tracked in the v1
/// deferred list. Re-onboarding overwrites the row with a new
/// `kapsoConnectionId`.
model WhatsAppInstall {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @unique
  /// Kapso's customer id (scoped to Sendero's Kapso project). Used for
  /// setup-link re-issue and health pings.
  kapsoCustomerId     String    @unique
  /// Kapso's internal connection id for the WhatsApp number. Distinct
  /// from Meta's `phone_number_id` — Kapso exposes both.
  kapsoConnectionId   String?   @unique
  businessDisplayName String?
  /// Meta Graph API id — used for outbound sends + webhook routing.
  phoneNumberId       String?   @unique
  /// Meta WABA id — used when creating / submitting templates.
  businessAccountId   String?
  displayPhoneNumber  String?
  /// Per-install webhook secret, Kapso-issued on registration. Stored
  /// plaintext pending `@sendero/crypto` — see v1 deferred list.
  webhookSecret       String
  status              String    @default("pending") // pending | active | disabled | error
  /// Last `status: error` cause, for ops surface debugging.
  lastErrorMessage    String?
  connectedByUserId   String?
  /// Last time the cron health ping succeeded.
  lastHealthyAt       DateTime? @db.Timestamptz(6)
  metadata            Json?
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([phoneNumberId])
  @@map("whatsapp_installs")
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING — tenant caps + batched nanopayment settlement
// ─────────────────────────────────────────────────────────────────────────────

/// Configurable per-tenant nanopayment spend cap. Enforced by
/// @sendero/billing before a tool call is charged. Absence = no cap.
model TenantSpendCap {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String
  period          CapPeriod @default(daily)
  /// Cap in micro-USDC (e.g. 5_000_000 = $5.00 per day).
  amountMicroUsdc BigInt
  /// Soft cap = alert but don't block. Hard cap rejects further calls.
  hardCap         Boolean   @default(true)
  /// Webhook target for cap breach notifications.
  alertWebhookUrl String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("tenant_spend_caps")
}

/// Composable policy guard rows for `@sendero/transfer-policy`. One row =
/// one guard. Compose multiple rows into a `PolicyChain` at runtime via
/// `apps/app/lib/transfer-policy/load.ts::loadPolicyChain()`.
///
///   guardKind   config shape
///   ─────────   ────────────────────────────────────────────────────────
///   budget      { period: 'daily' | 'weekly' | 'monthly',
///                 capMicroUsdc: string }   // bigint stored as string
///   single_tx   { maxMicroUsdc: string }
///   recipient   { mode: 'allow' | 'deny', addresses: string[] }
///   rate_limit  { maxCount: number, windowMs: number }
///   confirm     { triggerAtMicroUsdc?: string, reason?: string }
model TransferPolicy {
  id              String   @id @default(cuid())
  tenantId        String
  scope           String
  travelerId      String?
  toolName        String?
  guardKind       String
  config          Json
  hardCap         Boolean  @default(true)
  alertWebhookUrl String?
  enabled         Boolean  @default(true)
  priority        Int      @default(100)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  traveler User?  @relation("TravelerPolicies", fields: [travelerId], references: [id], onDelete: Cascade)

  @@index([tenantId, scope, enabled])
  @@index([tenantId, travelerId, enabled])
  @@index([tenantId, toolName, enabled])
  @@map("transfer_policies")
}

/// Per-attempt log for every Unified Balance Kit / DCW outbound spend.
/// Written by `/api/transfer/spend` at every branch — passed, blocked,
/// pending, executed, failed — so dashboards and budget guards have a
/// single source of truth for what the chain has been doing.
///
///   passed   — chain allowed; kit call hasn't returned yet (transient).
///   executed — kit.unifiedBalance.spend() succeeded, txHash set.
///   blocked  — chain hard-rejected, no money moved.
///   pending  — chain returned requiresApproval; awaiting operator click.
///   failed   — kit call returned an error mid-execution.
///
/// Budget guards read this table alongside `MeterEvent` so DCW transfers
/// count against the same windows that x402 charges do.
model TransferAttempt {
  id                String   @id @default(cuid())
  tenantId          String
  travelerId        String?
  amountMicroUsdc   BigInt
  /// Destination address (0x… EVM, sol… Solana, etc.).
  recipient         String
  /// App Kit chain name (e.g. "Arc_Testnet", "Base_Sepolia").
  destinationChain  String
  /// Source-chain breakdown when explicit allocations were used; null
  /// for App-Kit-automatic-routing.
  sourceAllocations Json?
  status            String   @default("passed")
  /// Returned by kit.unifiedBalance.spend() on success.
  txHash            String?
  /// Reason populated when status = blocked / pending / failed.
  blockReason       String?
  /// Trimmed PolicyChainResult.trace[] for audit / dashboard display.
  policyTrace       Json?
  /// Free-form metadata (App Kit fee breakdown, agent DID, etc.).
  metadata          Json?
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  traveler User?  @relation("TravelerTransferAttempts", fields: [travelerId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, travelerId, createdAt])
  @@map("transfer_attempts")
}

/// Generic webhook dedupe ledger. Every inbound webhook (Duffel, Slack,
/// WhatsApp, Stripe, ...) writes one row keyed by provider + externalId
/// so retries are idempotent. Processed rows carry `processedAt`.
model WebhookEvent {
  id              String    @id @default(uuid()) @db.Uuid
  receivedAt      DateTime  @default(now()) @db.Timestamptz(6)
  processedAt     DateTime? @db.Timestamptz(6)
  provider        String
  externalId      String
  eventType       String
  payload         Json
  processingError String?

  @@unique([provider, externalId])
  @@index([provider, processedAt])
  @@map("webhook_events")
}

model Invoice {
  id       String        @id @default(cuid())
  tenantId String
  kind     InvoiceKind
  status   InvoiceStatus @default(draft)

  number   String
  issuedAt DateTime? @db.Timestamptz(6)
  dueAt    DateTime? @db.Timestamptz(6)
  paidAt   DateTime? @db.Timestamptz(6)

  fromName    String
  fromAddress Json?
  fromTaxId   String?
  fromLogoUrl String?

  toName    String
  toEmail   String
  toAddress Json?
  toTaxId   String?

  currency       String  @default("USD") @db.Char(3)
  subtotalMicro  BigInt  @default(0)
  discountMicro  BigInt  @default(0)
  taxRate        Decimal @default(0) @db.Decimal(7, 4)
  taxAmountMicro BigInt  @default(0)
  vatRate        Decimal @default(0) @db.Decimal(7, 4)
  vatAmountMicro BigInt  @default(0)
  totalMicro     BigInt  @default(0)

  template Json

  bookingId String? @unique

  periodStart DateTime? @db.Timestamptz(6)
  periodEnd   DateTime? @db.Timestamptz(6)

  cfdiRef String?

  pdfBlobUrl    String?
  pdfRenderedAt DateTime? @db.Timestamptz(6)

  publicToken String @unique

  metadata Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking   Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  lineItems InvoiceLineItem[]
  payments  InvoicePayment[]

  @@unique([tenantId, number])
  @@index([tenantId, status, createdAt])
  @@index([kind, periodStart])
  @@map("invoices")
}

model InvoiceLineItem {
  id             String  @id @default(cuid())
  invoiceId      String
  position       Int
  description    String
  quantity       Decimal @default(1) @db.Decimal(12, 4)
  unitPriceMicro BigInt
  amountMicro    BigInt
  sourceKind     String?
  sourceRef      String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, position])
  @@map("invoice_line_items")
}

model InvoicePayment {
  id          String   @id @default(cuid())
  invoiceId   String
  paidAt      DateTime @default(now()) @db.Timestamptz(6)
  amountMicro BigInt
  method      String
  txHash      String?
  reference   String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, paidAt])
  @@map("invoice_payments")
}

model InvoiceSequence {
  tenantId String
  year     Int
  nextSeq  Int    @default(1)

  @@id([tenantId, year])
  @@map("invoice_sequences")
}

/// A batched USDC settlement of many MeterEvents. One on-chain transfer
/// per batch to amortize gas. Append-only once settled.
model NanopayBatch {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String
  status          NanopayBatchStatus @default(pending)
  /// Sum of priceMicroUsdc across all member events.
  totalMicroUsdc  BigInt
  eventCount      Int
  /// ISO 8601 window start (inclusive).
  windowStartedAt DateTime           @db.Timestamptz(6)
  /// ISO 8601 window end (exclusive).
  windowEndedAt   DateTime           @db.Timestamptz(6)
  /// On-chain settlement reference once the batch ships.
  txHash          String?
  chain           String?            @default("arc-testnet")
  settledAt       DateTime?          @db.Timestamptz(6)
  error           String?
  retryCount      Int                @default(0)
  lastError       String?
  createdAt       DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, windowStartedAt])
  @@index([status, windowEndedAt])
  @@map("nanopay_batches")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRIP COMPANION (Phase 11f) — audit + cache tables
// Thin, per-trip audit rows. Duffel stays canonical for orders / cancellations
// / credits; workflow runs stay canonical for state transitions. These tables
// exist so analytics + finance UI don't have to parse the Trip.events blob
// or replay workflow runs to answer "what did the traveler choose" or "what
// nudges fired when".
// ─────────────────────────────────────────────────────────────────────────────

/// Per-offer ancillary picker result. One row per pick-then-book round,
/// keyed by Duffel offerId. Becomes the source for invoice line items
/// once the order is ticketed.
model AncillarySelection {
  id            String    @id @default(cuid())
  tenantId      String
  tripId        String?
  userId        String? // traveler who made the selection
  offerId       String // Duffel off_…
  bookingId     String? // Booking.id once booked
  workflowRunId String?
  /// Array of { service_id, quantity, segment_ids?, type, total_amount, total_currency }.
  services      Json
  /// Running total at pick time — useful for diff when Duffel re-prices.
  totalAmount   Decimal?  @db.Decimal(12, 2)
  totalCurrency String?   @db.Char(3)
  bookedAt      DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, createdAt])
  @@index([offerId])
  @@index([bookingId])
  @@map("ancillary_selections")
}

/// One disruption-recovery run per triggering event (delay, cancellation,
/// schedule change). Tracks source and resolution independent of the
/// workflow run so finance can scan "how many disruptions this quarter"
/// without touching the runner.
model DisruptionRun {
  id            String    @id @default(cuid())
  tenantId      String
  tripId        String
  bookingId     String? // the disrupted booking
  /// delay | cancellation | schedule_changed
  kind          String
  /// traveler | webhook | agent | ops
  source        String
  workflowRunId String?
  /// open | awaiting_decision | rebooking | refunding | resolved | failed
  status        String    @default("open")
  /// Final decision blob: { choice, fareDeltaUsd, refundUsd, newBookingId, tx? }
  resolution    Json?
  resolvedAt    DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, createdAt])
  @@index([tenantId, status])
  @@index([bookingId])
  @@map("disruption_runs")
}

/// Scheduled + fired check-in nudges. One row per (trip, scheduled slot).
/// Cron queries `scheduledAt < now AND firedAt IS NULL` for catch-up.
model CheckInNudge {
  id          String    @id @default(cuid())
  tenantId    String
  tripId      String
  bookingId   String?
  /// T-24h (or other window) — absolute UTC.
  scheduledAt DateTime  @db.Timestamptz(6)
  firedAt     DateTime? @db.Timestamptz(6)
  actionedAt  DateTime? @db.Timestamptz(6)
  /// whatsapp | slack | email | web
  channel     String
  /// ISO8601 of the latest safe departure from origin to reach the gate.
  leaveByIso  String?
  /// Free-form snapshot: countdown, transit minutes, gate id, etc.
  metadata    Json?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, scheduledAt])
  @@index([scheduledAt, firedAt])
  @@map("check_in_nudges")
}

/// Composed travel-safety brief output. Per-provider outputs kept inline
/// so the UI can re-render without re-calling providers (each is metered).
model SafetyBrief {
  id            String   @id @default(cuid())
  tenantId      String
  tripId        String?
  userId        String?
  /// { name, iata?, lat, lng } — enough to re-key a cache lookup.
  destination   Json
  workflowRunId String?
  weather       Json?
  airQuality    Json?
  timezone      Json?
  elevation     Json?
  travelSafety  Json?
  /// low | moderate | high | extreme
  riskLevel     String   @default("low")
  computedAt    DateTime @default(now()) @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, computedAt])
  @@index([tenantId, riskLevel])
  @@map("safety_briefs")
}

/// One arrival-playbook invocation per trip/airport combo. Stores the
/// fully composed share payload so the web view can re-render the same
/// playbook the traveler saw on WA.
model ArrivalPlaybookRun {
  id               String    @id @default(cuid())
  tenantId         String
  tripId           String
  bookingId        String? // arrival flight booking
  airportIata      String    @db.Char(3)
  transferOptionId String? // airport_transfer_coordinator result ref
  /// Restaurant + POI ids that made it into the playbook.
  restaurantIds    Json      @default("[]")
  /// Static map CID/URL for channel-safe rendering.
  routeMapCid      String?
  /// Full composed share payload — bullets, CTAs, slackMrkdwn, whatsappUrl.
  playbook         Json
  workflowRunId    String?
  actionedAt       DateTime? @db.Timestamptz(6) // traveler tapped a step
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, createdAt])
  @@index([bookingId])
  @@map("arrival_playbook_runs")
}

/// Duffel Travel Support Assistant (or in-app support) turn log.
/// Exists primarily for finance (TSA calls are metered) and QA
/// (outcome distribution per tenant).
model SupportTurn {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?
  tripId          String?
  bookingId       String?
  /// Duffel's internal id if exposed; otherwise null.
  duffelSupportId String?
  /// Short-form summary of what the traveler asked.
  turnSummary     String
  /// answered | escalated | unresolved | deflected
  outcome         String
  /// MeterEvent.id — TSA turns are nanopaid.
  nanopayEventId  String?
  /// Redacted request/response blob (PII-stripped).
  rawIo           Json?
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, createdAt])
  @@index([tenantId, outcome])
  @@index([userId])
  @@map("support_turns")
}

// ─────────────────────────────────────────────────────────────────────────────
// TREASURY MULTISIG (phase 11g)
// ─────────────────────────────────────────────────────────────────────────────

/// Pending weighted-multisig operation — a proposed userOp awaiting signature
/// collection on a treasury MSCA. Signatures accumulate in the `signatures`
/// JSON until `collectedWeight` >= `threshold`, at which point the op
/// transitions from `pending` → `threshold_met` and can be submitted to the
/// bundler. Terminal states: `submitted`, `confirmed`, `expired`, `cancelled`.
///
/// Ported from desk-v1 (pending_multisig_ops) and adapted for Sendero's
/// tenant-scoped model. Initiator tracking lives in `initiatedByClerkUserId`
/// (Clerk user id) so we avoid cross-database foreign keys.
///
/// TODO(v1): cross-chain children — desk-v1 adds a `pending_multisig_op_children`
/// table for cross-chain fan-out (one parent op → one child op per blockchain).
/// Sendero ships the single-chain parent case first; children will land with
/// the Gateway integration phase.
model PendingMultisigOp {
  id                     String    @id @default(cuid())
  tenantId               String
  /// MSCA wallet id (CircleWallet.id) this op targets.
  walletId               String
  /// UserOp hash (0x…) from EntryPoint v0.7 — unique per chain + nonce.
  opHash                 String    @unique
  /// Full packed UserOperation struct (sender, nonce, gas fields, etc.).
  userOp                 Json
  /// Encoded `execute` / `executeBatch` call data — redundant with userOp.callData
  /// but indexed separately so we can search by target contract without parsing.
  callData               String
  /// Optional per-op metadata (transfer summary, recipient, amount, tokenSymbol).
  transferMeta           Json      @default("{}")
  /// Weight required for execution (sum of signer weights).
  threshold              Int
  /// Sum of weights contributed so far across the `signatures` array.
  collectedWeight        Int       @default(0)
  /// Array of { signerAddress, signature, weight, sigType, signedAt } entries.
  signatures             Json      @default("[]")
  /// Lifecycle: pending | threshold_met | submitted | confirmed | expired | cancelled.
  status                 String    @default("pending")
  /// Clerk user id of the member who initiated this op.
  initiatedByClerkUserId String
  expiresAt              DateTime  @db.Timestamptz(6)
  submittedAt            DateTime? @db.Timestamptz(6)
  confirmedAt            DateTime? @db.Timestamptz(6)
  /// On-chain transaction hash once the userOp is mined.
  txHash                 String?
  createdAt              DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([opHash])
  @@index([expiresAt])
  @@map("pending_multisig_ops")
}

// ─── Passport Vault (envelope-encrypted) ─────────────────────────────────────
//
// Highly-sensitive traveler identity documents. The full extraction (name,
// passport#, DOB, MRZ lines, place of birth, image hash) lives ONLY in the
// `ciphertext` column — encrypted via pgcrypto pgp_sym_encrypt with a
// per-tenant DEK derived from the env-stored KEK (see @sendero/vault).
//
// The plaintext sibling columns carry ONLY sanitized signals the LLM and
// agent tools are allowed to see:
//   - nationalityIso3         : "USA" — needed for visa-rule lookup
//   - expiresOn               : date  — needed for 6-month-rule check
//   - documentVariant         : passport | national_id | drivers_license | …
//   - mrzChecksumValid        : bool  — trust signal
//   - extractedBy             : mrz_fast | gemini_zdr
//
// Name / DOB / document number / MRZ lines / place of birth / image hash
// NEVER appear in plaintext columns. They only exist inside `ciphertext`,
// decryptable only by:
//   - the traveler themselves via /dashboard/passport (Clerk-auth)
//   - a workflow step running under the `vault:decrypt` service role
// Every decrypt goes through PassportVaultAccessLog (append-only).
//
// Compliance note: this table is INTENTIONALLY not referenced from Trip —
// a vault entry is scoped to (tenantId, userId) and reused across trips.
model PassportVault {
  id       String @id @default(cuid())
  tenantId String
  userId   String

  /// Envelope-encrypted full extraction blob (JSON-encoded IdDocumentExtraction
  /// + image SHA-256 + original filename). Written via pgp_sym_encrypt with
  /// the tenant DEK. Reads go through @sendero/vault decryptEnvelope().
  ciphertext Bytes

  /// AES-GCM nonce / PGP session-key wrapper bytes if we switch off pgp_sym
  /// down the road. Null when using pgp_sym_encrypt (it's self-contained).
  nonce Bytes?

  /// Key version — bumps when we rotate the KEK. @sendero/vault keeps old
  /// DEKs around keyed by this version so we can decrypt + re-wrap on read.
  keyVersion Int @default(1)

  // ── Sanitized signals (plaintext, LLM-safe) ─────────────────────────────

  /// ISO 3166-1 alpha-3 nationality code. Needed for visa-rule lookup.
  /// NOT stored when this would de-facto identify the traveler (e.g. the
  /// only American on a single-tenant agency) — caller decides.
  nationalityIso3 String?

  /// Expiry date. Date only, not datetime, to minimize fingerprint.
  expiresOn DateTime? @db.Date

  /// Document kind. No issuing country here — that's in ciphertext.
  documentVariant String // passport | national_id | drivers_license | residence_permit

  /// Machine-readable zone passed the ICAO 9303 checksum suite.
  mrzChecksumValid Boolean @default(false)

  /// Which extractor produced this row. Audit signal.
  extractedBy String // mrz_fast | gemini_zdr | manual

  extractedAt DateTime @default(now()) @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  /// Revocation flag — when true, the ciphertext is tombstoned. We keep the
  /// row so access logs remain joinable, but decrypt requests fail fast.
  revokedAt DateTime? @db.Timestamptz(6)

  tenant     Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessLogs PassportVaultAccessLog[]

  @@unique([tenantId, userId, documentVariant])
  @@index([tenantId, expiresOn])
  @@index([userId])
  @@map("passport_vault")
}

/// Append-only audit log for every decrypt / read / verify operation on a
/// vault entry. Written from @sendero/vault; never truncated.
model PassportVaultAccessLog {
  id      String @id @default(cuid())
  vaultId String

  /// What the caller did: decrypt | signals_read | verify | revoke | upsert.
  action String

  /// Who asked. For self-service: clerkUserId. For agents: svc:{apiKeyId}.
  /// For workflow: wf:{workflowId}:{stepId}. For humans via operator view:
  /// op:{clerkUserId}.
  actorRef String

  /// Where the call came from — ties back to a route or workflow run.
  source String // api/passport/upload | api/passport/[id]/self | workflow:verify_travel_documents | ...

  /// JSON context (ip, userAgent, tripId, reason). Never contains decrypted
  /// PII — decrypted payloads are consumed then dropped, not logged.
  context Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  vault PassportVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId, createdAt])
  @@index([action, createdAt])
  @@map("passport_vault_access_log")
}

// ─── Trip Eligibility Runs (async visa verification) ─────────────────────────
//
// Per-(trip × traveler) verification job.  Calls out to Sherpa's
// Requirements API (`POST /v3/trips`) in the background so the booking
// UI never halts waiting for an external network round-trip.  Frontend
// subscribes to the run's SSE channel (`pg_notify('trip_eligibility_run:${id}')`)
// and updates the verdict card in place the moment the run transitions
// to `succeeded` or `failed`.
//
// Failure path: when Sherpa is unreachable / returns 5xx, we fall back
// to the curated corridor table in @sendero/vault/visa-rules and mark
// the run `succeeded` with `source = 'fallback'` — the UX is never
// blocked by an external provider outage.
//
// Access pattern:
//   1. startRun(tripId, travelerUserId)   — writes a `pending` row
//   2. background worker calls Sherpa     — writes `running → succeeded | failed`
//   3. finalize emits pg_notify           — SSE updates the frontend
//   4. verdict JSON is consumed & cached on the trip page
//
// The ingested Sherpa response stays in `providerRaw` for audit +
// replay.  We don't expose it to the LLM — the verdict alone is what
// tools and workflows see.
model TripEligibilityRun {
  id         String  @id @default(cuid())
  tenantId   String
  /// Optional — runs can be started for a draft trip not yet persisted
  /// (client-side dry-run on flight search).  Real trip FKs are set
  /// once the trip is created.
  tripId     String?
  travelerId String

  /// State machine: pending → running → (succeeded | failed | skipped).
  /// `skipped` means we short-circuited to the curated-JSON path
  /// because the tenant hasn't enabled Sherpa.
  status String @default("pending")

  /// Which source produced the verdict: 'sherpa' | 'fallback_rules' | 'none'.
  source String?

  /// Opaque identifier Sherpa stamps on the trip object (tri_... slug).
  /// Used to de-duplicate re-runs + correlate webhook callbacks.
  sherpaTripId String?

  /// Origin + destination ISO-3 at the time of the run.  Storing these
  /// lets us re-run without walking the Trip graph.
  originIso3      String
  destinationIso3 String
  departureDate   DateTime  @db.Date
  returnDate      DateTime? @db.Date
  purpose         String    @default("business")

  /// Sanitized verdict JSON — same shape as TravelEligibilityVerdict
  /// from @sendero/vault.  Safe for the LLM; the raw Sherpa body is
  /// kept in `providerRaw` for replay but never exposed.
  verdict Json?

  /// Raw Sherpa response body (when source='sherpa').  Never rendered
  /// in the UI; used for audit replay + regression testing.
  providerRaw Json?

  /// Human-readable failure reason when status='failed'.
  failureReason String?

  /// Triggers: 'flight_search' | 'booking_review' | 'agent_tool' | 'manual'.
  trigger String @default("manual")

  requestedByActor String? // clerkUserId / svc:keyId / wf:id:step

  requestedAt DateTime  @default(now()) @db.Timestamptz(6)
  startedAt   DateTime? @db.Timestamptz(6)
  completedAt DateTime? @db.Timestamptz(6)

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  traveler User   @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId])
  @@index([travelerId, requestedAt])
  @@index([status, requestedAt])
  @@map("trip_eligibility_runs")
}
