// Sendero × Arc — Prisma schema
// Multi-tenant corporate travel SaaS backing:
//   - Clerk orgs (Tenant) + passkey MSCA users
//   - Trips / Bookings (Duffel) + Policies (JSON ruleset)
//   - Suppliers (public + tenant-private)
//   - Circle Gateway Wallets + x402 nanopayment MeterEvents
//   - On-chain Settlements (fan-out legs) + ERC-8004 Attestations
//   - Clerk billing Subscriptions
//
// Hard rules:
//   * Row-level isolation via tenantId foreign keys.
//   * Financial tables (MeterEvent, Settlement, SettlementLeg, Attestation)
//     are append-only — no destructive updates, no cascade deletes from Tenant.
//   * timestamptz everywhere.
//   * cuid() for user-facing ids; uuid() for internal rows.
//   * JSON columns for free-form / provider-raw payloads.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto]
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum BillingTier {
  free
  basic
  pro
  business
  enterprise
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  paused
  incomplete
}

enum Role {
  agency_admin
  finance
  traveler
  guest
}

enum MembershipStatus {
  active
  invited
  suspended
  removed
}

enum TripStatus {
  draft
  searching
  awaiting_approval
  booked
  in_progress
  completed
  canceled
  failed
}

enum BookingStatus {
  pending
  confirmed
  ticketed
  canceled
  refunded
  failed
}

enum BookingKind {
  flight
  hotel
  rail
  car
  other
}

enum SupplierKind {
  airline
  hotel
  dmc
  rail
  car_rental
  other
}

enum SupplierVisibility {
  public
  tenant_private
}

enum SupplierStatus {
  active
  inactive
  blacklisted
  pending_review
}

enum MeterStatus {
  paid
  free
  rejected
  /// API-key-authenticated call from a sandbox key (or a production
  /// key downgraded during testnet-beta network mode). Row is kept for
  /// analytics; NanopayBatch excludes `status='sandbox'` from settlement.
  sandbox
  /// Paid from the tenant's SaaS-included credit grant (Subscription.meterBalanceMicro).
  /// Excluded from NanopayBatch settlement and from CapStore.spentInWindow so the
  /// monthly spend cap only counts actual out-of-pocket overage.
  credit
}

enum SettlementStatus {
  pending
  submitted
  confirmed
  failed
  reverted
}

enum SettlementLegKind {
  supplier
  agency
  rail
  validator
  refund
  fee
  other
}

enum MemoryKind {
  preference
  observation
  fact
  relation
  trip_event
  policy_note
}

enum PreferenceCategory {
  seat
  cabin_class
  carrier
  meal
  hotel_chain
  hotel_room_type
  bag_allowance
  layover_tolerance
  departure_time
  price_ceiling
}

enum PreferenceSignal {
  approve
  reject
  select
  skip
}

enum ChannelKind {
  whatsapp
  slack
  email
  web
}

enum NanopayBatchStatus {
  pending
  settling
  settled
  failed
}

enum CapPeriod {
  daily
  monthly
}

enum InvoiceKind {
  booking
  platform_bill
  credit_note
}

enum InvoiceStatus {
  draft
  issued
  sent
  viewed
  paid
  overdue
  void
}

/// How a User row originated.
///   - native:   claimed via Clerk sign-up (clerkUserId is set).
///   - slack:    auto-provisioned from a Slack message (clerkUserId may
///               be null until the user signs up with the same email).
///   - whatsapp: future — auto-provisioned from a WhatsApp message.
///   - guest:    future — guest-link claim flow (escrow trips).
enum UserSource {
  native
  slack
  whatsapp
  guest
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANCY
// ─────────────────────────────────────────────────────────────────────────────

/// Paying customer. Clerk org maps 1:1 to a Tenant.
/// A Tenant can be a TMC (e.g. "SP Corporate Travel") or a corp client
/// ("Vale"). Sub-agencies modeled via self-referencing parentTenantId.
model Tenant {
  id                        String      @id @default(cuid())
  clerkOrgId                String      @unique
  slug                      String      @unique // URL-safe, e.g. "sp-corporate-travel"
  displayName               String
  billingTier               BillingTier @default(free)
  fiscalCountry             String? // ISO-3166-1 alpha-2, e.g. "BR"
  arcAddress                String? // treasury MSCA on Arc (0x…)
  parentTenantId            String?
  /// Duffel CustomerUserGroup id (`usg_…`) — each tenant maps to one group
  /// so travelers get the Travel Support Assistant scoped to their org.
  duffelCustomerUserGroupId String?     @unique
  metadata                  Json? // free-form; logo, phone, custom branding

  legalName           String?
  billingContactEmail String?
  billingAddress      Json?
  taxId               String?
  brandLogoUrl        String?
  brandColors         Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  parent   Tenant?  @relation("TenantHierarchy", fields: [parentTenantId], references: [id], onDelete: SetNull)
  children Tenant[] @relation("TenantHierarchy")

  memberships         Membership[]
  policies            Policy[]
  trips               Trip[]
  bookings            Booking[]
  suppliers           Supplier[]
  meterEvents         MeterEvent[]
  settlements         Settlement[]
  subscription        Subscription?
  sessions            Session[]
  attestations        Attestation[]
  agentMemories       AgentMemory[]
  preferenceLogs      PreferenceLog[]
  channelIdentities   ChannelIdentity[]
  groupTrips          GroupTrip[]
  chatSessions        ChatSession[]
  slackInstalls       SlackInstall[]
  slackUserBindings   SlackUserBinding[]
  whatsappInstall     WhatsAppInstall?
  whatsappOutbound    WhatsAppOutboundMessage[]
  whatsappLinkTokens  WhatsAppLinkToken[]
  bookingPayTokens    BookingPayToken[]
  spendCaps           TenantSpendCap[]
  transferPolicies    TransferPolicy[]
  transferAttempts    TransferAttempt[]
  nanopayBatches      NanopayBatch[]
  invoices            Invoice[]
  circleWallets       CircleWallet[]
  ancillarySelections AncillarySelection[]
  disruptionRuns      DisruptionRun[]
  checkInNudges       CheckInNudge[]
  safetyBriefs        SafetyBrief[]
  arrivalPlaybookRuns ArrivalPlaybookRun[]
  supportTurns        SupportTurn[]
  pendingMultisigOps  PendingMultisigOp[]
  passportVaults      PassportVault[]
  tripEligibilityRuns TripEligibilityRun[]
  nftStamps           NftStamp[]
  onchainIdentities   OnchainIdentity[]
  reputationPolicy    ReputationPolicy?
  pricingPolicies     TenantPricingPolicy[]
  otpDeliveryAttempts OtpDeliveryAttempt[]
  securityAlerts      SecurityAlert[]
  gatewaySigner       TenantGatewaySigner?
  gatewayConfig       TenantGatewayConfig?
  gatewayDeposits     GatewayDepositLog[]
  gatewayTransfers    GatewayTransferLog[]
  walletAccessLogs    WalletAccessLog[]

  @@index([parentTenantId])
  @@index([createdAt])
  @@map("tenants")
}

/// Human user. Identified by Clerk; cached MSCA address is deterministic
/// from the passkey (Circle Modular Wallets).
///
/// `clerkUserId` is nullable so we can auto-provision a User from a
/// Slack / WhatsApp message before the human ever signs up via Clerk.
/// When they do sign up with the same email, the Clerk webhook upserts
/// the existing row and stamps `clerkUserId`. `source` records origin.
model User {
  id                   String     @id @default(cuid())
  clerkUserId          String?    @unique
  email                String     @unique
  displayName          String?
  imageUrl             String?
  mscaAddress          String?    @unique // 0x…, nullable until first passkey link
  phone                String?
  /// Duffel CustomerUser id (`icu_…`) — unlocks Travel Support Assistant.
  duffelCustomerUserId String?    @unique
  /// Provenance of this row. See UserSource enum for values.
  source               UserSource @default(native)
  /// Free-form user metadata (preferred language, locale, etc.).
  metadata             Json?
  createdAt            DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime   @updatedAt @db.Timestamptz(6)
  lastSeenAt           DateTime?  @db.Timestamptz(6)

  memberships            Membership[]
  wallets                Wallet[]
  travelerTrips          Trip[]                @relation("TripTraveler")
  createdTrips           Trip[]                @relation("TripCreatedBy")
  bookings               Booking[]             @relation("BookingCreatedBy")
  suppliers              Supplier[]            @relation("SupplierCreatedBy")
  meterEvents            MeterEvent[]
  sessions               Session[]
  channelIdentities      ChannelIdentity[]
  whatsappLinkTokens     WhatsAppLinkToken[]
  airlineCredits         AirlineCredit[]
  passportVaults         PassportVault[]
  tripEligibilityRuns    TripEligibilityRun[]
  slackUserBindings      SlackUserBinding[]
  transferPolicies       TransferPolicy[]      @relation("TravelerPolicies")
  transferAttempts       TransferAttempt[]     @relation("TravelerTransferAttempts")
  nftStamps              NftStamp[]            @relation("StampTraveler")
  nftStampOwnerships     NftStampOwnership[]   @relation("StampOwner")
  onchainIdentities      OnchainIdentity[]
  pricingPoliciesCreated TenantPricingPolicy[] @relation("TenantPricingPolicyCreatedBy")
  groupTripMemberships   GroupTripPassenger[]  @relation("GroupTripPassengers")
  chatSessions           ChatSession[]         @relation("ChatSessionUser")

  @@index([createdAt])
  @@map("users")
}

/// Cached Duffel airline credit (unused ticket, MCO, voucher, etc.).
/// Mirrors the wire type in @sendero/duffel. Webhooks (or the ensure
/// path) keep `state` in sync with Duffel. `state` is derived from
/// spent_at / invalidated_at / expires_at so indexes on it work
/// directly for "available credits" lookups.
model AirlineCredit {
  id              String    @id // Duffel id, e.g. acd_…
  tenantId        String?
  userId          String? // Sendero User.id
  duffelUserId    String? // icu_… denormalized for list scans
  airlineIataCode String    @db.Char(2)
  /// eticket | mco | other
  type            String
  code            String
  amount          Decimal   @db.Decimal(18, 6)
  currency        String    @db.Char(3)
  issuedOn        DateTime? @db.Date
  expiresAt       DateTime? @db.Timestamptz(6)
  spentAt         DateTime? @db.Timestamptz(6)
  invalidatedAt   DateTime? @db.Timestamptz(6)
  givenName       String?
  familyName      String?
  passengerId     String? // pas_…
  orderId         String? // ord_…
  /// available | spent | invalidated | expired — precomputed for fast filters.
  state           String    @default("available")
  liveMode        Boolean   @default(false)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, state, expiresAt])
  @@index([tenantId, state])
  @@index([duffelUserId, state])
  @@map("airline_credits")
}

/// Many-to-many User↔Tenant with a per-tenant role.
model Membership {
  id                String           @id @default(cuid())
  tenantId          String
  userId            String
  clerkMembershipId String?          @unique
  role              Role             @default(traveler)
  status            MembershipStatus @default(active)
  invitedBy         String?
  invitedAt         DateTime?        @db.Timestamptz(6)
  joinedAt          DateTime?        @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@index([userId])
  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING (Clerk mirror)
// ─────────────────────────────────────────────────────────────────────────────

/// One Subscription per Tenant (Clerk Billing mirror).
model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  clerkSubId           String?            @unique
  tier                 BillingTier        @default(free)
  status               SubscriptionStatus @default(active)
  currentPeriodEnd     DateTime?          @db.Timestamptz(6)
  /// Signed micro-USDC balance for the current billing period (negative = owed).
  /// Refilled by the Clerk subscription.created/subscription.updated webhook on
  /// cycle renewal. Use-it-or-lose-it: no rollover.
  meterBalanceMicro    BigInt             @default(0)
  /// Sum of `status='credit'` MeterEvents inside the current daily window.
  /// Persisted so the atomic preflight UPDATE can enforce the daily sub-cap
  /// (typically 25% of monthlyIncludedCreditsMicro) without a separate
  /// aggregate read race.
  dailyCreditBurnMicro BigInt             @default(0)
  /// UTC timestamp when the current daily window opened. Reset by preflight
  /// when wall clock crosses (dailyWindowStartedAt + 24h).
  dailyWindowStartedAt DateTime?          @db.Timestamptz(6)
  metadata             Json?
  createdAt            DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// POLICY
// ─────────────────────────────────────────────────────────────────────────────

/// Corporate travel ruleset JSON. Many per tenant (e.g. per corp client).
model Policy {
  id            String    @id @default(cuid())
  tenantId      String
  slug          String // "vale-corp-2026"
  displayName   String
  /// JSON rules: maxNightUsd, intlCabinRequired, preferredCarriers, fiscalCountry, etc.
  rules         Json
  isDefault     Boolean   @default(false)
  version       Int       @default(1)
  effectiveFrom DateTime? @db.Timestamptz(6)
  effectiveTo   DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trips  Trip[]

  @@unique([tenantId, slug])
  @@index([tenantId, isDefault])
  @@index([tenantId, createdAt])
  @@map("policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRIP / BOOKING — the core product objects
// ─────────────────────────────────────────────────────────────────────────────

/// A persistent conversational thread for one trip. Core object.
model Trip {
  id                    String     @id @default(cuid())
  tenantId              String
  policyId              String?
  travelerId            String? // User.id — may be guest
  createdById           String? // booking agent
  intent                Json // parsed intent: {origin,dest,dates,pax,purpose}
  status                TripStatus @default(draft)
  /// Append-only event log (agent turns, tool calls, approvals).
  events                Json       @default("[]")
  settlementRef         String? // convenience pointer to latest Settlement
  cfdiRef               String? // MX fiscal invoice reference
  reputationScore       Int? // 0-100, mirrored from Attestation
  totalUsdc             Decimal?   @db.Decimal(18, 6) // denormalized from bookings
  metadata              Json?
  /// Per-trip channel routing override. Shape (see TripChannelBindings
  /// in `apps/app/lib/channel-routing.ts`):
  ///   { primary: 'whatsapp'|'slack'|'email'|'web',
  ///     whatsapp?: { identityId },
  ///     slack?: { channelId, threadTs? },
  ///     notifyChannels?: Array<...> }
  /// Nudge emitters read this before each share; null = use tenant default.
  channelBindings       Json?
  /// First-class verified contact channels for the guest, set at
  /// prefund_trip time by the buyer (and re-verified out-of-band).
  /// Shape: `{ phone?: string, email?: string }`. Read by the OTP
  /// resend route (`/api/trip/[tripId]/claim-code/resend`) to gate
  /// resend requests against the actual contacts the buyer attached.
  /// Backed by `migrations/20260425133807_trip_guest_verified_contacts`.
  guestVerifiedContacts Json?
  createdAt             DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime   @updatedAt @db.Timestamptz(6)

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policy    Policy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  traveler  User?   @relation("TripTraveler", fields: [travelerId], references: [id], onDelete: SetNull)
  createdBy User?   @relation("TripCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  bookings           Booking[]
  settlements        Settlement[]
  attestations       Attestation[]
  sessions           Session[]
  nftStamps          NftStamp[]
  reputationFeedback ReputationFeedback[]
  chatSessions       ChatSession[]        @relation("ChatSessionTrip")

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([policyId])
  @@index([travelerId])
  @@index([createdById])
  @@map("trips")
}

/// Persisted operator chat session — one row per `useChat` instance
/// in the console. Lets the CHAT MODE tab list past sessions, and
/// keeps a chat re-viewable even after it's been (re)assigned to a
/// trip. `tripId` is nullable: a chat can exist on its own and later
/// be promoted to a trip; a trip can have many chats over its life.
model ChatSession {
  id        String   @id @default(cuid())
  tenantId  String
  /// Operator who started the session (Clerk-authed User row).
  userId    String?
  /// Optional auto-generated title (first user message snippet, etc.).
  title     String?
  /// Trip this chat is attached to. Re-bindable.
  tripId    String?
  /// Free-form context (channel hint, system prompt name, etc.).
  metadata  Json?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User?         @relation("ChatSessionUser", fields: [userId], references: [id], onDelete: SetNull)
  trip     Trip?         @relation("ChatSessionTrip", fields: [tripId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([tripId])
  @@map("chat_sessions")
}

/// One message inside a ChatSession. Mirrors AI SDK's UIMessage
/// shape: role + the parts array (text / tool-* / reasoning) so a
/// re-render through `/dashboard/agent-chat` or MetaInbox can fully
/// reconstruct the original render path.
model ChatMessage {
  id            String   @id @default(uuid()) @db.Uuid
  chatSessionId String
  /// 'user' | 'assistant' | 'system'.
  role          String
  /// Concatenated text content (denormalized for fast list previews).
  content       String   @default("")
  /// Original UIMessage.parts array (text / tool-* / reasoning / sources).
  parts         Json?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  session ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@map("chat_messages")
}

/// Group trip — a coordinated multi-passenger journey (corporate
/// retreat, family vacation, conference cohort) where the operator
/// manages many travelers under one roof. Distinct from `Trip`, which
/// is per-traveler and per-itinerary; a single GroupTrip eventually
/// fans out into N child Trips at booking time.
model GroupTrip {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  destination   String?
  /// Optional capacity cap. Adds beyond this throw at the tool layer.
  /// Null = unlimited.
  maxPassengers Int?
  /// Free-form metadata (purpose, deposit terms, etc.).
  metadata      Json?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  passengers GroupTripPassenger[]

  @@index([tenantId, createdAt])
  @@map("group_trips")
}

/// Many-to-many between GroupTrip and User. One row per passenger
/// membership. Role is free-form ('lead', 'guest', 'attendee', …).
model GroupTripPassenger {
  id          String   @id @default(uuid()) @db.Uuid
  groupTripId String
  userId      String
  role        String   @default("attendee")
  addedAt     DateTime @default(now()) @db.Timestamptz(6)

  groupTrip GroupTrip @relation(fields: [groupTripId], references: [id], onDelete: Cascade)
  user      User      @relation("GroupTripPassengers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupTripId, userId])
  @@index([userId])
  @@map("group_trip_passengers")
}

/// One reserved product inside a Trip (flight, hotel, rail, car).
model Booking {
  id                   String        @id @default(cuid())
  tenantId             String
  tripId               String
  supplierId           String?
  createdById          String?
  kind                 BookingKind
  status               BookingStatus @default(pending)
  /// Duffel order id, Amadeus PNR locator, etc.
  externalId           String?
  /// Duffel order id once the hold is placed. Separate column (not
  /// externalId) so we can put a global @unique on it for webhook
  /// lookups independent of tenant.
  duffelOrderId        String?       @unique
  pnr                  String?
  totalUsd             Decimal       @db.Decimal(12, 2)
  /// Supplier net rate, in micro-USDC. Backfilled from totalUsd × 1e6 for
  /// rows that pre-date markup v1 (metadata.markupSource flags those).
  costMicroUsdc        BigInt?
  /// Tenant GMV slice (the "agency markup"), in micro-USDC. Null on
  /// pre-v1 rows; 0 when the tenant explicitly priced cost-plus.
  markupMicroUsdc      BigInt?
  /// When markup was set as a percentage of cost. Null when set as an
  /// absolute amount or when pre-v1.
  markupBps            Int?
  /// Sendero's take, in micro-USDC. Denormalized from the markup snapshot
  /// for fast GMV reporting.
  senderoTakeMicroUsdc BigInt?
  /// Human-readable audit pointer to TenantPricingPolicy.version. The
  /// actual race-protected pin lives at metadata.policySnapshot (Eng A2).
  pricingPolicyVersion Int?
  currency             String        @default("USD") @db.Char(3)
  /// Raw provider payload (Duffel offer / order), kept for reconciliation.
  rawDuffel            Json?
  segments             Json? // normalized itinerary
  /// Free-form booking lifecycle metadata (approvals, policy notes, etc.).
  metadata             Json?
  /// Which policy (+ which version of its rules) was applied at booking time.
  appliedPolicyId      String?
  appliedPolicyVersion Int?
  /// Result of the policy evaluation: "allowed", "allowed_with_warnings", "escalated", "rejected".
  policyCheckResult    String?
  /// Structured policy violations captured at book time.
  policyViolations     Json?
  bookedAt             DateTime?     @db.Timestamptz(6)
  createdAt            DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @db.Timestamptz(6)

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("BookingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  settlements        Settlement[]
  invoice            Invoice?
  nftStamps          NftStamp[]
  reputationFeedback ReputationFeedback[]
  payTokens          BookingPayToken[]

  @@unique([tenantId, externalId])
  @@index([tenantId, createdAt])
  @@index([tenantId, kind, createdAt])
  @@index([tripId])
  @@index([supplierId])
  @@index([status])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPLIER
// ─────────────────────────────────────────────────────────────────────────────

/// Airline / hotel / DMC. Either tenant-private (preferred partner) or
/// public (shared registry — tenantId is NULL, visibility = "public").
model Supplier {
  id            String             @id @default(cuid())
  tenantId      String? // null = public registry
  createdById   String?
  kind          SupplierKind
  visibility    SupplierVisibility @default(public)
  status        SupplierStatus     @default(active)
  name          String
  iataCode      String? // for airlines
  country       String? // ISO-3166-1 alpha-2
  arcAddress    String? // on-chain payout address on Arc
  commissionBps Int                @default(0) // basis points, 100 = 1%
  metadata      Json?
  createdAt     DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(6)

  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  bookings  Booking[]

  @@unique([tenantId, iataCode])
  @@index([visibility, status])
  @@index([kind])
  @@index([iataCode])
  @@map("suppliers")
}

// ─────────────────────────────────────────────────────────────────────────────
// WALLETS + METER
// ─────────────────────────────────────────────────────────────────────────────

/// User → on-chain wallet. Polymorphic by provisioner:
///
///   provisioner='msca'  — passkey-controlled Circle Modular Wallet
///                          (tenant treasury today; user-controlled in
///                          future). circleWalletId is null.
///   provisioner='dcw'   — Circle Developer-Controlled Wallet, EOA
///                          account type. Server-side custodial — Circle
///                          holds the keys, signs via entity secret.
///                          One per User, persistent across tenants and
///                          channels (same wallet whether they came in
///                          via Clerk corporate, WhatsApp lead, or B2C).
///                          circleWalletId is set.
///
/// A user may have multiple rows (one per chain) and rows from different
/// provisioners. `(userId, chainId, address)` stays unique.
model Wallet {
  id                  String    @id @default(cuid())
  userId              String
  address             String
  chainId             Int
  /// Cached Circle Gateway unified-USDC balance, in micro-USDC (1e-6).
  gatewayBalanceMicro BigInt    @default(0)
  /// Human label ("daily-ops", "treasury").
  label               String?
  /// Provisioner discriminator. See model docstring for shapes.
  provisioner         String    @default("msca")
  /// Circle DCW wallet id (e.g. `0190fe2c…`). Null for MSCA rows.
  circleWalletId      String?   @unique
  /// Walletset the DCW belongs to. Platform-level for travelers.
  circleWalletSetId   String?
  /// 'EOA' | 'SCA' for DCW; null for MSCA.
  accountType         String?
  /// Free-form. Used by transfer-policy + Gateway flows to cache things
  /// like delegate authorization status per chain.
  metadata            Json?
  lastSeenAt          DateTime? @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chainId, address])
  @@index([address])
  @@index([userId, provisioner])
  @@map("wallets")
}

/// Per-tenant Circle-backed on-chain wallet metadata. Provisioned by the
/// Clerk webhook handler / org provisioning flow (phase-11c). Distinct
/// from the user-scoped Wallet model above.
model CircleWallet {
  id                String    @id @default(cuid())
  tenantId          String
  clerkOrgId        String?
  address           String    @unique
  /// 'treasury' (primary tenant wallet, default-Arc settle target) or
  /// 'operations' (per-chain inbound staging DCW that the Gateway sweep
  /// loop drains into the tenant Gateway EOA). Phase 1 = both kinds on
  /// Arc; Phase 2 widens to per-chain operations rows.
  kind              String
  chain             String
  circleWalletSetId String?
  circleWalletId    String?
  /// Cached USDC balance in micro-USDC (1 USDC = 1_000_000). Authoritative
  /// source is the Circle webhook → `syncWalletBalance()` in
  /// @sendero/circle/balance-sync. Read this in the UI; do not poll RPC.
  usdcBalanceMicro  BigInt?
  /// Cached EURC balance, same convention as usdcBalanceMicro.
  eurcBalanceMicro  BigInt?
  balanceUpdatedAt  DateTime? @db.Timestamptz(6)
  /// SCA deployment cache. Circle DCW SCAs are counterfactual until their
  /// first OUTBOUND tx — `signTypedData` rejects with "undeployed wallet"
  /// before that. We self-send 0 native to deploy on first use and stamp
  /// this column so subsequent transfers skip the round-trip. See
  /// @sendero/sendero-circle/src/sca-deploy.ts (Phase 2).
  scaDeployedAt     DateTime? @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind, chain], name: "tenantId_kind_chain")
  @@index([tenantId, kind])
  @@map("circle_wallets")
}

/// Self-custody EOA per tenant for Circle Gateway burn-intent signing.
///
/// Reason this exists at all: Circle's `/v1/w3s/developer/sign/typedData`
/// injects `chainId` into the EIP-712 domain, but Circle Gateway's on-chain
/// DOMAIN_SEPARATOR has no `chainId` — so any DCW-signed burn intent
/// recovers to the wrong address and Gateway's `/transfer` rejects with
/// "recovered signer does not match sourceSigner". A throwaway viem EOA
/// (no chainId in domain) signs cleanly. Per-tenant EOAs replace the
/// shared `TREASURY_PRIVATE_KEY` for Gateway specifically.
///
/// Scope is deliberately narrow — this signer ONLY signs Gateway burns
/// + deposits. Nanopay batch settlement, App Kit ops, and settle_split
/// outside Gateway routing keep their existing signing paths.
///
/// Encryption: AES-256-GCM via @sendero/encryption. Key material never
/// leaves the server process. `kekVersion` enables KEK rotation without
/// re-encrypting historical rows in lockstep — readers decrypt under
/// the row's KEK version, lazy-rewrite under the latest version on access.
model TenantGatewaySigner {
  tenantId            String   @id
  /// Lowercased 0x… address derived from the encrypted key. We compare
  /// against this on decrypt to detect KEK mismatch / corruption early
  /// and bail rather than silently signing with the wrong key.
  address             String   @unique
  /// Base64-encoded ciphertext envelope (iv:tag:body) from
  /// @sendero/encryption. Plaintext is the 0x… private key.
  encryptedPrivateKey String
  /// KEK generation. Bumped on rotation; row decrypts under
  /// SENDERO_KEK_v{kekVersion} and re-encrypts under latest.
  kekVersion          Int      @default(1)
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_gateway_signers")
}

/// Per-tenant Circle Gateway configuration — which chains are enabled,
/// what addresses receive deposits / mints, and the sweep policy.
///
/// Provisioned at organization.created alongside the signer + ops DCW.
/// Updated when chains are added (Phase 3+) or sweep policy changes.
///
/// `evmDepositorAddress` is denormalized from `TenantGatewaySigner.address`
/// so Gateway API balance calls don't need a join on the hot path.
model TenantGatewayConfig {
  tenantId               String   @id
  /// Address that signs burn intents (= TenantGatewaySigner.address,
  /// lowercased). Denormalized to skip the join on /balances calls.
  evmDepositorAddress    String
  /// Solana DCW address — null until Phase 4. Used as mint recipient
  /// on Solana destinations + as the Gateway depositor for Solana-origin
  /// burns once Solana support lands.
  solanaDepositorAddress String?
  /// Circle Gateway domain IDs the tenant has wallets on. Phase 1 = [26]
  /// (ARC-TESTNET). Phase 3 adds 1 (AVAX-FUJI). Phase 4 adds 5 (SOL).
  /// See GATEWAY_DOMAINS in @sendero/sendero-circle/src/gateway.ts.
  enabledDomains         Int[]    @default([26])
  /// Sweep policy for inbound USDC. Null = always sweep 100% (Phase 1
  /// default — Arc gas is cheap). Phase 3 widens to support thresholds:
  /// `{ "mode": "always" }` or `{ "mode": "threshold", "minMicroUsdc": 50000000 }`.
  sweepPolicy            Json?
  createdAt              DateTime @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_gateway_configs")
}

/// One row per inbound USDC deposit handled by the Gateway auto-sweep
/// loop. Append-only audit trail for the webhook → ops DCW → tenant EOA
/// → Gateway path.
///
/// Idempotency: `webhookEventId` is unique. Circle fires CONFIRMED +
/// COMPLETED for the same `notification.id` — both arrivals resolve to
/// the same row, second one no-ops at the DB layer.
model GatewayDepositLog {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String
  chain           String
  /// Circle Gateway domain ID — matches GATEWAY_DOMAINS in
  /// @sendero/sendero-circle/src/gateway.ts.
  domain          Int
  /// USDC amount in micro-USDC (6 decimals). 1_000_000 = 1 USDC.
  amountMicroUsdc BigInt
  /// On-chain tx hash for the deposit step (ops DCW → Gateway). Null
  /// while pending; populated once Circle confirms the sweep tx.
  depositTxHash   String?
  /// Optional approve tx hash (pre-deposit ERC-20 approval).
  approveTxHash   String?
  /// pending | confirmed | failed
  status          String    @default("pending")
  retryCount      Int       @default(0)
  /// Circle webhook notification.id — unique so dual CONFIRMED/COMPLETED
  /// fires + at-least-once retries collapse to one row.
  webhookEventId  String?   @unique
  /// auto (webhook) | manual (UI) | cron (reaper)
  triggeredBy     String    @default("auto")
  errorMessage    String?
  confirmedAt     DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, chain, status])
  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@map("gateway_deposit_logs")
}

/// One row per outbound Gateway burn-mint transfer.
///
/// Lifecycle: `attesting` (signed burn submitted) → `minting` (Circle
/// attestation received, gatewayMint pending) → `confirmed` (mint tx
/// confirmed) | `failed`.
///
/// Reconciled by `/api/cron/reconcile-gateway-transfers` (Phase 5) when
/// stuck > 5 minutes. Per-row admin reconcile via
/// `POST /api/gateway/transfer/[logId]/reconcile`.
model GatewayTransferLog {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String
  /// Source domain — null for unified-balance transfers (Gateway picks
  /// across the depositor's enabled domains).
  sourceDomain            Int?
  destinationDomain       Int
  destinationChain        String
  /// USDC amount in micro-USDC.
  amountMicroUsdc         BigInt
  recipientAddress        String
  /// EIP-712 burn intent signature from the tenant Gateway EOA.
  burnSignature           String?
  /// Circle attestation payload returned by `/v1/transfer`.
  attestation             String?
  /// Circle's transfer id (used for `/v1/transfer/{id}` status polls).
  circleTransferId        String?   @unique
  /// On-chain mint tx hash on the destination chain (self-mint path).
  mintTxHash              String?
  /// Circle's destination tx hash when Circle forwarding handles the mint.
  circleDestinationTxHash String?
  /// True = Circle forwarding mints (default for EVM destinations).
  /// False = Sendero self-mints (Solana destinations, Phase 4).
  forwardingEnabled       Boolean   @default(true)
  forwardingFailureReason String?
  /// Total fees in micro-USDC (forwarding + gas).
  feesTotalMicroUsdc      BigInt?
  feesForwardingMicroUsdc BigInt?
  /// Per-burn-intent fee breakdown (Json — Circle returns an array).
  feesPerIntent           Json?
  /// attesting | minting | confirmed | failed
  status                  String    @default("attesting")
  lastReconciledAt        DateTime? @db.Timestamptz(6)
  initiatedByUserId       String?
  /// internal_transfer | payroll | invoice | manual | settle_split
  triggeredBy             String
  errorMessage            String?
  createdAt               DateTime  @default(now()) @db.Timestamptz(6)
  confirmedAt             DateTime? @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@map("gateway_transfer_logs")
}

/// Append-only audit trail of every Gateway-signer key-material access.
///
/// Phase 5. Required for compliance + forensics — answers "which user,
/// from which surface, decrypted tenant X's signer at time T?" Critical
/// for investigating any leak suspicion. Cache hits do NOT log because
/// they don't decrypt; only cold-path decrypts (cache miss) record here.
///
/// Surfaces include:
///   - 'route'   — operator UI request (Clerk session)
///   - 'cron'    — scheduled job (CRON_SECRET)
///   - 'webhook' — Circle inbound webhook fan-out
///   - 'tool'    — agent tool call via /api/agent/dispatch
///   - 'cli'     — out-of-band script (e.g. provisioning, reconciliation)
///
/// Failure mode: if an audit insert fails, the decrypt still proceeds —
/// availability beats audit completeness for the hot path. The DB row
/// is best-effort; production parity with audit comes from the
/// app-level "must-log-or-fail" mode (set via env in Phase 5+ if
/// compliance demands it).
model WalletAccessLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String
  /// route | cron | webhook | tool | cli
  callerSurface String
  /// Clerk userId when callerSurface='route'. Null for cron/webhook
  /// (system-driven). 'tool' callers may have it from the dispatch
  /// path; cli callers don't.
  callerUserId  String?
  /// KEK version used to decrypt. Surfaces rotation lag — a row with
  /// kekVersion < TenantGatewaySigner.kekVersion means the lazy
  /// re-encrypt-on-read step ran on this access.
  kekVersion    Int
  /// Free-form context. Examples: route path, cron name, webhook
  /// notification.id. Bounded to ~200 chars to keep table small.
  context       String?
  occurredAt    DateTime @default(now()) @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
  @@index([occurredAt])
  @@map("wallet_access_logs")
}

/// Append-only nanopayment ledger. Mirrors packages/tools/src/meter.ts
/// MeterEvent but durable. NEVER update or delete rows — audit trail.
model MeterEvent {
  id             String      @id @default(uuid()) @db.Uuid
  at             DateTime    @default(now()) @db.Timestamptz(6)
  tenantId       String?
  userId         String?
  payerAddress   String? // on-chain payer (x402)
  toolName       String
  /// USDC price charged, in micro-USDC (atomic). e.g. 5000 = $0.005.
  priceMicroUsdc BigInt
  status         MeterStatus
  settlementRef  String? // Gateway transfer id or tx hash
  note           String?
  metadata       Json?
  /// Idempotency key — unique per (tenantId, key). Duplicate writes
  /// from retried webhook deliveries no-op at the DB layer.
  idempotencyKey String?
  invoiceRef     String?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, at])
  @@index([userId, at])
  @@index([toolName, at])
  @@index([status, at])
  @@index([tenantId, status, invoiceRef])
  @@map("meter_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// SETTLEMENT (on-chain fan-out)
// ─────────────────────────────────────────────────────────────────────────────

/// One on-chain settlement per Booking (ERC-8183 fan-out). Append-only.
model Settlement {
  id                   String           @id @default(cuid())
  tenantId             String
  tripId               String?
  bookingId            String?
  /// Gross USDC amount distributed, in micro-USDC.
  grossMicroUsdc       BigInt
  /// Denormalized from Booking.costMicroUsdc for fast reconciliation
  /// against the on-chain supplier-leg transfer. Null on legacy rows.
  costMicroUsdc        BigInt?
  /// Sum of legs where kind='agency'. Denormalized for tenant GMV.
  tenantTakeMicroUsdc  BigInt?
  /// Sum of legs where kind='fee'. Denormalized for Sendero revenue.
  senderoTakeMicroUsdc BigInt?
  /// Human-readable status reason — e.g., 'pending_treasury' when the
  /// agency leg is held because tenant.circleWallet.address is null
  /// (Eng A1). Surfaces verbatim in the tenant dashboard.
  statusReason         String?
  chain                String // "arc-testnet", "arc-mainnet", "base", etc.
  chainId              Int?
  status               SettlementStatus @default(pending)
  txHashes             String[]         @default([])
  initiatedAt          DateTime         @default(now()) @db.Timestamptz(6)
  confirmedAt          DateTime?        @db.Timestamptz(6)
  metadata             Json?
  createdAt            DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime         @updatedAt @db.Timestamptz(6)

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  trip    Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  legs SettlementLeg[]

  @@index([tenantId, createdAt])
  @@index([bookingId])
  @@index([tripId])
  @@index([status])
  @@map("settlements")
}

/// One payout leg of a Settlement (supplier, agency, rail, validator, ...).
model SettlementLeg {
  id              String            @id @default(uuid()) @db.Uuid
  settlementId    String
  kind            SettlementLegKind
  toAddress       String
  amountMicroUsdc BigInt
  txHash          String?
  index           Int               @default(0)
  note            String?
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId, index])
  @@index([toAddress])
  @@map("settlement_legs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTESTATION (ERC-8004)
// ─────────────────────────────────────────────────────────────────────────────

/// ERC-8004 reputation write. Append-only.
model Attestation {
  id               String   @id @default(cuid())
  tenantId         String
  tripId           String?
  agentId          String // ERC-8004 agent identifier
  validatorAddress String
  stars            Int // 1-5
  txHash           String?
  chain            String?
  at               DateTime @default(now()) @db.Timestamptz(6)
  metadata         Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  trip   Trip?  @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([tripId])
  @@index([agentId])
  @@map("attestations")
}

// ─────────────────────────────────────────────────────────────────────────────
// SESSION (agent thread resume — optional)
// ─────────────────────────────────────────────────────────────────────────────

/// Clerk session → workflow thread context. Lets the agent resume an
/// interrupted turn (e.g. OTP, 3DS, approval gate).
model Session {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String?
  tripId         String?
  clerkSessionId String?
  /// Channel-agnostic subject key (WA BSUID, Slack (ent:team:user), web userId,
  /// MCP actor id). Lets runAgentTurn look up an ambient conversation session
  /// across channels without rebuilding context each turn.
  subjectKey     String?
  threadContext  Json? // in-flight tool call, pending approvals, turns log
  expiresAt      DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  trip   Trip?  @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@unique([tenantId, subjectKey])
  @@index([tenantId, createdAt])
  @@index([tripId])
  @@index([clerkSessionId])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTELLIGENCE — agent memory + preference learning (Phase 2)
// ─────────────────────────────────────────────────────────────────────────────

/// Agent memory store — per-tenant, per-subject. Phase 1 retrieval is
/// trigram-based keyword match; Phase 2 will add pgvector embeddings.
/// Append-only in practice, but lastAccessedAt/accessCount are mutable.
model AgentMemory {
  id             String     @id @default(uuid()) @db.Uuid
  tenantId       String
  /// Traveler / trip / user id this memory attaches to.
  subjectId      String
  /// Agent that created it ("sendero", "sendero:booking", "sendero:support").
  agentId        String     @default("sendero")
  kind           MemoryKind
  /// One-liner the agent reads. ≤ 240 chars.
  summary        String     @db.VarChar(240)
  /// Optional longer free-text. Indexed by trigram in Phase 2 migration.
  body           String?
  metadata       Json?
  createdAt      DateTime   @default(now()) @db.Timestamptz(6)
  lastAccessedAt DateTime?  @db.Timestamptz(6)
  accessCount    Int        @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, subjectId, kind])
  @@index([tenantId, agentId, createdAt])
  @@map("agent_memories")
}

/// Raw preference decision log. Aggregated into PreferencePattern by
/// @sendero/intelligence at recall time; not materialized server-side to
/// keep the hot path simple in Phase 2.
model PreferenceLog {
  id        String             @id @default(uuid()) @db.Uuid
  tenantId  String
  subjectId String
  category  PreferenceCategory
  /// "window", "premium_economy", "BA", "16:00-21:00"
  key       String
  signal    PreferenceSignal
  amountUsd Decimal?           @db.Decimal(12, 2)
  context   Json?
  createdAt DateTime           @default(now()) @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, subjectId, category])
  @@index([tenantId, createdAt])
  @@map("preference_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CHANNELS — WhatsApp / Slack installations + per-tenant identity mapping
// ─────────────────────────────────────────────────────────────────────────────

/// Binds a channel user (WhatsApp phone/BSUID, Slack user) to a Sendero
/// User within a Tenant. BSUID is the preferred primary key on WhatsApp
/// post-April-2026; phone is nullable to match the Meta rollout.
model ChannelIdentity {
  id                         String      @id @default(uuid()) @db.Uuid
  tenantId                   String
  userId                     String?
  kind                       ChannelKind
  /// For WhatsApp: E.164 phone (nullable — BSUID-only is possible).
  /// For Slack: member id on the workspace.
  externalUserId             String?
  /// WhatsApp only — primary identity key post-BSUID rollout.
  businessScopedUserId       String?
  parentBusinessScopedUserId String?
  username                   String?
  /// Arbitrary per-channel metadata (display name, timezone, locale hints).
  metadata                   Json?
  createdAt                  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime    @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tenantId, kind, businessScopedUserId])
  @@unique([tenantId, kind, externalUserId])
  @@index([tenantId, kind])
  @@index([userId])
  @@map("channel_identities")
}

/// Persisted Slack OAuth install. Keyed on (enterpriseId, teamId) so
/// Enterprise Grid installs spanning multiple workspaces resolve to one
/// install. `enterpriseId` is nullable for classic (non-Grid) installs.
model SlackInstall {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String
  /// Nullable for classic installs; required for Grid.
  enterpriseId        String?
  enterpriseName      String?
  teamId              String
  teamName            String
  appId               String
  botUserId           String
  /// Encrypt-at-rest in production. Plaintext acceptable on testnet demo.
  botToken            String
  scope               String
  isEnterpriseInstall Boolean   @default(false)
  authedUserId        String
  installedAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)
  /// Set when Slack delivers `tokens_revoked` or `app_uninstalled` for
  /// this install. Non-null means the bot token is dead — keep the
  /// row for audit trail (meter_events.userId references survive) but
  /// every webhook handler must treat the install as gone.
  revokedAt           DateTime? @map("revoked_at") @db.Timestamptz(6)
  raw                 Json?
  /// Channel routing config from the Slack setup wizard:
  /// { defaultChannel, routes: [{ eventClass, channel, mode }] }.
  /// Read by the channel-event dispatcher + agent persona to decide where
  /// to post each Sendero event class (trip events, settlements, cap
  /// warnings, escalations, silent).
  /// Backed by `migrations/20260424_slack_routing/migration.sql`.
  routing             Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, teamId])
  @@index([tenantId])
  @@index([revokedAt])
  @@map("slack_installs")
}

/// Maps a Slack member to their Sendero User. Cached so we don't call
/// `slack.users.info` on every webhook. One row per (tenantId, slackTeamId,
/// slackUserId). Refreshed when the Slack user's email changes (rare).
///
/// Used by the Slack webhook routes (`apps/app/lib/slack-user-mapping.ts`)
/// to resolve `meter_events.userId` to the Slack user who actually
/// triggered the agent turn — instead of the workspace admin who
/// installed the bot. Critical for per-user spend caps + analytics.
model SlackUserBinding {
  id            String   @id @default(cuid())
  tenantId      String
  slackTeamId   String // Slack workspace, e.g. T08X5JKLM
  slackUserId   String // Slack member, e.g. U09H4WXZ7
  senderoUserId String // links to User.id within this tenant
  email         String? // last seen Slack email; informational
  resolvedAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [senderoUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slackTeamId, slackUserId])
  @@index([tenantId])
  @@index([senderoUserId])
  @@map("slack_user_bindings")
}

/// Short-lived token bridging a web-signed-in user to a WhatsApp number.
/// User messages the token to the Sendero WA bot; the webhook consumes
/// the token and writes a ChannelIdentity row.
model WhatsAppLinkToken {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String
  userId     String
  token      String    @unique
  expiresAt  DateTime  @db.Timestamptz(6)
  consumedAt DateTime? @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([expiresAt])
  @@map("whatsapp_link_tokens")
}

/// Single-use magic link bridging an off-app traveler (agency / B2C with no
/// Clerk session) to a hosted payment page at `/pay/[bookingId]`. Issued
/// when an operator pre-funds + invites the traveler; consumed when the
/// traveler taps the link and confirms the spend. Distinct from
/// WhatsAppLinkToken (which links a signed-in user to a WA number) — the
/// pay token authorises a one-shot spend on a specific booking.
model BookingPayToken {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String
  bookingId  String
  /// 32 random bytes hex (64 chars). Stored bare — `@unique` is the lookup
  /// key. Treated as a bearer credential; rotate on any leak.
  token      String    @unique
  expiresAt  DateTime  @db.Timestamptz(6)
  consumedAt DateTime? @db.Timestamptz(6)
  /// TransferAttempt the consumption created (null until consumption).
  attemptId  String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tenantId, bookingId])
  @@index([expiresAt])
  @@map("booking_pay_tokens")
}

/// Per-tenant WhatsApp Business install, mediated by Kapso.
///
/// Created once the tenant admin completes the embedded signup flow
/// (see `@sendero/kapso` setup-link). Kapso fires
/// `whatsapp.phone_number.created` to our project-scope webhook, the
/// handler resolves the customer back to the Sendero tenant (via
/// `kapsoCustomerId` external-id mapping) and inserts this row.
///
/// One install per tenant for v1. Multi-install is tracked in the v1
/// deferred list. Re-onboarding overwrites the row with a new
/// `kapsoConnectionId`.
model WhatsAppInstall {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @unique
  /// Kapso's customer id (scoped to Sendero's Kapso project). Used for
  /// setup-link re-issue and health pings.
  kapsoCustomerId     String    @unique
  /// Kapso's internal connection id for the WhatsApp number. Distinct
  /// from Meta's `phone_number_id` — Kapso exposes both.
  kapsoConnectionId   String?   @unique
  businessDisplayName String?
  /// Meta Graph API id — used for outbound sends + webhook routing.
  phoneNumberId       String?   @unique
  /// Meta WABA id — used when creating / submitting templates.
  businessAccountId   String?
  displayPhoneNumber  String?
  /// Per-install webhook secret, Kapso-issued on registration. Stored
  /// plaintext pending `@sendero/crypto` — see v1 deferred list.
  webhookSecret       String
  status              String    @default("pending") // pending | active | disabled | error
  /// Last `status: error` cause, for ops surface debugging.
  lastErrorMessage    String?
  connectedByUserId   String?
  /// Last time the cron health ping succeeded.
  lastHealthyAt       DateTime? @db.Timestamptz(6)
  metadata            Json?
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([phoneNumberId])
  @@map("whatsapp_installs")
}

/// Audit row for every WhatsApp webhook delivery.
///
/// Closes the operator visibility gap: when a customer says "I sent a
/// message and the bot didn't respond," ops looks up by wamid (or
/// timestamp) and sees the verify outcome, replay-window decision,
/// dedup decision, and how many normalized messages were dispatched.
/// Inserted fire-and-forget after the 200 ack so it never blocks
/// Slack/Meta's retry-on-non-200 logic.
model WhatsAppWebhookEvent {
  id                    String   @id @default(cuid())
  tenantId              String?  @map("tenant_id")
  receivedAt            DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  signatureValid        Boolean  @map("signature_valid")
  replayWindowOk        Boolean? @map("replay_window_ok")
  payloadHash           String   @map("payload_hash")
  messageCount          Int      @default(0) @map("message_count")
  identityChangeCount   Int      @default(0) @map("identity_change_count")
  statusUpdateCount     Int      @default(0) @map("status_update_count")
  droppedReplayCount    Int      @default(0) @map("dropped_replay_count")
  droppedDuplicateCount Int      @default(0) @map("dropped_duplicate_count")
  dispatchedCount       Int      @default(0) @map("dispatched_count")
  durationMs            Int?     @map("duration_ms")
  traceId               String?  @map("trace_id")
  /// Optional raw envelope — null in production unless the tenant
  /// opts in via `WhatsAppInstall.metadata.auditRawPayloads`.
  rawEnvelope           Json?    @map("raw_envelope")

  @@index([tenantId, receivedAt(sort: Desc)])
  @@index([traceId])
  @@map("whatsapp_webhook_events")
}

/// Audit row for every external API call we make to Kapso or Meta.
///
/// Closes the last gap in Bucket 5 (observability): operators want to
/// know not just "did the inbound webhook arrive" but also "are our
/// outbound calls succeeding". Failed Kapso health pings, slow Meta
/// template publishes, 429-throttled sends — all show up here with
/// duration + status_code + endpoint shape so ops can grep the whole
/// outbound surface from one table.
///
/// `tenantId` is nullable: install-time setup links happen before a
/// tenant binding exists. Endpoint paths are normalized
/// (`/customers/{id}/setup_links`) so the same shape aggregates
/// cleanly without exploding row count per id.
model WhatsAppApiLog {
  id           String   @id @default(cuid())
  tenantId     String?  @map("tenant_id")
  calledAt     DateTime @default(now()) @map("called_at") @db.Timestamptz(6)
  /// 'kapso' | 'meta' — extend as new outbound surfaces land.
  target       String
  method       String
  /// Endpoint shape with path params replaced (`/messages`,
  /// `/customers/{id}/setup_links`). Static prefix so groupings work.
  endpoint     String
  /// 0 when the request never completed (DNS / network / timeout).
  statusCode   Int      @map("status_code")
  durationMs   Int      @map("duration_ms")
  ok           Boolean
  errorMessage String?  @map("error_message")
  traceId      String?  @map("trace_id")

  @@index([tenantId, calledAt(sort: Desc)])
  @@index([target, calledAt(sort: Desc)])
  @@map("whatsapp_api_logs")
}

/// Audit row for every WhatsApp outbound send.
///
/// One row per `wamid` (UNIQUE). Inserted at send time; updated by the
/// inbound `messages.statuses` webhook handler (already wired in the
/// route). Source labels separate agent replies from OTP drops from
/// security alerts so ops can answer "did the OTP land?" without
/// grepping handlers.
model WhatsAppOutboundMessage {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  wamid          String    @unique
  phoneNumberId  String    @map("phone_number_id")
  /// E.164 or BSUID, whichever was used at send time.
  recipientId    String    @map("recipient_id")
  /// 'text' | 'template' | 'interactive' | 'image' | 'document' | 'video' | …
  kind           String
  /// 'agent_reply' | 'otp' | 'security_alert' | 'manual' | etc.
  source         String
  templateName   String?   @map("template_name")
  /// Up to 280-char preview (PII-light). For `template` sends, the
  /// template name + first body parameter; for `text`, the body
  /// truncated.
  preview        String?
  sentAt         DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  /// Initialised to `'sent'` at insert. Updated by the inbound status
  /// webhook to `'delivered' | 'read' | 'failed'`.
  deliveryStatus String    @default("sent") @map("delivery_status")
  failureReason  String?   @map("failure_reason")
  deliveredAt    DateTime? @map("delivered_at") @db.Timestamptz(6)
  readAt         DateTime? @map("read_at") @db.Timestamptz(6)
  failedAt       DateTime? @map("failed_at") @db.Timestamptz(6)
  traceId        String?   @map("trace_id")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, sentAt(sort: Desc)])
  @@index([tenantId, deliveryStatus])
  @@index([tenantId, source])
  @@map("whatsapp_outbound_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING — tenant caps + batched nanopayment settlement
// ─────────────────────────────────────────────────────────────────────────────

/// Configurable per-tenant nanopayment spend cap. Enforced by
/// @sendero/billing before a tool call is charged. Absence = no cap.
model TenantSpendCap {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String
  period          CapPeriod @default(daily)
  /// Cap in micro-USDC (e.g. 5_000_000 = $5.00 per day).
  amountMicroUsdc BigInt
  /// Soft cap = alert but don't block. Hard cap rejects further calls.
  hardCap         Boolean   @default(true)
  /// Webhook target for cap breach notifications.
  alertWebhookUrl String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("tenant_spend_caps")
}

/// Composable policy guard rows for `@sendero/transfer-policy`. One row =
/// one guard. Compose multiple rows into a `PolicyChain` at runtime via
/// `apps/app/lib/transfer-policy/load.ts::loadPolicyChain()`.
///
///   guardKind   config shape
///   ─────────   ────────────────────────────────────────────────────────
///   budget      { period: 'daily' | 'weekly' | 'monthly',
///                 capMicroUsdc: string }   // bigint stored as string
///   single_tx   { maxMicroUsdc: string }
///   recipient   { mode: 'allow' | 'deny', addresses: string[] }
///   rate_limit  { maxCount: number, windowMs: number }
///   confirm     { triggerAtMicroUsdc?: string, reason?: string }
model TransferPolicy {
  id              String   @id @default(cuid())
  tenantId        String
  scope           String
  travelerId      String?
  toolName        String?
  guardKind       String
  config          Json
  hardCap         Boolean  @default(true)
  alertWebhookUrl String?
  enabled         Boolean  @default(true)
  priority        Int      @default(100)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  traveler User?  @relation("TravelerPolicies", fields: [travelerId], references: [id], onDelete: Cascade)

  @@index([tenantId, scope, enabled])
  @@index([tenantId, travelerId, enabled])
  @@index([tenantId, toolName, enabled])
  @@map("transfer_policies")
}

/// Per-attempt log for every Unified Balance Kit / DCW outbound spend.
/// Written by `/api/transfer/spend` at every branch — passed, blocked,
/// pending, executed, failed — so dashboards and budget guards have a
/// single source of truth for what the chain has been doing.
///
///   passed   — chain allowed; kit call hasn't returned yet (transient).
///   executed — kit.unifiedBalance.spend() succeeded, txHash set.
///   blocked  — chain hard-rejected, no money moved.
///   pending  — chain returned requiresApproval; awaiting operator click.
///   failed   — kit call returned an error mid-execution.
///
/// Budget guards read this table alongside `MeterEvent` so DCW transfers
/// count against the same windows that x402 charges do.
model TransferAttempt {
  id                String   @id @default(cuid())
  tenantId          String
  travelerId        String?
  /// Spend ('spend') vs tenant pre-fund deposit ('deposit'). Spends
  /// originate from the traveler's DCW; deposits originate from the
  /// tenant treasury and credit the traveler's unified balance via
  /// `kit.depositFor`. Defaults to 'spend' for backwards compat.
  kind              String   @default("spend")
  amountMicroUsdc   BigInt
  /// Destination address (0x… EVM, sol… Solana, etc.).
  recipient         String
  /// App Kit chain name (e.g. "Arc_Testnet", "Base_Sepolia").
  destinationChain  String
  /// Source-chain breakdown when explicit allocations were used; null
  /// for App-Kit-automatic-routing.
  sourceAllocations Json?
  status            String   @default("passed")
  /// Returned by kit.unifiedBalance.spend() on success.
  txHash            String?
  /// Reason populated when status = blocked / pending / failed.
  blockReason       String?
  /// Trimmed PolicyChainResult.trace[] for audit / dashboard display.
  policyTrace       Json?
  /// Free-form metadata (App Kit fee breakdown, agent DID, etc.).
  metadata          Json?
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  traveler User?  @relation("TravelerTransferAttempts", fields: [travelerId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, travelerId, createdAt])
  @@index([tenantId, kind, createdAt])
  /// Partial UNIQUE index on (tenantId, metadata->>'bookingId') WHERE
  /// status IN (pending, passed, executed) — closes the settle-action
  /// TOCTOU race so a booking can only have one in-flight / settled
  /// attempt. Lives in
  /// `migrations/20260428_transfer_attempt_booking_idempotency/migration.sql`
  /// because Prisma can't express partial indexes natively.
  @@map("transfer_attempts")
}

/// Generic webhook dedupe ledger. Every inbound webhook (Duffel, Slack,
/// WhatsApp, Stripe, ...) writes one row keyed by provider + externalId
/// so retries are idempotent. Processed rows carry `processedAt`.
model WebhookEvent {
  id              String    @id @default(uuid()) @db.Uuid
  receivedAt      DateTime  @default(now()) @db.Timestamptz(6)
  processedAt     DateTime? @db.Timestamptz(6)
  provider        String
  externalId      String
  eventType       String
  payload         Json
  processingError String?

  @@unique([provider, externalId])
  @@index([provider, processedAt])
  @@map("webhook_events")
}

model Invoice {
  id       String        @id @default(cuid())
  tenantId String
  kind     InvoiceKind
  status   InvoiceStatus @default(draft)

  number   String
  issuedAt DateTime? @db.Timestamptz(6)
  dueAt    DateTime? @db.Timestamptz(6)
  paidAt   DateTime? @db.Timestamptz(6)

  fromName    String
  fromAddress Json?
  fromTaxId   String?
  fromLogoUrl String?

  toName    String
  toEmail   String
  toAddress Json?
  toTaxId   String?

  currency       String  @default("USD") @db.Char(3)
  subtotalMicro  BigInt  @default(0)
  discountMicro  BigInt  @default(0)
  taxRate        Decimal @default(0) @db.Decimal(7, 4)
  taxAmountMicro BigInt  @default(0)
  vatRate        Decimal @default(0) @db.Decimal(7, 4)
  vatAmountMicro BigInt  @default(0)
  totalMicro     BigInt  @default(0)

  template Json

  bookingId String? @unique

  periodStart DateTime? @db.Timestamptz(6)
  periodEnd   DateTime? @db.Timestamptz(6)

  cfdiRef String?

  pdfBlobUrl    String?
  pdfRenderedAt DateTime? @db.Timestamptz(6)

  publicToken String @unique

  metadata Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking   Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  lineItems InvoiceLineItem[]
  payments  InvoicePayment[]

  @@unique([tenantId, number])
  @@index([tenantId, status, createdAt])
  @@index([kind, periodStart])
  @@map("invoices")
}

model InvoiceLineItem {
  id             String  @id @default(cuid())
  invoiceId      String
  position       Int
  description    String
  quantity       Decimal @default(1) @db.Decimal(12, 4)
  unitPriceMicro BigInt
  amountMicro    BigInt
  sourceKind     String?
  sourceRef      String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, position])
  @@map("invoice_line_items")
}

model InvoicePayment {
  id          String   @id @default(cuid())
  invoiceId   String
  paidAt      DateTime @default(now()) @db.Timestamptz(6)
  amountMicro BigInt
  method      String
  txHash      String?
  reference   String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, paidAt])
  @@map("invoice_payments")
}

model InvoiceSequence {
  tenantId String
  year     Int
  nextSeq  Int    @default(1)

  @@id([tenantId, year])
  @@map("invoice_sequences")
}

/// A batched USDC settlement of many MeterEvents. One on-chain transfer
/// per batch to amortize gas. Append-only once settled.
model NanopayBatch {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String
  status          NanopayBatchStatus @default(pending)
  /// Sum of priceMicroUsdc across all member events.
  totalMicroUsdc  BigInt
  eventCount      Int
  /// ISO 8601 window start (inclusive).
  windowStartedAt DateTime           @db.Timestamptz(6)
  /// ISO 8601 window end (exclusive).
  windowEndedAt   DateTime           @db.Timestamptz(6)
  /// On-chain settlement reference once the batch ships.
  txHash          String?
  chain           String?            @default("arc-testnet")
  settledAt       DateTime?          @db.Timestamptz(6)
  error           String?
  retryCount      Int                @default(0)
  lastError       String?
  createdAt       DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, windowStartedAt])
  @@index([status, windowEndedAt])
  @@map("nanopay_batches")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRIP COMPANION (Phase 11f) — audit + cache tables
// Thin, per-trip audit rows. Duffel stays canonical for orders / cancellations
// / credits; workflow runs stay canonical for state transitions. These tables
// exist so analytics + finance UI don't have to parse the Trip.events blob
// or replay workflow runs to answer "what did the traveler choose" or "what
// nudges fired when".
// ─────────────────────────────────────────────────────────────────────────────

/// Per-offer ancillary picker result. One row per pick-then-book round,
/// keyed by Duffel offerId. Becomes the source for invoice line items
/// once the order is ticketed.
model AncillarySelection {
  id            String    @id @default(cuid())
  tenantId      String
  tripId        String?
  userId        String? // traveler who made the selection
  offerId       String // Duffel off_…
  bookingId     String? // Booking.id once booked
  workflowRunId String?
  /// Array of { service_id, quantity, segment_ids?, type, total_amount, total_currency }.
  services      Json
  /// Running total at pick time — useful for diff when Duffel re-prices.
  totalAmount   Decimal?  @db.Decimal(12, 2)
  totalCurrency String?   @db.Char(3)
  bookedAt      DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, createdAt])
  @@index([offerId])
  @@index([bookingId])
  @@map("ancillary_selections")
}

/// One disruption-recovery run per triggering event (delay, cancellation,
/// schedule change). Tracks source and resolution independent of the
/// workflow run so finance can scan "how many disruptions this quarter"
/// without touching the runner.
model DisruptionRun {
  id            String    @id @default(cuid())
  tenantId      String
  tripId        String
  bookingId     String? // the disrupted booking
  /// delay | cancellation | schedule_changed
  kind          String
  /// traveler | webhook | agent | ops
  source        String
  workflowRunId String?
  /// open | awaiting_decision | rebooking | refunding | resolved | failed
  status        String    @default("open")
  /// Final decision blob: { choice, fareDeltaUsd, refundUsd, newBookingId, tx? }
  resolution    Json?
  resolvedAt    DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, createdAt])
  @@index([tenantId, status])
  @@index([bookingId])
  @@map("disruption_runs")
}

/// Scheduled + fired check-in nudges. One row per (trip, scheduled slot).
/// Cron queries `scheduledAt < now AND firedAt IS NULL` for catch-up.
model CheckInNudge {
  id          String    @id @default(cuid())
  tenantId    String
  tripId      String
  bookingId   String?
  /// T-24h (or other window) — absolute UTC.
  scheduledAt DateTime  @db.Timestamptz(6)
  firedAt     DateTime? @db.Timestamptz(6)
  actionedAt  DateTime? @db.Timestamptz(6)
  /// whatsapp | slack | email | web
  channel     String
  /// ISO8601 of the latest safe departure from origin to reach the gate.
  leaveByIso  String?
  /// Free-form snapshot: countdown, transit minutes, gate id, etc.
  metadata    Json?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, scheduledAt])
  @@index([scheduledAt, firedAt])
  @@map("check_in_nudges")
}

/// Composed travel-safety brief output. Per-provider outputs kept inline
/// so the UI can re-render without re-calling providers (each is metered).
model SafetyBrief {
  id            String   @id @default(cuid())
  tenantId      String
  tripId        String?
  userId        String?
  /// { name, iata?, lat, lng } — enough to re-key a cache lookup.
  destination   Json
  workflowRunId String?
  weather       Json?
  airQuality    Json?
  timezone      Json?
  elevation     Json?
  travelSafety  Json?
  /// low | moderate | high | extreme
  riskLevel     String   @default("low")
  computedAt    DateTime @default(now()) @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, computedAt])
  @@index([tenantId, riskLevel])
  @@map("safety_briefs")
}

/// One arrival-playbook invocation per trip/airport combo. Stores the
/// fully composed share payload so the web view can re-render the same
/// playbook the traveler saw on WA.
model ArrivalPlaybookRun {
  id               String    @id @default(cuid())
  tenantId         String
  tripId           String
  bookingId        String? // arrival flight booking
  airportIata      String    @db.Char(3)
  transferOptionId String? // airport_transfer_coordinator result ref
  /// Restaurant + POI ids that made it into the playbook.
  restaurantIds    Json      @default("[]")
  /// Static map CID/URL for channel-safe rendering.
  routeMapCid      String?
  /// Full composed share payload — bullets, CTAs, slackMrkdwn, whatsappUrl.
  playbook         Json
  workflowRunId    String?
  actionedAt       DateTime? @db.Timestamptz(6) // traveler tapped a step
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, createdAt])
  @@index([bookingId])
  @@map("arrival_playbook_runs")
}

/// Duffel Travel Support Assistant (or in-app support) turn log.
/// Exists primarily for finance (TSA calls are metered) and QA
/// (outcome distribution per tenant).
model SupportTurn {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?
  tripId          String?
  bookingId       String?
  /// Duffel's internal id if exposed; otherwise null.
  duffelSupportId String?
  /// Short-form summary of what the traveler asked.
  turnSummary     String
  /// answered | escalated | unresolved | deflected
  outcome         String
  /// MeterEvent.id — TSA turns are nanopaid.
  nanopayEventId  String?
  /// Redacted request/response blob (PII-stripped).
  rawIo           Json?
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId, createdAt])
  @@index([tenantId, outcome])
  @@index([userId])
  @@map("support_turns")
}

// ─────────────────────────────────────────────────────────────────────────────
// TREASURY MULTISIG (phase 11g)
// ─────────────────────────────────────────────────────────────────────────────

/// Pending weighted-multisig operation — a proposed userOp awaiting signature
/// collection on a treasury MSCA. Signatures accumulate in the `signatures`
/// JSON until `collectedWeight` >= `threshold`, at which point the op
/// transitions from `pending` → `threshold_met` and can be submitted to the
/// bundler. Terminal states: `submitted`, `confirmed`, `expired`, `cancelled`.
///
/// Ported from desk-v1 (pending_multisig_ops) and adapted for Sendero's
/// tenant-scoped model. Initiator tracking lives in `initiatedByClerkUserId`
/// (Clerk user id) so we avoid cross-database foreign keys.
///
/// TODO(v1): cross-chain children — desk-v1 adds a `pending_multisig_op_children`
/// table for cross-chain fan-out (one parent op → one child op per blockchain).
/// Sendero ships the single-chain parent case first; children will land with
/// the Gateway integration phase.
model PendingMultisigOp {
  id                     String    @id @default(cuid())
  tenantId               String
  /// MSCA wallet id (CircleWallet.id) this op targets.
  walletId               String
  /// UserOp hash (0x…) from EntryPoint v0.7 — unique per chain + nonce.
  opHash                 String    @unique
  /// Full packed UserOperation struct (sender, nonce, gas fields, etc.).
  userOp                 Json
  /// Encoded `execute` / `executeBatch` call data — redundant with userOp.callData
  /// but indexed separately so we can search by target contract without parsing.
  callData               String
  /// Optional per-op metadata (transfer summary, recipient, amount, tokenSymbol).
  transferMeta           Json      @default("{}")
  /// Weight required for execution (sum of signer weights).
  threshold              Int
  /// Sum of weights contributed so far across the `signatures` array.
  collectedWeight        Int       @default(0)
  /// Array of { signerAddress, signature, weight, sigType, signedAt } entries.
  signatures             Json      @default("[]")
  /// Lifecycle: pending | threshold_met | submitted | confirmed | expired | cancelled.
  status                 String    @default("pending")
  /// Clerk user id of the member who initiated this op.
  initiatedByClerkUserId String
  expiresAt              DateTime  @db.Timestamptz(6)
  submittedAt            DateTime? @db.Timestamptz(6)
  confirmedAt            DateTime? @db.Timestamptz(6)
  /// On-chain transaction hash once the userOp is mined.
  txHash                 String?
  createdAt              DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([opHash])
  @@index([expiresAt])
  @@map("pending_multisig_ops")
}

// ─── Passport Vault (envelope-encrypted) ─────────────────────────────────────
//
// Highly-sensitive traveler identity documents. The full extraction (name,
// passport#, DOB, MRZ lines, place of birth, image hash) lives ONLY in the
// `ciphertext` column — encrypted via pgcrypto pgp_sym_encrypt with a
// per-tenant DEK derived from the env-stored KEK (see @sendero/vault).
//
// The plaintext sibling columns carry ONLY sanitized signals the LLM and
// agent tools are allowed to see:
//   - nationalityIso3         : "USA" — needed for visa-rule lookup
//   - expiresOn               : date  — needed for 6-month-rule check
//   - documentVariant         : passport | national_id | drivers_license | …
//   - mrzChecksumValid        : bool  — trust signal
//   - extractedBy             : mrz_fast | gemini_zdr
//
// Name / DOB / document number / MRZ lines / place of birth / image hash
// NEVER appear in plaintext columns. They only exist inside `ciphertext`,
// decryptable only by:
//   - the traveler themselves via /dashboard/passport (Clerk-auth)
//   - a workflow step running under the `vault:decrypt` service role
// Every decrypt goes through PassportVaultAccessLog (append-only).
//
// Compliance note: this table is INTENTIONALLY not referenced from Trip —
// a vault entry is scoped to (tenantId, userId) and reused across trips.
model PassportVault {
  id       String @id @default(cuid())
  tenantId String
  userId   String

  /// Envelope-encrypted full extraction blob (JSON-encoded IdDocumentExtraction
  /// + image SHA-256 + original filename). Written via pgp_sym_encrypt with
  /// the tenant DEK. Reads go through @sendero/vault decryptEnvelope().
  ciphertext Bytes

  /// AES-GCM nonce / PGP session-key wrapper bytes if we switch off pgp_sym
  /// down the road. Null when using pgp_sym_encrypt (it's self-contained).
  nonce Bytes?

  /// Key version — bumps when we rotate the KEK. @sendero/vault keeps old
  /// DEKs around keyed by this version so we can decrypt + re-wrap on read.
  keyVersion Int @default(1)

  // ── Sanitized signals (plaintext, LLM-safe) ─────────────────────────────

  /// ISO 3166-1 alpha-3 nationality code. Needed for visa-rule lookup.
  /// NOT stored when this would de-facto identify the traveler (e.g. the
  /// only American on a single-tenant agency) — caller decides.
  nationalityIso3 String?

  /// Expiry date. Date only, not datetime, to minimize fingerprint.
  expiresOn DateTime? @db.Date

  /// Document kind. No issuing country here — that's in ciphertext.
  documentVariant String // passport | national_id | drivers_license | residence_permit

  /// Machine-readable zone passed the ICAO 9303 checksum suite.
  mrzChecksumValid Boolean @default(false)

  /// Which extractor produced this row. Audit signal.
  extractedBy String // mrz_fast | gemini_zdr | manual

  extractedAt DateTime @default(now()) @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  /// Revocation flag — when true, the ciphertext is tombstoned. We keep the
  /// row so access logs remain joinable, but decrypt requests fail fast.
  revokedAt DateTime? @db.Timestamptz(6)

  tenant     Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessLogs PassportVaultAccessLog[]

  @@unique([tenantId, userId, documentVariant])
  @@index([tenantId, expiresOn])
  @@index([userId])
  @@map("passport_vault")
}

/// Append-only audit log for every decrypt / read / verify operation on a
/// vault entry. Written from @sendero/vault; never truncated.
model PassportVaultAccessLog {
  id      String @id @default(cuid())
  vaultId String

  /// What the caller did: decrypt | signals_read | verify | revoke | upsert.
  action String

  /// Who asked. For self-service: clerkUserId. For agents: svc:{apiKeyId}.
  /// For workflow: wf:{workflowId}:{stepId}. For humans via operator view:
  /// op:{clerkUserId}.
  actorRef String

  /// Where the call came from — ties back to a route or workflow run.
  source String // api/passport/upload | api/passport/[id]/self | workflow:verify_travel_documents | ...

  /// JSON context (ip, userAgent, tripId, reason). Never contains decrypted
  /// PII — decrypted payloads are consumed then dropped, not logged.
  context Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  vault PassportVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId, createdAt])
  @@index([action, createdAt])
  @@map("passport_vault_access_log")
}

// ─── Trip Eligibility Runs (async visa verification) ─────────────────────────
//
// Per-(trip × traveler) verification job.  Calls out to Sherpa's
// Requirements API (`POST /v3/trips`) in the background so the booking
// UI never halts waiting for an external network round-trip.  Frontend
// subscribes to the run's SSE channel (`pg_notify('trip_eligibility_run:${id}')`)
// and updates the verdict card in place the moment the run transitions
// to `succeeded` or `failed`.
//
// Failure path: when Sherpa is unreachable / returns 5xx, we fall back
// to the curated corridor table in @sendero/vault/visa-rules and mark
// the run `succeeded` with `source = 'fallback'` — the UX is never
// blocked by an external provider outage.
//
// Access pattern:
//   1. startRun(tripId, travelerUserId)   — writes a `pending` row
//   2. background worker calls Sherpa     — writes `running → succeeded | failed`
//   3. finalize emits pg_notify           — SSE updates the frontend
//   4. verdict JSON is consumed & cached on the trip page
//
// The ingested Sherpa response stays in `providerRaw` for audit +
// replay.  We don't expose it to the LLM — the verdict alone is what
// tools and workflows see.
model TripEligibilityRun {
  id         String  @id @default(cuid())
  tenantId   String
  /// Optional — runs can be started for a draft trip not yet persisted
  /// (client-side dry-run on flight search).  Real trip FKs are set
  /// once the trip is created.
  tripId     String?
  travelerId String

  /// State machine: pending → running → (succeeded | failed | skipped).
  /// `skipped` means we short-circuited to the curated-JSON path
  /// because the tenant hasn't enabled Sherpa.
  status String @default("pending")

  /// Which source produced the verdict: 'sherpa' | 'fallback_rules' | 'none'.
  source String?

  /// Opaque identifier Sherpa stamps on the trip object (tri_... slug).
  /// Used to de-duplicate re-runs + correlate webhook callbacks.
  sherpaTripId String?

  /// Origin + destination ISO-3 at the time of the run.  Storing these
  /// lets us re-run without walking the Trip graph.
  originIso3      String
  destinationIso3 String
  departureDate   DateTime  @db.Date
  returnDate      DateTime? @db.Date
  purpose         String    @default("business")

  /// Sanitized verdict JSON — same shape as TravelEligibilityVerdict
  /// from @sendero/vault.  Safe for the LLM; the raw Sherpa body is
  /// kept in `providerRaw` for replay but never exposed.
  verdict Json?

  /// Raw Sherpa response body (when source='sherpa').  Never rendered
  /// in the UI; used for audit replay + regression testing.
  providerRaw Json?

  /// Human-readable failure reason when status='failed'.
  failureReason String?

  /// Triggers: 'flight_search' | 'booking_review' | 'agent_tool' | 'manual'.
  trigger String @default("manual")

  requestedByActor String? // clerkUserId / svc:keyId / wf:id:step

  requestedAt DateTime  @default(now()) @db.Timestamptz(6)
  startedAt   DateTime? @db.Timestamptz(6)
  completedAt DateTime? @db.Timestamptz(6)

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  traveler User   @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@index([tenantId, tripId])
  @@index([travelerId, requestedAt])
  @@index([status, requestedAt])
  @@map("trip_eligibility_runs")
}

// ─────────────────────────────────────────────────────────────────────────────
// NFT STAMPS — souvenir collectibles minted across the trip lifecycle
// ─────────────────────────────────────────────────────────────────────────────

/// One row per stamp class minted into the SenderoStamps ERC-1155
/// contract on Arc-Testnet. The (kind, primaryKey) UNIQUE gives us
/// idempotency at the application layer — Circle's TokenERC1155
/// template assigns sequential tokenIds, so we map (kind, primaryKey)
/// → tokenId here. Refreshable kinds (ItineraryMap) update `uri`
/// in place; everything else is append-only.
model NftStamp {
  id         String    @id @default(cuid())
  tenantId   String
  tripId     String?
  bookingId  String?
  travelerId String?
  /// One of: BoardingPass | SettlementReceipt | ItineraryMap | TripPassport
  kind       String
  /// Domain key for idempotency: bookingId for BoardingPass / Receipt,
  /// tripId for ItineraryMap / TripPassport. Used in the unique pair
  /// with `kind` so a re-attempt finds the existing tokenId rather
  /// than minting a duplicate.
  primaryKey String
  /// On-chain class id assigned by the contract (auto-increment).
  /// Stored as decimal string to fit uint256.
  tokenId    String
  contract   String
  /// Tenant slug copied at mint time so off-chain queries can fan
  /// out by tenant without a join.
  tenantSlug String
  /// IPFS metadata URI (canonical) — the contract's tokenURI value.
  uri        String
  /// Vercel Blob URL for hot UI rendering. Mirrors the manifest's
  /// image_blob field.
  blobUrl    String?
  /// GPT-5-nano caption shown on the stamp page + OG description.
  caption    String?
  /// Free-form: brand snapshot at mint time, source meter event ids,
  /// recipients[] for TripPassport, prior CIDs after refresh.
  metadata   Json?
  mintTxHash String?
  mintTxId   String?
  /// `pending` (workflow started, mint not confirmed) | `minted` |
  /// `failed` (workflow terminal failure) | `refreshed` (URI updated).
  status     String    @default("pending")
  mintedAt   DateTime? @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trip       Trip?               @relation(fields: [tripId], references: [id], onDelete: SetNull)
  booking    Booking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  traveler   User?               @relation("StampTraveler", fields: [travelerId], references: [id], onDelete: SetNull)
  ownerships NftStampOwnership[]

  @@unique([kind, primaryKey])
  @@unique([contract, tokenId])
  @@index([tenantId, mintedAt])
  @@index([travelerId, mintedAt])
  @@index([tripId])
  @@index([status])
  @@map("nft_stamps")
}

/// Per-(stamp, owner) balance rollup driven by Circle Event Monitor
/// notifications (TransferSingle / TransferBatch). Source of truth
/// for the "my stamps" page — read here, not from chain RPC.
/// `ownerAddress` may be a traveler DCW (resolved → User via FK)
/// or any external address (FK stays null).
model NftStampOwnership {
  id           String   @id @default(cuid())
  stampId      String
  ownerAddress String
  /// Optional FK to User when ownerAddress matches a known DCW.
  ownerUserId  String?
  balance      BigInt   @default(0)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)
  /// Last block + tx that moved this balance — for audit / debugging.
  lastTxHash   String?
  lastBlock    BigInt?

  stamp NftStamp @relation(fields: [stampId], references: [id], onDelete: Cascade)
  user  User?    @relation("StampOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@unique([stampId, ownerAddress])
  @@index([ownerAddress])
  @@index([ownerUserId])
  @@map("nft_stamp_ownerships")
}

// ─────────────────────────────────────────────────────────────────────────────
// ERC-8004 ON-CHAIN REPUTATION (identity + reputation + validation)
// ─────────────────────────────────────────────────────────────────────────────

/// ERC-8004 IdentityRegistry agent NFT bound to a Sendero subject.
/// Either the org's treasury wallet (kind='org', tenantId set) or the
/// user's DCW (kind='user', userId set). Provisioning is async-with-
/// retry, mirroring NftStamp.status semantics: `pending` → `minted` |
/// `failed`. The sweeper retries `pending` rows forever; `failed` is
/// terminal and surfaces in the admin UI.
///
/// Cached aggregations (cachedStars / cachedFeedbackCount /
/// cachedValidatorCount / cachedValidationCount / cachedAt) are
/// written by the Circle Event Monitor webhook on every FeedbackGiven
/// / ValidationResponseSubmitted event so reads stay sub-50ms — chain
/// RPC is only the fallback for external counterparties not yet in
/// our index.
model OnchainIdentity {
  id                    String    @id @default(cuid())
  /// 'org' | 'user' — drives FK + holderAddress source resolution.
  kind                  String
  tenantId              String? // populated when kind='org'
  userId                String? // populated when kind='user'
  chainId               Int // 5042002 for ARC-TESTNET
  contract              String // IdentityRegistry address (0x8004A8…)
  /// uint256 token id from IdentityRegistry — decimal string. Null
  /// while pending; populated from the Transfer event in the mint
  /// receipt.
  agentId               String?
  /// EOA/SCA that owns the NFT — copy of CircleWallet.address (org)
  /// or Wallet.address (user). Lower-cased on insert.
  holderAddress         String
  /// Stable URL the contract stores via tokenURI(). Resolves to
  /// `/agents/{kind}/{tenantId|userId}/metadata.json`.
  metadataUri           String
  mintTxHash            String?
  mintTxId              String? // Circle DCW tx id
  mintedAt              DateTime? @db.Timestamptz(6)
  /// 'pending' (mint submitted) | 'minted' (NFT exists on-chain) |
  /// 'failed' (terminal — sweeper gave up).
  status                String    @default("pending")
  /// Denormalized aggregations — written by Circle Event Monitor
  /// webhook for sub-50ms reads. cachedAt is null until first event.
  cachedStars           Float?
  cachedFeedbackCount   Int       @default(0)
  cachedValidatorCount  Int       @default(0)
  cachedValidationCount Int       @default(0)
  cachedAt              DateTime? @db.Timestamptz(6)
  /// Number of provisioning attempts. After N attempts the sweeper
  /// flips status='failed' and stops retrying.
  attemptCount          Int       @default(0)
  lastAttemptAt         DateTime? @db.Timestamptz(6)
  lastError             String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)

  tenant      Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  given       ReputationFeedback[] @relation("Rater")
  received    ReputationFeedback[] @relation("Subject")
  validations ValidationCheck[]

  @@unique([contract, agentId])
  /// App layer enforces "exactly one identity per (kind, subject)"
  /// — Postgres partial-unique on these two pairs.
  @@unique([kind, tenantId])
  @@unique([kind, userId])
  @@index([holderAddress])
  @@index([status])
  @@map("onchain_identities")
}

/// One row per on-chain ReputationRegistry FeedbackGiven event.
/// Indexed by Circle Event Monitor → `/api/webhooks/circle/events`
/// → `handleFeedbackGiven` (idempotent on `txHash`). The on-chain
/// score is int128 0-100; we mirror it and denormalize stars =
/// score / 20 for ORDER BY / AVG queries.
///
/// `tripId` / `bookingId` are audit-trail only (which trip drove
/// this feedback). `fromIdentityId` is null for off-platform raters
/// (external Sendero ecosystem partners) — `fromAddress` is the
/// raw on-chain validator address regardless.
model ReputationFeedback {
  id             String   @id @default(cuid())
  subjectId      String
  fromIdentityId String? // null when rater is off-platform / unresolved
  fromAddress    String
  score          Int // 0-100
  stars          Float // score / 20
  tag            String?
  feedbackHash   String
  uri            String?
  txHash         String   @unique
  blockNumber    BigInt
  tripId         String?
  bookingId      String?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  subject OnchainIdentity  @relation("Subject", fields: [subjectId], references: [id], onDelete: Cascade)
  from    OnchainIdentity? @relation("Rater", fields: [fromIdentityId], references: [id], onDelete: SetNull)
  trip    Trip?            @relation(fields: [tripId], references: [id], onDelete: SetNull)
  booking Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([subjectId, createdAt])
  @@index([fromIdentityId])
  @@index([tripId])
  @@map("reputation_feedback")
}

/// ValidationRegistry request/response pair — KYC, KYB, suitability
/// checks, etc. Two on-chain calls (request + response) reduce to one
/// row keyed on the deterministic `requestHash`. `responseScore` is
/// 100=passed, 0=failed, null=pending.
model ValidationCheck {
  id               String    @id @default(cuid())
  subjectId        String
  validatorAddress String
  requestUri       String
  requestHash      String    @unique
  requestTxHash    String
  responseScore    Int? // 100=passed, 0=failed, null=pending
  responseTxHash   String?
  tag              String?
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  resolvedAt       DateTime? @db.Timestamptz(6)

  subject OnchainIdentity @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@map("validation_checks")
}

/// Per-tenant rules used to gate engagement with counterparties.
/// `enforcement` defaults to 'warn' so launch is non-blocking — admins
/// surface violations in the UI before flipping a tenant to 'block'.
/// Star threshold (`minStars`) only applies once a counterparty has
/// crossed `minTripCount` so first-time travelers aren't accidentally
/// blocked by a no-history zero score.
model ReputationPolicy {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  minStars        Float?
  minTripCount    Int?
  maxDisputeRatio Float?
  requireKyc      Boolean  @default(false)
  requireKyb      Boolean  @default(false)
  /// 'block' | 'warn' | 'allow'.
  enforcement     String   @default("warn")
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("reputation_policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT PRICING POLICY (markup v1)
// ─────────────────────────────────────────────────────────────────────────────

/// Per-tenant markup policy. Versioned + append-only — new edits insert
/// a new row with the next monotonic version. The Booking pins both
/// the version int (human-readable audit) AND the resolved snapshot to
/// metadata.policySnapshot so policy edits do not retro-price open
/// quotes (Eng A3).
///
/// `markupConfig` is a discriminated-union JSON keyed by BookingKind.
/// Validated by `MarkupConfigSchema` (Zod) in `@sendero/billing/markup`
/// AND by a Postgres CHECK that the column is a JSON object — Eng A7
/// defense-in-depth.
model TenantPricingPolicy {
  id                  String   @id @default(cuid())
  tenantId            String
  version             Int
  markupConfig        Json
  /// Floor on tenant markup itself ($1 USDC default). Below this the
  /// agency is not running a business — separate from the Sendero take
  /// floor, which is computed in code per tier.
  floorMicroUsdc      BigInt   @default(1000000)
  /// Self-imposed tenant ceiling (NOT platform policy). Null = no ceiling.
  ceilingMicroUsdc    BigInt?
  /// 'add_to_customer' | 'deduct_from_markup' (DX D7 — self-documenting
  /// replacements for the original 'passthrough' / 'absorb' values).
  senderoTakeBehavior String   @default("add_to_customer")
  /// Activation gate. Quote API rejects writes until true; Clerk webhook
  /// seeds an `activated=true, sandboxOnly=true` row at org.created so
  /// sandbox keys can call confirm_booking immediately (DX D1).
  activated           Boolean  @default(false)
  /// Sandbox-only seed flag. Production keys ignore sandboxOnly rows
  /// and still hit policy_inactive until a human activates a real one.
  sandboxOnly         Boolean  @default(false)
  createdById         String?
  createdAt           DateTime @default(now()) @db.Timestamptz(6)

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("TenantPricingPolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([tenantId, version])
  @@index([tenantId, createdAt])
  @@map("tenant_pricing_policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// OTP DELIVERY (guest-claim)
// ─────────────────────────────────────────────────────────────────────────────

/// Audit trail for guest-claim OTP sends. Per OTP design: never store
/// the OTP preimage. Only records THAT we sent something via channel X
/// at time T, with the on-chain claimCodeHash that was rotated to.
/// providerMessageId lets us reconcile delivery webhooks later.
model OtpDeliveryAttempt {
  id                String   @id @default(cuid())
  tenantId          String
  /// Off-chain Trip.id (cuid). Cross-references onchainTripId for the
  /// on-chain hex32 form because event observers see the latter first.
  tripId            String
  /// On-chain bytes32 trip id, hex-encoded (`0x…`).
  onchainTripId     String
  /// 'whatsapp' | 'email' | 'sms'.
  channel           String
  sentAt            DateTime @default(now()) @db.Timestamptz(6)
  /// 'sent' | 'delivered' | 'failed' | 'rate_limited'.
  deliveryStatus    String
  /// Provider-specific id (Resend message id, Twilio sid, Meta wamid).
  /// Useful for receipt webhook reconciliation. Never PII.
  providerMessageId String?
  /// Non-PII reason — 'invalid_phone', 'no_verified_contact',
  /// 'throttled', etc.
  failureReason     String?
  /// Hex32 of the new claim code hash written on-chain.
  rotatedHash       String
  /// Tx hash of the setClaimCodeHash call. Null until receipt lands.
  rotatedTxHash     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tripId, sentAt])
  @@index([tenantId, sentAt])
  @@map("otp_delivery_attempts")
}

// ─────────────────────────────────────────────────────────────────────────────
// SECURITY ALERTS
// ─────────────────────────────────────────────────────────────────────────────

/// Operator inbox for high-severity security events. Per OTP design:
/// claim_lockout fans out to email + Slack + WhatsApp at < 60s and
/// persists an alert here for the dashboard inbox. tenantId is
/// nullable for the unknown-buyer case (lockout fired against an
/// address we have no Tenant row for — still useful to log for ops
/// triage).
model SecurityAlert {
  id             String    @id @default(cuid())
  tenantId       String?
  /// 'claim_lockout' | 'claim_lockout_unknown_buyer' | future kinds.
  kind           String
  /// 'low' | 'medium' | 'high' | 'critical'.
  severity       String
  /// Hex32 on-chain tripId for trip-related alerts; null for non-trip.
  onchainTripId  String?
  /// Free-form context — addresses, timestamps, deep-link URLs.
  /// NEVER contains PII; the OTP design doc is explicit about this.
  payload        Json
  /// Operator acknowledgement state for the dashboard inbox.
  acknowledgedAt DateTime? @db.Timestamptz(6)
  acknowledgedBy String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([kind, severity, createdAt])
  @@map("security_alerts")
}
