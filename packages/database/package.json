{
  "name": "@sendero/database",
  "version": "0.1.0",
  "private": true,
  "description": "Sendero — Prisma + Neon Postgres data layer. Multi-tenant corporate travel SaaS schema (Tenants, Trips, Bookings, Policies, Suppliers, Wallets, MeterEvents, Settlements, Attestations). Consumed by apps/app, apps/edge, and optionally @sendero/tools.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/index.ts",
    "./types": "./src/types.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "bun run src/seed.ts",
    "db:reset": "prisma migrate reset --force && bun run db:seed",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@neondatabase/serverless": "^0.10.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "prisma": "^5.22.0",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "bun run src/seed.ts"
  }
}
