{
  "name": "@sendero/cli",
  "version": "0.1.0",
  "description": "Sendero CLI — agent-friendly access to the Sendero travel-ops surface. One npx, OAuth-or-key auth, every MCP tool exposed as a structured command.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://sendero.travel",
  "repository": {
    "type": "git",
    "url": "https://github.com/tcxcx/sendero",
    "directory": "packages/cli"
  },
  "bin": {
    "sendero": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --target=node --outdir=dist --format=esm --minify --banner='#!/usr/bin/env node'",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
