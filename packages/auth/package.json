{
  "name": "@sendero/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Sendero — auth layer. Bridges Clerk (tenant / org / role) with Circle Modular Wallets (passkey MSCA) via Prisma-backed 1:1 mapping. Consumed by apps/app (Next.js 15 App Router) and apps/edge (Hono).",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./clerk": "./src/clerk.tsx",
    "./clerk/server": "./src/clerk.server.ts",
    "./msca": "./src/msca.ts",
    "./tenant": "./src/tenant.ts",
    "./middleware": "./src/middleware.ts",
    "./store": "./src/store.ts",
    "./types": "./src/types.ts",
    "./claims": "./src/claims.ts",
    "./dispatch-auth": "./src/dispatch-auth.ts",
    "./roles": "./src/roles.ts",
    "./webhooks": "./src/webhooks.ts",
    "./proxy": "./src/proxy.ts",
    "./clerk-appearance": "./src/clerk-appearance.ts",
    "./components/sign-in": "./src/components/sign-in.tsx",
    "./components/sign-up": "./src/components/sign-up.tsx",
    "./components/clerk-form-skeleton": "./src/components/clerk-form-skeleton.tsx",
    "./components/sso-callback": "./src/components/sso-callback.tsx",
    "./components/org-switcher": "./src/components/org-switcher.tsx",
    "./components/user-button": "./src/components/user-button.tsx",
    "./components/user-details": "./src/components/user-details.tsx"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.3",
    "@clerk/backend": "^3.2.13",
    "svix": "^1.38.0"
  },
  "peerDependencies": {
    "@circle-fin/modular-wallets-core": "^1.0.13",
    "@sendero/database": "*",
    "@sendero/tools": "*",
    "hono": "^4.12.14",
    "next": "^16.2.4",
    "react": "^19.1.0",
    "viem": "^2.21.0",
    "webauthn-p256": "0.0.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@sendero/database": {
      "optional": false
    },
    "hono": {
      "optional": true
    }
  }
}
