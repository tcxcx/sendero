{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@/*": ["./src/*"],
      "@sendero/locale": ["../locale/src/index.ts"],
      "@sendero/locale/*": ["../locale/src/*"],
      "@sendero/ui/cn": ["./src/utils/cn.ts"],
      "@sendero/ui/*": ["./src/components/*.tsx"],
      "@sendero/ui/components": ["./src/components"],
      "@sendero/ui/components/*": ["./src/components/*"],
      "@sendero/ui/hooks": ["./src/hooks"],
      "@sendero/ui/hooks/*": ["./src/hooks/*"]
    }
  },
  "include": ["src/brand/**/*", "src/components/**/*", "src/hooks/**/*", "src/utils/**/*"],
  "exclude": ["src/stories/**/*"]
}
