{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "paths": {
      "@/abis/*": ["./abis/*"]
    }
  },
  "include": ["./*.ts", "./src/**/*.ts", "./abis/**/*.ts"],
  "exclude": ["node_modules"]
}
