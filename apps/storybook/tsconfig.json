{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@app/*": ["../../app/*"],
      "@components/*": ["../../components/*"]
    },
    "types": ["node", "react", "react-dom"]
  },
  "include": [".storybook/**/*.ts", ".storybook/**/*.tsx", "stories/**/*.ts", "stories/**/*.tsx"],
  "exclude": [
    "node_modules",
    "storybook-static",
    "stories/composed/FooterRail.stories.tsx"
  ]
}
