{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@sendero/llms": ["../../packages/llms/src/index.ts"],
      "@sendero/llms/*": ["../../packages/llms/src/*"],
      "@sendero/locale": ["../../packages/locale/src/index.ts"],
      "@sendero/locale/*": ["../../packages/locale/src/*"],
      "@sendero/seo": ["../../packages/seo/src/index.ts"],
      "@sendero/seo/*": ["../../packages/seo/src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
