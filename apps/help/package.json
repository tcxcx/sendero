{
  "name": "@sendero/help",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sendero help center — basehub-backed article catalog with categories, search, and per-locale routing. Scaffold ships with a static fallback so the site renders without BASEHUB_TOKEN.",
  "scripts": {
    "dev": "next dev -p ${HELP_PORT:-3012}",
    "build": "next build",
    "start": "next start -p ${HELP_PORT:-3012}",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sendero/fonts": "workspace:*",
    "@sendero/llms": "workspace:*",
    "@sendero/locale": "workspace:*",
    "@sendero/seo": "workspace:*",
    "@sendero/ui": "workspace:*",
    "next": "^16.2.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-grab": "^0.1.32",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.8.3"
  }
}
