{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bun install",
  "buildCommand": "echo 'no build step — Hono handler'",
  "ignoreCommand": "bash -c '[[ \"$VERCEL_GIT_COMMIT_REF\" == \"main\" || \"$VERCEL_GIT_COMMIT_REF\" == \"development\" ]] && exec npx turbo-ignore @sendero/edge; exit 0'",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/[[...route]].ts": {
      "maxDuration": 60,
      "includeFiles": "packages/tools/src/**"
    }
  }
}
