{
  "name": "@sendero/edge",
  "version": "0.1.0",
  "private": true,
  "description": "Sendero edge worker — one Bun+Hono instance serving MCP + WhatsApp + Slack + Discord adapters on top of @sendero/tools. Deployable to Vercel Edge, Cloudflare Workers, Fly, Deno Deploy, or bare Bun.",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "PORT=${PORT:-3021} bun run --watch src/server.ts",
    "start": "PORT=${PORT:-3021} bun run src/server.ts",
    "build": "true",
    "typecheck": "tsc --noEmit",
    "vercel:build": "vercel build --prod --cwd . --scope tcxcxs-projects --non-interactive",
    "vercel:deploy": "vercel deploy --prebuilt --prod --cwd . --scope tcxcxs-projects --non-interactive"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "@circle-fin/x402-batching": "^2.1.0",
    "@circle-fin/app-kit": "^1.3.0",
    "@circle-fin/adapter-viem-v2": "^1.8.2",
    "@circle-fin/developer-controlled-wallets": "^8.0.0",
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "ai": "^6.0.0",
    "@duffel/api": "^4.0.0",
    "@sendero/agent": "workspace:*",
    "@sendero/arc": "workspace:*",
    "@sendero/circle": "workspace:*",
    "@sendero/duffel": "workspace:*",
    "@sendero/guest": "workspace:*",
    "@sendero/llms": "workspace:*",
    "@sendero/nanopayments": "workspace:*",
    "@sendero/seo": "workspace:*",
    "@sendero/tools": "workspace:*",
    "viem": "^2.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
