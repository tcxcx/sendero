{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@sendero/llms": ["../../packages/llms/src/index.ts"],
      "@sendero/llms/*": ["../../packages/llms/src/*"],
      "@sendero/seo": ["../../packages/seo/src/index.ts"],
      "@sendero/seo/*": ["../../packages/seo/src/*"],
      "@sendero/tools": ["../../packages/tools/src/index.ts"],
      "@sendero/tools/adapters/ai-sdk": ["../../packages/tools/src/adapters/ai-sdk.ts"],
      "@sendero/tools/adapters/mcp": ["../../packages/tools/src/adapters/mcp.ts"],
      "@sendero/tools/agent": ["../../packages/tools/src/agent.ts"],
      "@sendero/tools/meter": ["../../packages/tools/src/meter.ts"],
      "@sendero/tools/pricing": ["../../packages/tools/src/pricing.ts"],
      "@sendero/tools/types": ["../../packages/tools/src/types.ts"],
      "@sendero/circle": ["../../packages/circle/src/index.ts"],
      "@sendero/circle/*": ["../../packages/circle/src/*"],
      "@sendero/arc": ["../../packages/arc/src/index.ts"],
      "@sendero/arc/*": ["../../packages/arc/src/*"],
      "@sendero/billing": ["../../packages/billing/src/index.ts"],
      "@sendero/billing/*": ["../../packages/billing/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "api/**/*.ts",
    "../../packages/llms/src/**/*.ts",
    "../../packages/seo/src/**/*.ts",
    "../../packages/tools/src/**/*.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "../../packages/llms/src/**/*.test.ts",
    "../../packages/seo/src/**/*.test.ts",
    "../../packages/tools/src/**/*.test.ts"
  ]
}
