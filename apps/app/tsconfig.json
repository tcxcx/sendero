      "@sendero/auth/clerk/server": ["../../packages/auth/src/clerk.server.ts"],
      "@sendero/auth/msca": ["../../packages/auth/src/msca.ts"],
      "@sendero/auth/tenant": ["../../packages/auth/src/tenant.ts"],
      "@sendero/auth/middleware": ["../../packages/auth/src/middleware.ts"],
      "@sendero/auth/store": ["../../packages/auth/src/store.ts"],
      "@sendero/auth/types": ["../../packages/auth/src/types.ts"],
      "@sendero/database": ["../../packages/database/src/index.ts"],
      "@sendero/database/types": ["../../packages/database/src/types.ts"]
