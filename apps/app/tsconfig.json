{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],

      "@sendero/*": ["../../packages/*/src/index.ts"],

      "@sendero/env/*": ["../../packages/env/src/*"],
      "@sendero/arc/*": ["../../packages/arc/src/*"],
      "@sendero/auth/*": ["../../packages/auth/src/*"],
      "@sendero/billing/*": ["../../packages/billing/src/*"],
      "@sendero/circle/*": ["../../packages/circle/src/*"],
      "@sendero/collaboration/*": ["../../packages/collaboration/src/*"],
      "@sendero/commission/*": ["../../packages/commission/src/*"],
      "@sendero/database/*": ["../../packages/database/src/*"],
      "@sendero/duffel/*": ["../../packages/duffel/src/*"],
      "@sendero/encryption/*": ["../../packages/encryption/src/*"],
      "@sendero/guest/*": ["../../packages/guest/src/*"],
      "@sendero/intelligence/*": ["../../packages/intelligence/src/*"],
      "@sendero/kapso/*": ["../../packages/kapso/src/*"],
      "@sendero/langfuse/*": ["../../packages/langfuse/src/*"],
      "@sendero/llms/*": ["../../packages/llms/src/*"],
      "@sendero/location/*": ["../../packages/location/src/*"],
      "@sendero/locale/*": ["../../packages/locale/src/*"],
      "@sendero/multisig/*": ["../../packages/multisig/src/*"],
      "@sendero/nanopayments/*": ["../../packages/nanopayments/src/*"],
      "@sendero/notifications/*": ["../../packages/notifications/src/*"],
      "@sendero/ocr/*": ["../../packages/ocr/src/*"],
      "@sendero/sherpa/*": ["../../packages/sherpa/src/*"],
      "@sendero/seo/*": ["../../packages/seo/src/*"],
      "@sendero/slack/*": ["../../packages/slack/src/*"],
      "@sendero/tools/*": ["../../packages/tools/src/*"],
      "@sendero/transfer-policy/*": ["../../packages/transfer-policy/src/*"],
      "@sendero/vault/*": ["../../packages/vault/src/*"],
      "@sendero/webhooks/*": ["../../packages/webhooks/src/*"],
      "@sendero/whatsapp/*": ["../../packages/whatsapp/src/*"],
      "@sendero/workflows/*": ["../../packages/workflows/src/*"],

      "@sendero/ui/cn": ["../../packages/ui/src/utils/cn.ts"],
      "@sendero/ui/components/*": ["../../packages/ui/src/components/*"],
      "@sendero/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@sendero/ui/illustrations/*": ["../../packages/ui/src/illustrations/*"],
      "@sendero/ui/*": ["../../packages/ui/src/components/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "**/*.test.ts", "**/*.test.tsx", "scripts/_local/**"]
}
