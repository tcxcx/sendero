      "@sendero/arc": ["../../packages/sendero-arc/src/index.ts"],
      "@sendero/arc/chain": ["../../packages/sendero-arc/src/chain.ts"],
      "@sendero/arc/identity": ["../../packages/sendero-arc/src/identity.ts"],
      "@sendero/arc/jobs": ["../../packages/sendero-arc/src/jobs.ts"],
      "@sendero/arc/bridge-chains": ["../../packages/sendero-arc/src/bridge-chains.ts"],
      "@sendero/erc8183": ["../../packages/sendero-erc8183/src/index.ts"],
      "@sendero/erc8183/client": ["../../packages/sendero-erc8183/src/client.ts"],
      "@sendero/duffel": ["../../packages/sendero-duffel/src/index.ts"],
      "@sendero/circle": ["../../packages/sendero-circle/src/index.ts"],
      "@sendero/circle/wallets": ["../../packages/sendero-circle/src/wallets.ts"],
