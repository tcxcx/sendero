KAPSO_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=1133326556530962
PROVIDER_MODEL_NAME=gpt-5-mini

# Slack escalation for cases the agent cannot safely resolve from docs/context.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=

# Sendero app API used by support context tools.
# SUPPORT_TOOLS_SECRET can override KAPSO_WEBHOOK_SECRET if desired.
KAPSO_WEBHOOK_BASE_URL=https://app.sendero.travel
KAPSO_WEBHOOK_SECRET=
SENDERO_APP_ORIGIN=https://app.sendero.travel
SUPPORT_TOOLS_SECRET=

# Optional: direct human escalation owner for Slack support tickets.
# Set the Slack user ID to notify the owner directly with <@U...>.
SLACK_ESCALATION_ASSIGNEE_ID=
SUPPORT_ESCALATION_ASSIGNEE_NAME=
SUPPORT_ESCALATION_ASSIGNEE_EMAIL=

# Optional: WhatsApp Flow live-test ids created/published in Kapso for the
# support number. Use SENDERO_WHATSAPP_FLOW_MODE=draft while testing a draft.
SENDERO_SUPPORT_TRIP_INTAKE_FLOW_ID=
SENDERO_SUPPORT_REQUEST_FLOW_ID=
SENDERO_SUPPORT_LOGIN_SIGNUP_FLOW_ID=
SENDERO_SUPPORT_QUOTE_APPROVAL_FLOW_ID=
SENDERO_SUPPORT_ANCILLARIES_FLOW_ID=
SENDERO_SUPPORT_DISRUPTION_HELP_FLOW_ID=
SENDERO_SUPPORT_PREFUND_CLAIM_FLOW_ID=
SENDERO_SUPPORT_BOOKING_CHANGE_FLOW_ID=
SENDERO_SUPPORT_ACCOMMODATION_FLOW_ID=
SENDERO_SUPPORT_CAR_TRANSFER_FLOW_ID=
SENDERO_SUPPORT_RESTAURANT_EXPERIENCE_FLOW_ID=
SENDERO_SUPPORT_NFT_TRIP_GALLERY_FLOW_ID=
SENDERO_SUPPORT_REFUND_ESCROW_FLOW_ID=
SENDERO_WHATSAPP_FLOW_MODE=

# Optional: mounted repo context inside Kapso's remote agent sandbox.
AGENT_SANDBOX_GITHUB_REPO_URL=https://github.com/tcxcx/sendero
AGENT_SANDBOX_GITHUB_REPO_BRANCH=main
AGENT_SANDBOX_GITHUB_PAT=
AGENT_SANDBOX_NETWORK_MODE=allow_list
AGENT_SANDBOX_ALLOWED_OUTBOUND_HOSTS=api.sendero.travel,docs.kapso.ai
